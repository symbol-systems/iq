directive @rdf(ns: String, iri : String) repeatable on FIELD_DEFINITION | OBJECT | ARGUMENT_DEFINITION
schema { 
   query: Query
}
type Query {
Concepts: [skos_Concept]
skos_inScheme (this: ID! @rdf(iri:"skos:inScheme")): [skos_Concept]
}

type skos_Concept @rdf(iri:"skos:Concept") {
_id: ID!
label: String! @rdf(iri:"skos:prefLabel")
}