<https://test.symbol.systems/cases#hbs/index.hbs> <http://www.w3.org/2011/content#chars> "<div>\n    <a href=\"[{@this}]\"><h1>[{ skos:prefLabel }]</h1></a>\n    <p>[{data}]</p>\n\n    <p>[{dct:description}]</p>\n\n    <p>\n        <a href=\"[{@this}]\"><h1>[{ label }]</h1></a>\n    </p>\n\n    <h3>Test Cases</h3>\n    <test-cases>\n        [{#follow this \"inScheme\" }]\n            <h1>Scheme:  <a href=\"[{ @this }]\">[{label}]</a></h1>\n            [{>hbs/hello.hbs}]\n        [{/follow}]\n    </test-cases>\n\n</div>\n"^^<http://www.iana.org/assignments/media-types/text/x-handlebars> <https://test.symbol.systems/cases#> .
