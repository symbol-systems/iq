package systems.symbol.render;

import com.github.jknack.handlebars.Handlebars;
import com.github.jknack.handlebars.Template;

//import systems.symbol.rdf4j.util.TripleFinder;
import org.eclipse.rdf4j.namedMap.IRI;

import java.io.IOException;
import java.io.OutputStream;
import java.io.OutputStreamWriter;
import java.util.Map;

public class TripleRenderer implements Renderer {
    IQ kbms;
    String[] LABELS = {"@label","skos:prefLabel", "dct:title", "dc:title", "dcterms:title", "rdfs:label"};
    Handlebars hbs;

    public TripleRenderer(IQ kbms) {
        this.kbms=kbms;
        hbs = new Handlebars(new TripleTemplateLoader(kbms));
        hbs.registerHelper("follow", new FollowQueryHelper(kbms));
    }

    public void blockSyntax() {
        hbs.setStartDelimiter("[{");
        hbs.setEndDelimiter("}]");
    }

    public void hbsSyntax() {
        hbs.setStartDelimiter("{{");
        hbs.setEndDelimiter("}}");
    }

    @Override
    public void render(String templatePath, Map namedMap, OutputStream out) throws IOException {
        IRI templateIRI = kbms.getTriples().getValueFactory().createIRI(templatePath);
        System.out.println("render.template.script: "+templateIRI+" -> ");
        Template template = hbs.compile(templateIRI.stringValue());
        if (template==null) throw new IOException("Template not found: "+templatePath);
        System.out.println("render.template.compiled: "+template);

        Map kb_model = TripleFinder.mapOf(kbms.getTriples(), kbms.getNS(), templateIRI,null, kbms.getIdentity());
        if (namedMap!=null) kb_model.putAll(namedMap);
        label(kb_model);
        System.out.println("render.template.namedMap: "+templateIRI+"->"+kb_model);
        OutputStreamWriter writer = new OutputStreamWriter(out);
        template.apply(kb_model, writer);
        writer.flush();
    }

    String label(Map namedMap) {
        for(String l: LABELS) {
            if (namedMap.containsKey(l)) {
                String label = namedMap.get(l).toString();
                namedMap.put("label",label);
                return label;
            }
        }
        return null;
    }
}
