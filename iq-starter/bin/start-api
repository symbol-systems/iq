#!/bin/bash
# Start the IQ REST API server
# Usage: ./bin/start-api [--port 8080] [--mode development]

set -e

# Colors
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m' # No Color

# Defaults
PORT=${PORT:-8080}
MODE=${MODE:-development}

# Parse arguments
while [[ $# -gt 0 ]]; do
  case $1 in
    --port) PORT="$2"; shift 2 ;;
    --mode) MODE="$2"; shift 2 ;;
    *) echo "Unknown option: $1"; exit 1 ;;
  esac
done

echo -e "${YELLOW}Starting IQ API server...${NC}"
echo "  Port: $PORT"
echo "  Mode: $MODE"

# Check Java
if ! command -v java &> /dev/null; then
  echo -e "${RED}✗ Java not found. Install Java 21+${NC}"
  exit 1
fi

JAVA_VERSION=$(java -version 2>&1 | head -1)
echo "  Java: $JAVA_VERSION"

# Navigate to iq-apis module
cd "$(dirname "$0")/../.."

# Build if needed
if [ ! -d "iq-apis/target" ]; then
  echo -e "${YELLOW}Building iq-apis (first run, ~1-2 min)...${NC}"
  ./mvnw -pl iq-apis -am clean install -DskipTests > /tmp/iq-build.log 2>&1
  if [ $? -ne 0 ]; then
    echo -e "${RED}✗ Build failed. See /tmp/iq-build.log${NC}"
    exit 1
  fi
fi

# Start with Quarkus dev mode (recompilation on save)
echo ""
echo -e "${GREEN}✓ Starting IQ API$${NC}"
echo ""
echo "Dev UI: http://localhost:$PORT/q/dev/"
echo "Health: http://localhost:$PORT/health"
echo ""
echo "Try: curl http://localhost:$PORT/chat"
echo ""
echo "Press Ctrl+C to stop"
echo ""

./mvnw \
  -pl iq-apis \
  -am \
  -DskipTests \
  -Dquarkus.http.port=$PORT \
  -Dquarkus.log.level=$([[ "$MODE" == "production" ]] && echo "INFO" || echo "DEBUG") \
  quarkus:dev
