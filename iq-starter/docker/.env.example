# Environment template for Docker Compose
# Copy to .env and edit with your values

# ============================================
# LLM Configuration
# ============================================

# Choose: openai, groq, local, or none
IQ_LLM_PROVIDER=openai

# OpenAI API key (if using openai provider)
OPENAI_API_KEY=sk-your-key-here

# Model name
IQ_LLM_MODEL=gpt-3.5-turbo

# ============================================
# Authentication & Security 
# ============================================

# JWT secret for authentication (change in production!)
IQ_AUTH_JWT_SECRET=super-secret-key-change-me

# Default realm
IQ_REALM_DEFAULT=default

# ============================================
# Database (optional, uses in-memory by default)
# ============================================

# Leave empty to use in-memory (faster for dev, no persistence)
# Or use PostgreSQL for production:
# DATABASE_URL=postgresql://iq:password@postgres:5432/iq_prod

POSTGRES_PASSWORD=change-me-in-production

# ============================================
# Slack Integration
# ============================================

# Get from https://api.slack.com/apps
SLACK_BOT_TOKEN=xoxb-your-token-here

# ============================================
# GitHub Integration
# ============================================

# Get from https://github.com/settings/tokens
GITHUB_TOKEN=ghp_your-token-here

# ============================================
# AWS Integration
# ============================================

# AWS credentials for S3, EC2, CloudWatch access
AWS_ACCESS_KEY_ID=AKIAI...
AWS_SECRET_ACCESS_KEY=your-secret-key

# ============================================
# Other Integrations
# ============================================

# Salesforce
SALESFORCE_CLIENT_ID=your-client-id
SALESFORCE_CLIENT_SECRET=your-client-secret

# Stripe
STRIPE_API_KEY=sk_test_...

# ============================================
# Optional Configuration
# ============================================

# Java memory limit
JAVA_OPTS=-Xmx4g

# Request timeout (seconds)
REQUEST_TIMEOUT=30
