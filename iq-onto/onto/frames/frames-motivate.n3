@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix sdo: <http://schema.org/> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix vcard: <http://www.w3.org/2006/vcard/ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

# Logical Ontology Definitions (experimental, private or proprietary)

@prefix raci: <https://symbol.systems/v0/onto/raci#>.
@prefix fact: <https://symbol.systems/v0/onto/fact#>.
@prefix frames: <https://symbol.systems/v0/onto/frames#>.
@prefix dama: <https://symbol.systems/v0/onto/dama#>.
@prefix fab: <https://symbol.systems/v0/onto/fab#>.
@prefix pmo: <https://symbol.systems/v0/onto/pmo#>.
@prefix gg: <https://symbol.systems/v0/onto/gg#>.
@prefix iq-test: <https://test.symbol.systems/cases#>.

# Model Definitions

frames:Motivation
dct:title "Motivation"@en;
.

frames:CorporateMission
rdfs:subClassOf frames:Motivation;
rdfs:isDefinedBy frames:Ontology;
dct:title "Corporate Mission"@en;
dct:description "The aims, values and plan of the orgnisation"@en;
.
frames:Executive raci:responsible frames:CorporateMission.

frames:CorporateVision
rdfs:subClassOf frames:Motivation;
rdfs:isDefinedBy frames:Ontology;
dct:title "Corporate Vision"@en;
dct:description "The organisation's desired future state"@en;
.
frames:Business raci:responsible frames:CorporateVision.

frames:Driver
rdfs:subClassOf frames:Motivation;
rdfs:isDefinedBy frames:Ontology;
dct:title "External Drivers"@en;
dct:description "External events or market forces that drive the project"@en;
.

frames:ExternalDriver
rdfs:subClassOf frames:Motivation;
rdfs:subClassOf frames:Driver;
rdfs:isDefinedBy frames:Ontology;
dct:title "External Drivers"@en;
dct:description "External events or market forces that drive the project"@en;
.

frames:InternalDriver
rdfs:subClassOf frames:Motivation;
rdfs:subClassOf frames:Driver;
rdfs:isDefinedBy frames:Ontology;
dct:title "Internal Drivers"@en;
dct:description "Internal initiatives or imperatives that motivate the project"@en;
.

frames:ProjectGoal
rdfs:subClassOf frames:Motivation;
rdfs:isDefinedBy frames:Ontology;
dct:title "Project Goals"@en;
dct:description "High-level plan of what the project will deliver"@en;
.

frames:ProjectObjective
rdfs:subClassOf frames:Motivation;
rdfs:isDefinedBy frames:Ontology;
dct:title "Project Objectives"@en;
dct:description "Outcomes of the project on people, assets, processes and tools"@en;
.

frames:BusinessGoal
rdfs:subClassOf frames:Motivation;
rdfs:isDefinedBy frames:Ontology;
dct:title "Project Goals"@en;
dct:description "High-level view of what the business plans to achieve"@en;
.

frames:BusinessObjective
rdfs:subClassOf frames:Motivation;
rdfs:isDefinedBy frames:Ontology;
dct:title "Project Objectives"@en;
dct:description "Outcomes of the business with respect to customers, people, assets, processes and tools"@en;
.
