@prefix : <https://symbol.systems/v0/onto/demo/dama/frames/dmbok#>.

# Canonical Ontology Definitions (e.g. W3C standards)

@prefix dbr:  <https://dbpedia.org/page/>.
@prefix dcat: <http://www.w3.org/ns/dcat#> .
@prefix cnt: <http://www.w3.org/2011/content#>.
@prefix dct: <http://purl.org/dc/terms/> .
@prefix dctype: <http://purl.org/dc/dcmitype/> .
@prefix foaf: <http://xmlns.com/foaf/0.1/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix sdo: <http://schema.org/> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix vcard: <http://www.w3.org/2006/vcard/ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

# Logical Ontology Definitions (experimental, private or proprietary)

@prefix raci: <https://symbol.systems/v0/onto/raci#>.
@prefix fact: <https://symbol.systems/v0/onto/fact#>.
@prefix frames: <https://symbol.systems/v0/onto/frames#>.
@prefix dama: <https://symbol.systems/v0/onto/dama#>.
@prefix pmo: <https://symbol.systems/v0/onto/pmo#>.
@prefix fab: <https://symbol.systems/v0/onto/fab#>.
@prefix IQ:  <https://symbol.systems/v0/onto/gg#>.
@prefix iq-test: <https://test.symbol.systems/cases#>.

# Model Definitions

dama:Functional
    a skos:Concept;
    dct:title "Functional Area"@en;
.
dama:FunctionalGoalsAndPrinciples
    rdfs:subClassOf dama:Functional;
    dct:title "Goals and Principles"@en;
.
dama:FunctionalOrganisationAndCulture
    a dama:FunctionalGoalsAndPrinciples;
    a frames:People;
    dct:title "Organisation and Culture"@en;
.
dama:FunctionalActivities
    a dama:FunctionalGoalsAndPrinciples;
    a frames:Processes;
    dct:title "Activities"@en;
.
dama:FunctionalDeliverables
    a dama:FunctionalGoalsAndPrinciples;
    a frames:Technology;
    rdfs:subClassOf pmo:Deliverable;
    dct:title "Deliverables"@en;
.
dama:FunctionalRolesAndResponsibilities
    a dama:FunctionalGoalsAndPrinciples;
    a frames:People;
    dct:title "Roles and Responsibilities"@en;
.
dama:FunctionalPracticesAndTechniques
    a dama:FunctionalGoalsAndPrinciples;
    a frames:Processes;
    dct:title "Practices and Techniques"@en;
.
dama:FunctionalTools
    a dama:FunctionalGoalsAndPrinciples;
    a frames:Technology;
    a frames:Tools;
    dct:title "Tools"@en;
.
