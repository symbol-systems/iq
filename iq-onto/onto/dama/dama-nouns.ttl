@prefix : <https://symbol.systems/v0/onto/dama#>.

# Canonical Ontology Definitions (e.g. W3C standards)

@prefix dbr:  <https://dbpedia.org/page/>.
@prefix dcat: <http://www.w3.org/ns/dcat#> .
@prefix cnt: <http://www.w3.org/2011/content#>.
@prefix dct: <http://purl.org/dc/terms/> .
@prefix dctype: <http://purl.org/dc/dcmitype/> .
@prefix foaf: <http://xmlns.com/foaf/0.1/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix sdo: <http://schema.org/> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix vcard: <http://www.w3.org/2006/vcard/ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

# Logical Ontology Definitions (experimental, private or proprietary)

@prefix raci: <https://symbol.systems/v0/onto/raci#>.
@prefix fact: <https://symbol.systems/v0/onto/fact#>.
@prefix frames: <https://symbol.systems/v0/onto/frames#>.
@prefix dama: <https://symbol.systems/v0/onto/dama#>.
@prefix fab: <https://symbol.systems/v0/onto/fab#>.
@prefix pmo: <https://symbol.systems/v0/onto/pmo#>.
@prefix IQ:  <https://symbol.systems/v0/onto/gg#>.
@prefix iq-test: <https://test.symbol.systems/cases#>.

# Model Definitions

dama:Ontology
a owl:Ontology;
dct:title "DAMA"@en;
.

skos:Concept rdfs:subClassOf skos:Concept.

dama:DAMA
skos:prefLabel "DAMA"@en;
skos:hasTopConcept IQ: ;
.

dama:Governance
rdfs:isDefinedBy dama:Ontology;
a   skos:Concept;
skos:inScheme dama:DAMA;
dct:title   "Governance"@en;
.
dama:DataGovernance
rdfs:isDefinedBy dama:Ontology;
a   skos:Concept;
skos:inScheme dama:DAMA;
a   frames:Processes;
rdfs:subClassOf dama:Governance;
dct:title   "Data Governance"@en;
rdfs:seeAlso   dbr:Data_governance;
.


dama:DataSovereignty
rdfs:isDefinedBy dama:Ontology;
a   skos:Concept;
skos:inScheme dama:DAMA;
dct:title  "Data Sovereignty"@en;
dct:description "Data sovereignty is the idea that data are subject to the laws and governance structures within the nation it is collected."@en;
rdfs:seeAlso   dbr:Data_sovereignty;
.


dama:DataLineage
rdfs:isDefinedBy dama:Ontology;
a   skos:Concept;
skos:inScheme dama:DAMA;
dct:title  "Data Lineage"@en;
dct:description "Data lineages describes how and where data originates, its processing logic and destination."@en;
.
dama:PII
rdfs:isDefinedBy dama:Ontology;
a   skos:Concept;
skos:inScheme dama:DAMA;
dct:title   "Personally Identifiable Information"@en;
.
dama:Policy
rdfs:isDefinedBy dama:Ontology;
a   skos:Concept;
skos:inScheme dama:DAMA;
dct:title   "Policy"@en;
.
dama:DataPolicy
rdfs:isDefinedBy dama:Ontology;
rdfs:subClassOf dama:Policy;
dct:title   "Data Policy"@en;
.
dama:BestPractice
rdfs:isDefinedBy dama:Ontology;
a   skos:Concept;
skos:inScheme dama:DAMA;
a   frames:Processes;
dct:title   "Best Practice"@en;
.
dama:DataManagement
rdfs:isDefinedBy dama:Ontology;
a   skos:Concept;
skos:inScheme dama:DAMA;
a   frames:Processes;
dct:title   "Data Management"@en;
frames:manages dama:Data;
.
dama:MasterDataManagement
rdfs:isDefinedBy dama:Ontology;
a   skos:Concept;
skos:inScheme dama:DAMA;
a   frames:Processes;
a   frames:Tools;
dct:title   "Master Data Management"@en;
frames:manages dama:MasterData;
.
dama:MetaDataManagement
rdfs:isDefinedBy dama:Ontology;
a   skos:Concept;
skos:inScheme dama:DAMA;
a   frames:Processes;
a   frames:Tools;
dct:title   "Meta Data Management"@en;
frames:manages dama:MetaData;
.
dama:DataAccountability
a   skos:Concept;
skos:inScheme dama:DAMA;
a   frames:Processes;
a   frames:People;
dct:title "Data Accountability"@en;
.

dama:DataQuality
a   skos:Concept;
skos:inScheme dama:DAMA;
a   frames:Processes;
a   frames:People;
dct:title "Data Quality"@en;
.

dama:DataProblem
a   skos:Concept;
skos:inScheme dama:DAMA;
rdfs:subClassOf dama:DataQuality;
skos:inScheme dama:DataQuality;
dct:title "Data Problems"@en;
.

dama:DataCulture
a   skos:Concept;
skos:inScheme dama:DAMA;
a   frames:Processes;
a   frames:People;
dct:title "Data Culture"@en;
.

dama:Catalog
rdfs:subClassOf dcat:Catalog;
a   skos:Concept;
skos:inScheme dama:DAMA;
a   frames:Tools;
dct:title "Data Catalog"@en;
.
dama:DataDictionary
a   skos:Concept;
skos:inScheme dama:DAMA;
a   frames:Tools;
dct:title "Data Dictionary"@en;
.
dama:BusinessGlossary
a   skos:Concept;
skos:inScheme dama:DAMA;
a   frames:Tools;
dct:title "Business Glossary"@en;
.
dama:Dataset
rdfs:subClassOf dcat:Dataset;
a   skos:Concept;
skos:inScheme dama:DAMA;
a   frames:Tools;
dct:title "Dataset"@en;
.
dama:DataDiscovery
rdfs:subClassOf dcat:DataService;
a   skos:Concept;
skos:inScheme dama:DAMA;
a   frames:Tools;
dct:title "Data Discovery"@en;
.
dama:DataService
rdfs:subClassOf dcat:DataService;
a   skos:Concept;
skos:inScheme dama:DAMA;
a   frames:Tools;
dct:title "Data Service"@en;
.

dama:Activity
rdfs:isDefinedBy dama:Ontology;
a   skos:Concept;
skos:inScheme dama:DAMA;
a   frames:Processes;
dct:title "Activity"@en;
.

dama:Risk
rdfs:isDefinedBy dama:Ontology;
a   skos:Concept;
skos:inScheme dama:DAMA;
dct:title "Risk"@en;
.

dama:RiskMitigation
rdfs:isDefinedBy dama:Ontology;
a   skos:Concept;
skos:inScheme dama:DAMA;
dct:title "Risk Mitigation"@en;
.

dama:DataValueChain
a   frames:Processes;
a   dama:Asset;
dct:title  "Data Value Chain"@en;
dct:description  "Information = Data + Meaning. Knowledge = Information + Context. Wisdom = Knowledge + Action"@en;
rdfs:seeAlso   dama:Data;
rdfs:seeAlso   dama:Information;
rdfs:seeAlso   dama:MetaData;
rdfs:seeAlso   dama:Knowledge;
rdfs:seeAlso   dama:Wisdom;
.

dama:Asset
rdfs:isDefinedBy dama:Ontology;
a   skos:Concept;
skos:inScheme dama:DAMA;
dct:title  "Data Asset"@en;
dct:description "A data asset is a valuable and durable digital resource."@en;
rdfs:seeAlso   dbr:Data_asset;
.

dama:Data
rdfs:isDefinedBy dama:Ontology;
a   skos:Concept;
skos:inScheme dama:DAMA;
a   dama:Asset;
dct:title  "Data"@en;
dct:description "Data represents objects and events."@en;
rdfs:seeAlso   dbr:Data;
fact:example [
dct:title "31/10/1972"@en;
]
.
dama:Information
rdfs:isDefinedBy dama:Ontology;
a   skos:Concept;
skos:inScheme dama:DAMA;
a   dama:Asset;
 dct:title  "Information"@en;
dct:description "Information is organised data."@en;
rdfs:seeAlso   dbr:Information;
fact:example [
dct:title "31st October"@en;
]
.
dama:MetaData
rdfs:isDefinedBy dama:Ontology;
a   skos:Concept;
skos:inScheme dama:DAMA;
a   dama:Asset;
dct:title  "Meta Data"@en;
dct:description "Metadata provides context to raw data."@en;
rdfs:seeAlso   dbr:Meta_data;
fact:example [
dct:title "Birthday is a date"@en;
]
.
dama:Knowledge
rdfs:isDefinedBy dama:Ontology;
a   skos:Concept;
skos:inScheme dama:DAMA;
a   dama:Asset;
dct:title  "Knowledge"@en;
dct:description "Knowledge is contextually useful information."@en;
rdfs:seeAlso   dbr:Meta_data;
fact:example [
dct:title "It's my birthday"@en;
]
.
dama:Wisdom
rdfs:isDefinedBy dama:Ontology;
a   skos:Concept;
skos:inScheme dama:DAMA;
a   dama:Asset;
dct:title  "Wisdom"@en;
dct:description "Wisdom is knowledge expressed as actions."@en;
rdfs:seeAlso   dbr:Wisdom;
fact:example [
dct:title "Invite friends and family"@en;
]
.
dama:Technology
rdfs:isDefinedBy dama:Ontology;
a   skos:Concept;
skos:inScheme dama:DAMA;
rdfs:subClassOf frames:Tools;
dct:title "Technology"@en;
rdfs:seeAlso frames:Tools;
dct:description "Technology comprises techniques, skills, methods, and processes used in the production of value."@en;
.
dama:MasterData
rdfs:isDefinedBy dama:Ontology;
a   dama:Knowledge;
a   skos:Concept;
skos:inScheme dama:DAMA;
a   dama:Asset;
a   frames:Tools;
dct:title  "Master Data"@en;
dct:description "Master Data describes the organisation's key data entities and their attributes."@en;
rdfs:seeAlso   dbr:Master_data;
.
dama:KnowledgeBase
rdfs:isDefinedBy dama:Ontology;
a   dama:Technology;
a   skos:Concept;
skos:inScheme dama:DAMA;
a   frames:Tools;
rdfs:seeAlso frames:Tools;
dct:title "Knowledge Base"@en;
dct:description "A Knowledge Base understands the intent of users and empowers them with the right knowledge, at the right time and the right place."@en;
.

dama:DataBase
rdfs:isDefinedBy dama:Ontology;
a   dama:Technology;
a   skos:Concept;
skos:inScheme dama:DAMA;
a   frames:Tools;
rdfs:seeAlso frames:Tools;
dct:title "Database"@en;
dct:description "A Database manages the organisation, retrieval and storage of structured information ."@en;
.
