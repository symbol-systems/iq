@prefix : <https://symbol.systems/v0/onto/dama#>.

# Canonical Ontology Definitions (e.g. W3C standards)

@prefix dbr:  <https://dbpedia.org/page/>.
@prefix dcat: <http://www.w3.org/ns/dcat#> .
@prefix cnt: <http://www.w3.org/2011/content#>.
@prefix dct: <http://purl.org/dc/terms/> .
@prefix dctype: <http://purl.org/dc/dcmitype/> .
@prefix foaf: <http://xmlns.com/foaf/0.1/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix sdo: <http://schema.org/> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix vcard: <http://www.w3.org/2006/vcard/ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

# Logical Ontology Definitions (experimental, private or proprietary)

@prefix raci: <https://symbol.systems/v0/onto/raci#>.
@prefix fact: <https://symbol.systems/v0/onto/fact#>.
@prefix frames: <https://symbol.systems/v0/onto/frames#>.
@prefix dama: <https://symbol.systems/v0/onto/dama#>.
@prefix fab: <https://symbol.systems/v0/onto/fab#>.
@prefix pmo: <https://symbol.systems/v0/onto/pmo#>.
@prefix gg: <https://symbol.systems/v0/onto/gg#>.
@prefix iq-test: <https://test.symbol.systems/cases#>.


# Property Definitions

dama:stewards
    rdfs:subPropertyOf dama:uses;
    rdfs:label "stewards"@en;
    rdfs:domain dama:DataSteward;
    rdfs:range dama:Dataset;
.
dama:owns
    rdfs:label "owns"@en;
    rdfs:domain dama:DataOwner;
    rdfs:range dama:Dataset;
.
dama:produces
    rdfs:subPropertyOf dama:uses;
    rdfs:label "produces"@en;
    rdfs:domain dama:DataProducer;
    rdfs:range dama:Dataset;
.
dama:consumes
    rdfs:subPropertyOf dama:uses;
    rdfs:label "consumes"@en;
    rdfs:domain dama:DataConsumer;
    rdfs:range dama:Dataset;
.
dama:uses
    rdfs:label "uses"@en;
    rdfs:domain dama:DataUser;
    rdfs:range dama:Dataset;
.
dama:curates
    rdfs:subPropertyOf dama:stewards;
    rdfs:label "curates"@en;
    rdfs:domain dama:DataSteward;
    rdfs:range dama:DataCatalog;
.
dama:has_policy
    rdfs:subPropertyOf dama:stewards;
    rdfs:label "has policy"@en;
#    rdfs:domain skos:Concept;
    rdfs:range dama:DataPolicy;
.

# Experimental

dama:collates
    rdfs:label "collates"@en;
    rdfs:domain dama:Information;
    rdfs:range dama:Data;
.
dama:derives
    rdfs:domain dama:Information;
    rdfs:range dama:Knowledge;
.
dama:decides
    rdfs:domain dama:Knowledge;
    rdfs:range dama:Wisdom;
.

dama:DataValueChain
    a   frames:Processes;
    a   dama:Asset;
    dct:title  "Data Value Chain"@en;
    dct:description  "Information = Data + Meaning. Knowledge = Information + Context. Wisdom = Knowledge + Action"@en;
.
