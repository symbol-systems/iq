@prefix : <https://symbol.systems/v0/onto/dama#>.

# Canonical Ontology Definitions (e.g. W3C standards)

@prefix dbr:  <https://dbpedia.org/page/>.
@prefix dcat: <http://www.w3.org/ns/dcat#> .
@prefix cnt: <http://www.w3.org/2011/content#>.
@prefix dct: <http://purl.org/dc/terms/> .
@prefix dctype: <http://purl.org/dc/dcmitype/> .
@prefix foaf: <http://xmlns.com/foaf/0.1/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix sdo: <http://schema.org/> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix vcard: <http://www.w3.org/2006/vcard/ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

# Logical Ontology Definitions (experimental, private or proprietary)

@prefix raci: <https://symbol.systems/v0/onto/raci#>.
@prefix fact: <https://symbol.systems/v0/onto/fact#>.
@prefix frames: <https://symbol.systems/v0/onto/frames#>.
@prefix dama: <https://symbol.systems/v0/onto/dama#>.
@prefix fab: <https://symbol.systems/v0/onto/fab#>.
@prefix pmo: <https://symbol.systems/v0/onto/pmo#>.

@prefix IQ:  <https://symbol.systems/v0/onto/gg#>.
@prefix iq-test: <https://test.symbol.systems/cases#>.

# Model Definitions

dama:Stakeholder
    rdfs:isDefinedBy dama:Ontology;
    a   skos:Concept;
    a   frames:People;
    dct:title   "Stakeholder"@en;
.

dama:DataUser
    a   skos:Concept;
    a   frames:People;
    dct:title "Data User"@en;
    dct:description "Uses data assets to achieve an outcome."@en;
.

dama:DataSteward
    rdfs:isDefinedBy dama:Ontology;
    a   skos:Concept;
    a   frames:People;
    rdfs:subClassOf dama:DataUser;
    dct:title  "Data Steward"@en;
    dct:description "A data steward is responsible for the quality and fitness for purpose of data assets."@en;
    rdfs:seeAlso   dbr:Data_steward;
.
dama:DataOwner
    rdfs:isDefinedBy dama:Ontology;
    a   skos:Concept;
    a   frames:People;
    rdfs:subClassOf dama:DataUser;
    dct:title   "Data Owner"@en;
    rdfs:seeAlso   dbr:Data_owner;
.
dama:DataCustodian
    rdfs:isDefinedBy dama:Ontology;
    a   skos:Concept;
    a   frames:People;
    rdfs:subClassOf dama:DataUser;
    dct:title   "Data Custodian"@en;
    rdfs:seeAlso   dbr:Data_custodian;
.

dama:DataModeller
    a   skos:Concept;
    a   frames:People;
    rdfs:subClassOf dama:DataUser;
    dct:title "Data Modeller"@en;
    dct:description "Defines the structure and meaningful of a dataset."@en;
.

dama:DataProducer
    a   skos:Concept;
    a   frames:People;
    rdfs:subClassOf dama:DataUser;
    dct:title "Data Producer"@en;
    dct:description "Creates or updates all or part of a dataset."@en;
.

dama:DataConsumer
    a   skos:Concept;
    a   frames:People;
    rdfs:subClassOf dama:DataUser;
    dct:title "Data Consumer"@en;
    dct:description "Consumes and combines data assets to achieve an outcome."@en;
.

dama:BusinessSponsorRole
    rdfs:subclassOf pmo:Role;
    dct:title "Business Sponsor"@en;
    dct:description "Senior leadership involved in planning and execution"@en;
.

dama:BusinessTechnologyRole
    rdfs:subclassOf pmo:Role;
    dct:title "Business Technologist"@en;
    dct:description "Technologist that understands the business and their tools"@en;
.
