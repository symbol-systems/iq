@prefix : <https://symbol.systems/v0/onto/raci#>.

# Canonical Ontology Definitions (e.g. W3C standards)

@prefix dbr:  <https://dbpedia.org/page/>.
@prefix dcat: <http://www.w3.org/ns/dcat#> .
@prefix cnt: <http://www.w3.org/2011/content#>.
@prefix dct: <http://purl.org/dc/terms/> .
@prefix dctype: <http://purl.org/dc/dcmitype/> .
@prefix foaf: <http://xmlns.com/foaf/0.1/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix sdo: <http://schema.org/> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix vcard: <http://www.w3.org/2006/vcard/ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

# Logical Ontology Definitions (experimental, private or proprietary)

@prefix raci: <https://symbol.systems/v0/onto/raci#>.
@prefix fact: <https://symbol.systems/v0/onto/fact#>.
@prefix frames: <https://symbol.systems/v0/onto/frames#>.
@prefix dama: <https://symbol.systems/v0/onto/dama#>.
@prefix fab: <https://symbol.systems/v0/onto/fab#>.
@prefix pmo: <https://symbol.systems/v0/onto/pmo#>.
@prefix gg: <https://symbol.systems/v0/onto/gg#>.
@prefix iq-test: <https://test.symbol.systems/cases#>.

# Model Definitions

raci:Ontology
dct:title "GG: RACI Vocabulary"@en;
.

raci:RACI
skos:prefLabel "RACI"@en;
skos:description "A framework for describing project roles"@en;
skos:hasTopConcept gg:;
.

raci:Role
rdfs:isDefinedBy raci:Ontology;
dct:title   "RACI Role"@en;
skos:inScheme raci:RACI;
.
raci:Task
rdfs:isDefinedBy raci:Ontology;
dct:title   "RACI Task"@en;
skos:inScheme raci:RACI;
.

raci:Responsible
rdfs:isDefinedBy raci:Ontology;
rdfs:subClassOf   raci:Role;
dct:title   "Responsible"@en;
skos:description "Those who do the work to achieve the task/deliverable."@en;
skos:inScheme raci:RACI;
.
raci:Accountable
rdfs:isDefinedBy raci:Ontology;
rdfs:subClassOf   raci:Role;
dct:title  "Accountable"@en;
skos:description "The role that is answerable for the task/deliverable."@en;
skos:inScheme raci:RACI;
.
raci:Support
rdfs:isDefinedBy raci:Ontology;
rdfs:subClassOf   raci:Role;
dct:title  "Supporting"@en;
skos:description "The role provides operational support."@en;
skos:inScheme raci:RACI;
.
raci:Consulted
rdfs:isDefinedBy raci:Ontology;
rdfs:subClassOf   raci:Role;
dct:title  "Consulted"@en;
dct:description "Subject matter experts with whom there is two-way dialogue."@en;
skos:inScheme raci:RACI;
.
raci:Informed
rdfs:isDefinedBy raci:Ontology;
rdfs:subClassOf   raci:Role;
dct:title  "Informed"@en;
dct:description "Those kept up-to-date on progress via one-way communication."@en;
skos:inScheme raci:RACI;
.
