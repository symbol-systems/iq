@prefix : <https://symbol.systems/v0/onto/skos/bsc#>.

# Canonical Ontology Definitions (e.g. W3C standards)

@prefix dbr:  <https://dbpedia.org/page/>.
@prefix dcat: <http://www.w3.org/ns/dcat#> .
@prefix cnt: <http://www.w3.org/2011/content#>.
@prefix dct: <http://purl.org/dc/terms/> .
@prefix dctype: <http://purl.org/dc/dcmitype/> .
@prefix foaf: <http://xmlns.com/foaf/0.1/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix sdo: <http://schema.org/> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix vcard: <http://www.w3.org/2006/vcard/ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

# Logical Ontology Definitions (experimental, private or proprietary)

@prefix raci: <https://symbol.systems/v0/onto/raci#>.
@prefix fact: <https://symbol.systems/v0/onto/fact#>.
@prefix frames: <https://symbol.systems/v0/onto/frames#>.
@prefix dama: <https://symbol.systems/v0/onto/dama#>.
@prefix fab: <https://symbol.systems/v0/onto/fab#>.
@prefix pmo: <https://symbol.systems/v0/onto/pmo#>.
@prefix IQ:  <https://symbol.systems/v0/onto/gg#>.
@prefix iq-test: <https://test.symbol.systems/cases#>.

# Model Definitions

@prefix iq-bsc: <https://symbol.systems/v0/onto/skos/balanced-scorecard#>.

:Ontology
    a owl:Ontology;
    dct:title "IQ: Balanced Scorecard Vocabulary"@en;
    skos:relatedTo <https://www.clearpointstrategy.com/full-exhaustive-balanced-scorecard-example/>;
.

:BSC
    skos:prefLabel   "Balanced Scorecard"@en;
    skos:description   "A strategy performance management tool"@en;
    skos:altLabel    "BSC"@en;
    skos:hasTopConcept IQ: ;
.
:Purpose
    skos:prefLabel   "Purpose"@en;
    skos:description   "A high-level story that descrives the strategic vision"@en;
    a skos:Concept;
    skos:inScheme  :BSC;
    rdfs:isDefinedBy :Ontology;
.
:Perspective
    skos:prefLabel   "Perspective"@en;
    skos:description   "A lens through which to analyse objectives and measures"@en;
    a skos:Concept;
    skos:inScheme  :BSC;
    rdfs:isDefinedBy :Ontology;
.
:Financial
    skos:prefLabel   "Financial"@en;
    skos:description   "How well does the strategy improve the organisation's financial health"@en;
    a skos:Concept;
    skos:inScheme  :BSC;
    rdfs:isDefinedBy :Ontology;
    rdfs:subClassOf :Perspective;
.
:Customer
    skos:prefLabel   "Customer"@en;
    a skos:Concept;
    skos:inScheme  :BSC;
    rdfs:isDefinedBy :Ontology;
    rdfs:subClassOf :Perspective;
.
:Internal
    skos:prefLabel   "Internal"@en;
    a skos:Concept;
    skos:inScheme  :CreateOrUpdate;
    skos:inScheme  :BSC;
    rdfs:isDefinedBy :Ontology;
    rdfs:subClassOf :Perspective;
.
:LearningAndGrowth
    skos:prefLabel   "Learning and Growth"@en;
    a skos:Concept;
    skos:inScheme  :BSC;
    rdfs:isDefinedBy :Ontology;
    rdfs:subClassOf :Perspective;
.

:Objective
    skos:prefLabel   "Objective"@en;
    skos:description   "How well does the strategy improve the organisation's financial health"@en;
    a skos:Concept;
    skos:inScheme  :BSC;
    rdfs:isDefinedBy :Ontology;
    rdfs:subClassOf :Perspective;
.
:Measure
    skos:prefLabel   "Measure"@en;
    skos:description   "How you know that you're accomplishing your objectives"@en;
    a skos:Concept;
    skos:inScheme  :BSC;
    rdfs:isDefinedBy :Ontology;
    rdfs:subClassOf :Perspective;
.
:Initiative
    skos:prefLabel   "Initiative"@en;
    skos:description   "Action plans and programs developed to achieve objectives"@en;
    a skos:Concept;
    skos:inScheme  :BSC;
    rdfs:isDefinedBy :Ontology;
    rdfs:subClassOf :Perspective;
.
:Action
    skos:prefLabel   "Action"@en;
    skos:description   "Tasks typically delegated to an accountable one person or a small team"@en;
    a skos:Concept;
    skos:inScheme  :BSC;
    rdfs:isDefinedBy :Ontology;
    rdfs:subClassOf :Perspective;
    rdfs:subClassOf raci:Task;
.

