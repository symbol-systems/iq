@prefix : <https://symbol.systems/v0/onto/skos/privacy#>.

# Canonical Ontology Definitions (e.g. W3C standards)

@prefix dbr:  <https://dbpedia.org/page/>.
@prefix dcat: <http://www.w3.org/ns/dcat#> .
@prefix cnt: <http://www.w3.org/2011/content#>.
@prefix dct: <http://purl.org/dc/terms/> .
@prefix dctype: <http://purl.org/dc/dcmitype/> .
@prefix foaf: <http://xmlns.com/foaf/0.1/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix sdo: <http://schema.org/> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix vcard: <http://www.w3.org/2006/vcard/ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

# Logical Ontology Definitions (experimental, private or proprietary)

@prefix raci: <https://symbol.systems/v0/onto/raci#>.
@prefix fact: <https://symbol.systems/v0/onto/fact#>.
@prefix frames: <https://symbol.systems/v0/onto/frames#>.
@prefix dama: <https://symbol.systems/v0/onto/dama#>.
@prefix fab: <https://symbol.systems/v0/onto/fab#>.
@prefix pmo: <https://symbol.systems/v0/onto/pmo#>.
@prefix gg: <https://symbol.systems/v0/onto/gg#>.
@prefix iq-test: <https://test.symbol.systems/cases#>.

# Model Definitions

@prefix iq-pii: <https://symbol.systems/v0/onto/skos/privacy#>.

:Ontology
    a owl:Ontology;
    dct:title "IQ: Privacy Vocabulary"@en;
    skos:prefLabel   "Privacy"@en;
    skos:description   "Respecting and protecting sensitive information"@en;
    a skos:Concept;
    rdfs:isDefinedBy :Ontology;
.

:Privacy
   skos:prefLabel   "Privacy"@en;
   skos:hasTopConcept gg:;
.

:PI
    skos:prefLabel   "PI"@en;
    skos:description   "Personal information"@en;
    a skos:Concept;
    rdfs:isDefinedBy :Ontology;
    skos:inScheme  :Privacy;
.

:PII
    skos:prefLabel   "PII"@en;
    skos:description   "Personally identifiable information"@en;
    a skos:Concept;
    rdfs:isDefinedBy :Ontology;
    skos:inScheme  :Privacy;
    skos:inScheme  :PI;
    rdfs:subClassOf :PI;
.
:PHI
    skos:prefLabel   "PHI"@en;
    skos:description   "Personal Health Information"@en;
    a skos:Concept;
    rdfs:isDefinedBy :Ontology;
    skos:inScheme  :Privacy;
    skos:inScheme  :PI;
    rdfs:subClassOf :PI;
.
:LI
    skos:prefLabel   "Legal Incept"@en;
    skos:description   "Legally incepted personal information"@en;
    a skos:Concept;
    rdfs:isDefinedBy :Ontology;
    skos:inScheme  :Privacy;
    skos:inScheme  :PI;
    rdfs:subClassOf :PI;
.
