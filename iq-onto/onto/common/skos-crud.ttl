@prefix : <https://symbol.systems/v0/onto/skos/crud#>.

# Canonical Ontology Definitions (e.g. W3C standards)

@prefix dbr:  <https://dbpedia.org/page/>.
@prefix dcat: <http://www.w3.org/ns/dcat#> .
@prefix cnt: <http://www.w3.org/2011/content#>.
@prefix dct: <http://purl.org/dc/terms/> .
@prefix dctype: <http://purl.org/dc/dcmitype/> .
@prefix foaf: <http://xmlns.com/foaf/0.1/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix sdo: <http://schema.org/> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix vcard: <http://www.w3.org/2006/vcard/ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

# Logical Ontology Definitions (experimental, private or proprietary)

@prefix raci: <https://symbol.systems/v0/onto/raci#>.
@prefix fact: <https://symbol.systems/v0/onto/fact#>.
@prefix frames: <https://symbol.systems/v0/onto/frames#>.
@prefix dama: <https://symbol.systems/v0/onto/dama#>.
@prefix fab: <https://symbol.systems/v0/onto/fab#>.
@prefix pmo: <https://symbol.systems/v0/onto/pmo#>.
@prefix gg: <https://symbol.systems/v0/onto/gg#>.
@prefix iq-test: <https://test.symbol.systems/cases#>.

# Model Definitions

@prefix iq-crud: <https://symbol.systems/v0/onto/skos/crud#>.

:Ontology
a owl:Ontology;
dct:title "IQ: CRUD Vocabulary"@en;
a skos:Concept;
.

:CRUD
skos:prefLabel   "C/R/U/D"@en;
skos:description   "Create, Read, Update, Delete"@en;
skos:hasTopConcept gg:;
.

:Create
skos:prefLabel   "Create"@en;
skos:description   "Capability to create new information"@en;
a skos:Concept;
skos:inScheme  :CreateOrUpdate;
skos:inScheme  :CRUD;
rdfs:isDefinedBy :Ontology;
.
:Read
skos:prefLabel   "Read"@en;
skos:description   "Capability to access information"@en;
a skos:Concept;
skos:inScheme  :CRUD;
rdfs:isDefinedBy :Ontology;
.
:Update
skos:prefLabel   "Update"@en;
skos:description   "Capability to modify information"@en;
a skos:Concept;
skos:inScheme  :CreateOrUpdate;
skos:inScheme  :CRUD;
rdfs:isDefinedBy :Ontology;
.
:CreateOrUpdate
skos:prefLabel   "Create Or Update"@en;
skos:description   "Capability to create or modify information"@en;
a skos:Concept;
skos:inScheme  :CRUD;
rdfs:isDefinedBy :Ontology;
.
:Delete
skos:prefLabel   "Delete"@en;
skos:description   "Capability to destroy information"@en;
a skos:Concept;
skos:inScheme  :CreateOrUpdate;
skos:inScheme  :CRUD;
rdfs:isDefinedBy :Ontology;
.
:Archive
skos:prefLabel   "Archive"@en;
skos:description   "Capability to archive information"@en;
a skos:Concept;
skos:inScheme   :CreateOrUpdate;
skos:inScheme  :CRUD;
rdfs:isDefinedBy :Ontology;
.
:DeleteOrArchive
skos:prefLabel   "Delete Or Archive"@en;
skos:description   "Capability to remove information"@en;
a skos:Concept;
skos:inScheme  :CRUD;
rdfs:isDefinedBy :Ontology;
.
:Search
skos:prefLabel   "Search"@en;
skos:description   "Capability to discover information"@en;
a skos:Concept;
skos:inScheme  :Read;
skos:inScheme  :CRUD;
rdfs:isDefinedBy :Ontology;
.
