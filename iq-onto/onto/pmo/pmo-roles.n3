@prefix : <https://symbol.systems/v0/onto/pmo#>.
# Canonical Ontology Definitions (e.g. W3C standards)

@prefix dbr:  <https://dbpedia.org/page/>.
@prefix dcat: <http://www.w3.org/ns/dcat#> .
@prefix cnt: <http://www.w3.org/2011/content#>.
@prefix dct: <http://purl.org/dc/terms/> .
@prefix dctype: <http://purl.org/dc/dcmitype/> .
@prefix foaf: <http://xmlns.com/foaf/0.1/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix sdo: <http://schema.org/> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix vcard: <http://www.w3.org/2006/vcard/ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

# Logical Ontology Definitions (experimental, private or proprietary)

@prefix raci: <https://symbol.systems/v0/onto/raci#>.
@prefix fact: <https://symbol.systems/v0/onto/fact#>.
@prefix frames: <https://symbol.systems/v0/onto/frames#>.
@prefix dama: <https://symbol.systems/v0/onto/dama#>.
@prefix fab: <https://symbol.systems/v0/onto/fab#>.
@prefix pmo: <https://symbol.systems/v0/onto/pmo#>.
@prefix IQ:  <https://symbol.systems/v0/onto/gg#>.
@prefix iq-test: <https://test.symbol.systems/cases#>.

# Model Definitions

pmo:Role
    rdfs:isDefinedBy pmo:Ontology;
    a   pmo:Concept;
    rdfs:subClassOf raci:Role;
    dct:title  "Role"@en;
    dct:description ""@en;
.

pmo:Stakeholder
    rdfs:isDefinedBy pmo:Ontology;
    rdfs:subClassOf  pmo:Role;
    dct:title  "Stakeholder"@en;
    dct:description ""@en;
.

pmo:Sponsor
    rdfs:isDefinedBy pmo:Ontology;
    rdfs:subClassOf   pmo:Stakeholder;
    dct:title  "Business Sponsor"@en;
    dct:description ""@en;
.
pmo:Owner
    rdfs:isDefinedBy pmo:Ontology;
    rdfs:subClassOf   pmo:Stakeholder;
    dct:title  "Project Owner"@en;
    dct:description ""@en;
.
pmo:ProjectManager
    rdfs:isDefinedBy pmo:Ontology;
    rdfs:subClassOf   pmo:TeamManager;
    a  pmo:Role;
    dct:title  "Project Manager"@en;
    dct:description ""@en;
.
pmo:ScrumMaster
    rdfs:isDefinedBy pmo:Ontology;
    rdfs:subClassOf   pmo:TeamMember;
    a  pmo:Role;
    dct:title  "SCRUM Master"@en;
    dct:description ""@en;
.
pmo:TeamManager
    rdfs:isDefinedBy pmo:Ontology;
    rdfs:subClassOf   pmo:TeamMember;
    dct:title  "Team Manager"@en;
    dct:description ""@en;
.
pmo:TeamMember
    rdfs:isDefinedBy pmo:Ontology;
    rdfs:subClassOf   pmo:Stakeholder;
    dct:title  "Team Member"@en;
    dct:description ""@en;
.
