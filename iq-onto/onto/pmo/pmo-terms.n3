@prefix : <https://symbol.systems/v0/onto/pmo#>.
# Canonical Ontology Definitions (e.g. W3C standards)

@prefix dbr:  <https://dbpedia.org/page/>.
@prefix dcat: <http://www.w3.org/ns/dcat#> .
@prefix cnt: <http://www.w3.org/2011/content#>.
@prefix dct: <http://purl.org/dc/terms/> .
@prefix dctype: <http://purl.org/dc/dcmitype/> .
@prefix foaf: <http://xmlns.com/foaf/0.1/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix sdo: <http://schema.org/> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix vcard: <http://www.w3.org/2006/vcard/ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

# Logical Ontology Definitions (experimental, private or proprietary)

@prefix raci: <https://symbol.systems/v0/onto/raci#>.
@prefix fact: <https://symbol.systems/v0/onto/fact#>.
@prefix frames: <https://symbol.systems/v0/onto/frames#>.
@prefix dama: <https://symbol.systems/v0/onto/dama#>.
@prefix fab: <https://symbol.systems/v0/onto/fab#>.
@prefix pmo: <https://symbol.systems/v0/onto/pmo#>.
@prefix gg: <https://symbol.systems/v0/onto/gg#>.
@prefix iq-test: <https://test.symbol.systems/cases#>.

# Model Definitions

pmo:manages
rdfs:isDefinedBy pmo:Ontology;
dct:title  "manages"@en;
dct:description ""@en;
rdfs:domain pmo:TeamManager;
rdfs:range pmo:TeamMember;
.

pmo:delivers
rdfs:isDefinedBy pmo:Ontology;
dct:title  "delivers"@en;
dct:description ""@en;
rdfs:domain pmo:Story;
rdfs:range pmo:Deliverable;
.

pmo:activity
rdfs:isDefinedBy pmo:Ontology;
dct:title  "activity"@en;
dct:description ""@en;
rdfs:domain pmo:Story;
rdfs:range pmo:Activity;
.

pmo:todo
rdfs:isDefinedBy pmo:Ontology;
dct:title  "to do"@en;
dct:description ""@en;
rdfs:domain pmo:TeamMember;
rdfs:range pmo:Activity;
.
