@prefix : <https://symbol.systems/v0/onto/demo/dama/frames/risks#>.

# Canonical Ontology Definitions (e.g. W3C standards)

@prefix dbr:  <https://dbpedia.org/page/>.
@prefix dcat: <http://www.w3.org/ns/dcat#> .
@prefix cnt: <http://www.w3.org/2011/content#>.
@prefix dct: <http://purl.org/dc/terms/> .
@prefix dctype: <http://purl.org/dc/dcmitype/> .
@prefix foaf: <http://xmlns.com/foaf/0.1/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix sdo: <http://schema.org/> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix vcard: <http://www.w3.org/2006/vcard/ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

# Logical Ontology Definitions (experimental, private or proprietary)

@prefix raci: <https://symbol.systems/v0/onto/raci#>.
@prefix fact: <https://symbol.systems/v0/onto/fact#>.
@prefix frames: <https://symbol.systems/v0/onto/frames#>.
@prefix dama: <https://symbol.systems/v0/onto/dama#>.
@prefix fab: <https://symbol.systems/v0/onto/fab#>.
@prefix pmo: <https://symbol.systems/v0/onto/pmo#>.
@prefix IQ:  <https://symbol.systems/v0/onto/gg#>.
@prefix iq-test: <https://test.symbol.systems/cases#>.

# Model Definitions

:BusinessStrategyRisk
    a frames:Risk;
    dct:title "Adequate business plan"@en;
    rdfs:seeAlso [
        a dama:RiskMitigation;
        dct:title "A clearly articulated business strategy"@en;
    ]
.
:BusinessValueRisk
    a frames:Risk;
    dct:title "Business value mis-aligned"@en;
    rdfs:seeAlso [
        a dama:RiskMitigation;
        dct:title "A measurable business goal"@en;
    ]
.
:BusinessSponsorRisk
    a frames:Risk;
    dct:title "Ineffective business sponsor"@en;
    rdfs:seeAlso [
        a dama:RiskMitigation;
        dct:title "Senior leadership involved in planning and execution"@en;
    ]
.
:BusinessOwnershipRisk
    a frames:Risk;
    dct:title "Lack of business ownership"@en;
    rdfs:seeAlso [
        a dama:RiskMitigation;
        dct:title "Business takes ownership of their data and the data strategy"@en;
    ]
.
:BusinessTechnologyRisk
    a frames:Risk;
    dct:title "Led by IT not the business"@en;
    rdfs:seeAlso [
        a dama:RiskMitigation;
        dct:title "The Business owns their data strategy rather than IT"@en;
    ]
.
:BusinessTechnologyCollaborationRisk
    a frames:Risk;
    dct:title "Lack of collaboration between business and IT"@en;
    rdfs:seeAlso [
        a dama:RiskMitigation;
        dct:title "The team collaborates and communications across buiness and IT silos"@en;
    ]
.
:MilestoneRisk
    a frames:Risk;
    dct:title "Complexity and lack of focused milesstones"@en;
    rdfs:seeAlso [
        a dama:RiskMitigation;
        dct:title "Clear milesstones focused on business priorities"@en;
    ]
.
:ChangeControlRisk
    a frames:Risk;
    dct:title "Poor change control"@en;
    rdfs:seeAlso [
        a dama:RiskMitigation;
        dct:title "Effective and timely change management"@en;
    ]
.
:TalentRisk
    a frames:Risk;
    dct:title "Lack of expertise to achieve strategy"@en;
    rdfs:seeAlso [
        a dama:RiskMitigation;
        dct:title "Expertise and resource to achieve strategic outcomes"@en;
    ]
.
