# Model Definitions - Data Architecture and Governance

:
    rdfs:subClassOf frames:Framework;
    dct:title "Data Architecture and Governance"@en;
.
:what_prioritise
    skos:inScheme :;
    skos:inScheme frames:What;
    skos:inScheme fact:Question;
    dct:title "What data do we prioritise?"@en;
.
:where_used
    skos:inScheme :;
    skos:inScheme frames:Where;
    skos:inScheme fact:Question;
    dct:title "Where is data used?"@en;
.
:where_stored
    skos:inScheme :;
    skos:inScheme frames:Where;
    skos:inScheme fact:Question;
    dct:title "Where is data stored?"@en;
.
:what_rules
    skos:inScheme :;
    skos:inScheme frames:What;
    skos:inScheme fact:Question;
    dct:title "What rules apply to the data?"@en;
.
:what_quality
    skos:inScheme :;
    skos:inScheme frames:What;
    skos:inScheme fact:Question;
    dct:title "What is the quality of the data?"@en;
.
:who_colleagues
    skos:inScheme :;
    skos:inScheme frames:Who;
    skos:inScheme fact:Question;
    dct:title "What data best supports our colleagues?"@en;
.
:who_customers
    skos:inScheme :;
    skos:inScheme frames:Who;
    skos:inScheme fact:Question;
    dct:title "What data best supports our customers?"@en;
.
:who_partners
    skos:inScheme :;
    skos:inScheme frames:Who;
    skos:inScheme fact:Question;
    dct:title "What data best supports our partners?"@en;
.
:who_marketing
    rdfs:subClassOf :who_colleagues;
    skos:inScheme frames:Who;
    skos:inScheme fact:Question;
    dct:title "What data best supports our marketing team?"@en;
.
:who_sales
    rdfs:subClassOf :who_colleagues;
    skos:inScheme frames:Who;
    skos:inScheme fact:Question;
    dct:title "What data best supports our sales team?"@en;
.
:who_operations
    rdfs:subClassOf :who_colleagues;
    skos:inScheme frames:Who;
    skos:inScheme fact:Question;
    dct:title "What data best supports BAU operations?"@en;
.

