# Model Definitions

dama:DataAccountability
    a dama:Outcome;
    frames:requires IQ: Story_DAMARolesResponsibilities;
    frames:requires IQ: Story_DAMADataGovernanceFramework;
    frames:requires IQ: Story_DAMACorporateDataPolicy;
    frames:requires IQ: Story_DAMADocumentDataStandards;
    frames:requires IQ: Story_DAMATrainDataAccountability;
.

dama:DataQuality
    a dama:Outcome;
    frames:requires IQ: Story_DAMADefineKPI;
    frames:requires IQ: Story_DAMAMonitorQualityImprovements;
    frames:requires IQ: Story_DAMADevelopQualityImprovements;
    frames:requires IQ: Story_DAMAImplementQualityImprovements;
.

dama:DataCulture
    a dama:Outcome;
    frames:requires IQ: Story_DAMACultureBenefit;
    frames:requires IQ: Story_DAMACultureCommunity;
    frames:requires IQ: Story_DAMACultureEngage;
    frames:requires IQ: Story_DAMACultureRole;
.
