# Model Definitions

:data_is_business_asset
    a dama:Principle;
    dct:title "Data is a business asset"@en;
    dct:description "Data is owned by the business and employed to create value"@en;
.


:governance_is_programme 
    a dama:Principle;
    dct:title "Data governance is a business-as-usual activity"@en;
    dct:description "Data governance is not a project with an end-date"@en;
.

:data_follows_rules 
    a dama:Principle;
    dct:title "Data is managed in accordance with internal and external rules and regulations"@en;
    dct:description "The rules and regulations must be usable, documented, communicated and enforced"@en;
.
