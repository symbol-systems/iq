@prefix sm:     <urn:iq:schema:mapping#> .
@prefix rdfs:   <http://www.w3.org/2000/01/rdf-schema#> .
@prefix rdf:    <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd:    <http://www.w3.org/2001/XMLSchema#> .
@prefix owl:    <http://www.w3.org/2002/07/owl#> .

####
# Schema Mapping Ontology
#
# Defines metadata for auto-discovered database and API schemas.
# Used by JDBC and OpenAPI connectors to track introspection state and mappings.
#
# Key concepts:
# - SchemaMapping: metadata about a discovered schema (JDBC or OpenAPI)
# - sourceType: JDBC, OpenAPI, GraphQL, etc.
# - detectedAt: timestamp when introspected
# - r2rmlGraph / jsonLdGraph: where the mappings are stored as RDF
# - approved: whether a human has approved the auto-generated mapping
####

# Main Class: SchemaMapping
# Represents metadata about a discovered schema from an external source
sm:SchemaMapping
  a owl:Class ;
  rdfs:label "Schema Mapping" ;
  rdfs:comment "Metadata for a discovered database or API schema" ;
  .

# Property: sourceType
# Indicates what kind of source was introspected
sm:sourceType
  a owl:DataProperty ;
  rdfs:domain sm:SchemaMapping ;
  rdfs:range xsd:string ;
  rdfs:label "Source Type" ;
  rdfs:comment "Type of source: JDBC, OpenAPI, GraphQL, etc." ;
  .

# Vocabulary for sourceType values
sm:JDBC
  a rdf:Constant ;
  rdf:value "JDBC" ;
  rdfs:comment "JDBC database source" ;
  .

sm:OpenAPI
  a rdf:Constant ;
  rdf:value "OpenAPI" ;
  rdfs:comment "OpenAPI/Swagger REST API source" ;
  .

sm:GraphQL
  a rdf:Constant ;
  rdf:value "GraphQL" ;
  rdfs:comment "GraphQL endpoint source" ;
  .

# Property: sourceUri
# The connection string (JDBC) or endpoint URL (OpenAPI)
sm:sourceUri
  a owl:DataProperty ;
  rdfs:domain sm:SchemaMapping ;
  rdfs:range xsd:anyURI ;
  rdfs:label "Source URI" ;
  rdfs:comment "Connection string (JDBC) or endpoint URL (OpenAPI)" ;
  .

# Property: detectedAt
# Timestamp when the schema was auto-discovered
sm:detectedAt
  a owl:DataProperty ;
  rdfs:domain sm:SchemaMapping ;
  rdfs:range xsd:dateTime ;
  rdfs:label "Detected At" ;
  rdfs:comment "When the schema was auto-discovered" ;
  .

# Property: generatedBy
# Which tool/class generated this mapping
sm:generatedBy
  a owl:DataProperty ;
  rdfs:domain sm:SchemaMapping ;
  rdfs:range xsd:string ;
  rdfs:label "Generated By" ;
  rdfs:comment "Tool that generated the mapping (e.g., JdbcSchemaIntrospector, OpenApiSchemaIntrospector)" ;
  .

# Property: r2rmlGraph
# Named graph URI where R2RML triples for this schema are stored (JDBC only)
sm:r2rmlGraph
  a owl:ObjectProperty ;
  rdfs:domain sm:SchemaMapping ;
  rdfs:range rdf:Graph ;
  rdfs:label "R2RML Graph" ;
  rdfs:comment "Named graph URI where W3C R2RML mapping triples are stored (for JDBC)" ;
  .

# Property: jsonLdGraph
# Named graph URI where JSON-LD mappings for this schema are stored (OpenAPI only)
sm:jsonLdGraph
  a owl:ObjectProperty ;
  rdfs:domain sm:SchemaMapping ;
  rdfs:range rdf:Graph ;
  rdfs:label "JSON-LD Graph" ;
  rdfs:comment "Named graph URI where JSON-LD semantic mapping triples are stored (for OpenAPI)" ;
  .

# Property: approved
# Whether a human has reviewed and approved the auto-generated mapping
sm:approved
  a owl:DatatypeProperty ;
  rdfs:domain sm:SchemaMapping ;
  rdfs:range xsd:boolean ;
  rdfs:label "Approved" ;
  rdfs:comment "Has a human approved this auto-generated mapping?" ;
  .

# Property: approvedBy
# User or role that approved the mapping
sm:approvedBy
  a owl:DataProperty ;
  rdfs:domain sm:SchemaMapping ;
  rdfs:range xsd:string ;
  rdfs:label "Approved By" ;
  rdfs:comment "User or role that approved the mapping (if approved=true)" ;
  .

# Property: approvedAt
# Timestamp when the mapping was approved
sm:approvedAt
  a owl:DataProperty ;
  rdfs:domain sm:SchemaMapping ;
  rdfs:range xsd:dateTime ;
  rdfs:label "Approved At" ;
  rdfs:comment "Timestamp when the mapping was approved (if approved=true)" ;
  .

# Property: refinements
# User customizations to the auto-generated mapping
sm:refinements
  a owl:DataProperty ;
  rdfs:domain sm:SchemaMapping ;
  rdfs:range xsd:string ;
  rdfs:label "Refinements" ;
  rdfs:comment "User customizations to auto-generated mapping (JSON-Patch format or SPARQL UPDATE)" ;
  .

# Property: rowCountEstimate
# Estimated row/entity count for statistics and query planning
sm:rowCountEstimate
  a owl:DatatypeProperty ;
  rdfs:domain sm:SchemaMapping ;
  rdfs:range xsd:long ;
  rdfs:label "Row Count Estimate" ;
  rdfs:comment "Estimated number of rows/entities (for query planning)" ;
  .

# Property: lastModified
# When this mapping was last modified
sm:lastModified
  a owl:DataProperty ;
  rdfs:domain sm:SchemaMapping ;
  rdfs:range xsd:dateTime ;
  rdfs:label "Last Modified" ;
  rdfs:comment "Timestamp of last modification" ;
  .

# Property: schemaVersion
# Schema version identifier (from source API or data model)
sm:schemaVersion
  a owl:DataProperty ;
  rdfs:domain sm:SchemaMapping ;
  rdfs:range xsd:string;
  rdfs:label "Schema Version" ;
  rdfs:comment "Version identifier from the source (e.g., OpenAPI spec version, database version)" ;
  .

# Class: AutoGeneratedMapping
# Marker class for auto-generated mappings that may need review
sm:AutoGeneratedMapping
  a owl:Class ;
  rdfs:subClassOf sm:SchemaMapping ;
  rdfs:label "Auto-Generated Mapping" ;
  rdfs:comment "Mapping that was automatically generated and may need human review" ;
  .

# Class: ApprovedMapping
# Marker class for human-approved mappings
sm:ApprovedMapping
  a owl:Class ;
  rdfs:subClassOf sm:SchemaMapping ;
  rdfs:label "Approved Mapping" ;
  rdfs:comment "Mapping that has been reviewed and approved by a human" ;
  .

####
# Example Usage
#
# Auto-discovered JDBC mapping (not yet approved):
# 
# ex:crm-db-schema a sm:SchemaMapping, sm:AutoGeneratedMapping ;
#   sm:sourceType "JDBC" ;
#   sm:sourceUri "jdbc:postgresql://db.example.com:5432/crm" ;
#   sm:detectedAt "2026-04-08T14:32:45Z"^^xsd:dateTime ;
#   sm:generatedBy "JdbcSchemaIntrospector" ;
#   sm:r2rmlGraph ex:crm-db-schemas-1a2b3c ;
#   sm:approved false ;
#   sm:rowCountEstimate 45000 ;
#   .
#
# OpenAPI mapping (approved):
#
# ex:stripe-api-schema a sm:SchemaMapping, sm:ApprovedMapping ;
#   sm:sourceType "OpenAPI" ;
#   sm:sourceUri "https://api.stripe.com/openapi/stripe-api.json" ;
#   sm:detectedAt "2026-04-07T10:15:30Z"^^xsd:dateTime ;
#   sm:generatedBy "OpenApiSchemaIntrospector" ;
#   sm:jsonLdGraph ex:stripe-api-schemas-5d4e3f ;
#   sm:approved true ;
#   sm:approvedBy "alice@example.com" ;
#   sm:approvedAt "2026-04-07T11:00:00Z"^^xsd:dateTime ;
#   sm:schemaVersion "1.0.0" ;
#   .
