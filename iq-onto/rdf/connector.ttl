@prefix connect: <https://symbol.systems/v0/connect#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

# Connector ontology for IQ connectors

connect:Connector a rdf:Class ;
rdfs:label "Connector" ;
rdfs:comment "A connector that synchronizes external systems into IQ." .

connect:hasSyncStatus a rdf:Property ;
rdfs:label "has sync status" ;
rdfs:comment "A connector's current sync status." ;
rdfs:range xsd:string .

connect:syncStatus a rdf:Property ;
rdfs:label "sync status" ;
rdfs:comment "Status enumeration for connector sync state (Idle, Syncing, Error, etc.)." ;
rdfs:range xsd:string .

connect:lastSyncedAt a rdf:Property ;
rdfs:label "last synced at" ;
rdfs:comment "Timestamp of the last successful sync." ;
rdfs:range xsd:dateTime .

connect:checkpoint a rdf:Property ;
rdfs:label "checkpoint" ;
rdfs:comment "Opaque checkpoint token used to resume synchronization." ;
rdfs:range xsd:string .

connect:hasDescriptor a rdf:Property ;
rdfs:label "has descriptor" ;
rdfs:comment "Links a connector to its descriptor model." ;
rdfs:range connect:ConnectorDescriptor .

connect:ConnectorDescriptor a rdf:Class ;
rdfs:label "Connector Descriptor" ;
rdfs:comment "Metadata used to discover and register connectors." .

connect:hasName a rdf:Property ;
rdfs:label "has name" ;
rdfs:comment "Human-friendly name of the connector." ;
rdfs:range xsd:string .

connect:hasDescription a rdf:Property ;
rdfs:label "has description" ;
rdfs:comment "Human-friendly description of the connector." ;
rdfs:range xsd:string .

# Specific Connector types for IQ Connect modules

connect:TemplateConnector a connect:Connector ;
rdfs:label "Template Connector" ;
rdfs:comment "Base template connector implementation." .

connect:AwsConnector a connect:Connector ;
rdfs:label "AWS Connector" ;
rdfs:comment "Connector for AWS resources." .

connect:AzureConnector a connect:Connector ;
rdfs:label "Azure Connector" ;
rdfs:comment "Connector for Azure resources." .

connect:ConfluenceConnector a connect:Connector ;
rdfs:label "Confluence Connector" ;
rdfs:comment "Connector for Atlassian Confluence state." .

connect:DatabricksConnector a connect:Connector ;
rdfs:label "Databricks Connector" ;
rdfs:comment "Connector for Databricks clusters and jobs." .

connect:DatadogConnector a connect:Connector ;
rdfs:label "Datadog Connector" ;
rdfs:comment "Connector for Datadog metrics and alerts." .

connect:DigitalOceanConnector a connect:Connector ;
rdfs:label "DigitalOcean Connector" ;
rdfs:comment "Connector for DigitalOcean resources." .

connect:DockerConnector a connect:Connector ;
rdfs:label "Docker Connector" ;
rdfs:comment "Connector for Docker resources." .

connect:GcpConnector a connect:Connector ;
rdfs:label "GCP Connector" ;
rdfs:comment "Connector for Google Cloud Platform resources." .

connect:GithubConnector a connect:Connector ;
rdfs:label "GitHub Connector" ;
rdfs:comment "Connector for GitHub repositories and events." .

connect:GoogleAppsConnector a connect:Connector ;
rdfs:label "Google Apps Connector" ;
rdfs:comment "Connector for Google Workspace resources." .

connect:K8sConnector a connect:Connector ;
rdfs:label "Kubernetes Connector" ;
rdfs:comment "Connector for Kubernetes/EKS/GKE clusters." .

connect:Office365Connector a connect:Connector ;
rdfs:label "Office 365 Connector" ;
rdfs:comment "Connector for Microsoft 365 resources." .

connect:ParquetConnector a connect:Connector ;
rdfs:label "Parquet Connector" ;
rdfs:comment "Connector for Parquet dataset feathers." .

connect:SalesforceConnector a connect:Connector ;
rdfs:label "Salesforce Connector" ;
rdfs:comment "Connector for Salesforce CRM data." .

connect:SlackConnector a connect:Connector ;
rdfs:label "Slack Connector" ;
rdfs:comment "Connector for Slack workspace entities." .

connect:SnowflakeConnector a connect:Connector ;
rdfs:label "Snowflake Connector" ;
rdfs:comment "Connector for Snowflake data warehouses." .

connect:StripeConnector a connect:Connector ;
rdfs:label "Stripe Connector" ;
rdfs:comment "Connector for Stripe payment objects." .
