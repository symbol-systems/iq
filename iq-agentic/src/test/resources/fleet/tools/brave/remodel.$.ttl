@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#>.
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .

@prefix iq: <iq:>.

{{#each my.results.infobox.results}}

    <{{my.agent}}> iq:knows <{{my.self}}>.

    <{{my.self}}> schema:hasPart <{{url}}>.
    <{{url}}>
        a schema:WebPage;
        schema:url <{{website_url}}> ;
        schema:name "{{title}} - {{description}}";
        schema:description "{{long_desc}}";
        schema:datePublished "{{page_age}}";
        schema:thumbnailUrl "{{thumbnail.original}}";
.
    {{#each profiles}}
        <{{my.self}}> schema:hasPart <{{url}}>.
        <{{url}}>
            a schema:ProfilePage;
        schema:url <{{url}}> ;
        schema:name "{{title}}";
        schema:description "{{title}} [{{long_name}}]";
        schema:datePublished "{{page_age}}";
        schema:thumbnailUrl "{{thumbnail.original}}";
.
    {{/each}}

{{/each}}

{{#each my.results.videos.results}}
    <{{my.self}}> schema:hasPart <{{url}}>.

    <{{url}}> a schema:VideoObject;
        schema:url <{{url}}> ;
        schema:name "{{title}}";
        schema:datePublished "{{page_age}}";
        schema:description "{{description}}";
        schema:thumbnailUrl "{{thumbnail.original}}";
.
{{/each}}

{{#each my.results.web.results}}
        <{{my.self}}> schema:hasPart <{{url}}>.

<{{url}}> a schema:WebPage;
          schema:url <{{url}}> ;
          schema:name "{{title}}";
          schema:datePublished "{{page_age}}";
          schema:description "{{extra_snippets}}";
          schema:thumbnailUrl "{{thumbnail.original}}";
.
{{/each}}
