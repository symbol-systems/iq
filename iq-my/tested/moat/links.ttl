[] a schema:Organization;
  schema:address [ a schema:PostalAddress;
      schema:addressCountry "USA";
      schema:addressLocality "Cheyene";
      schema:addressRegion "WY";
      schema:postalCode "33444";
      schema:streetAddress "123 Mild West Street"
    ];
  schema:contactPoint [ a schema:ContactPoint;
      schema:contactType "customer support";
      schema:email "example@symbol.systems";
      schema:telephone "[+555-123-8457]"
    ];
  schema:founders [ a schema:Person;
      schema:name "JO"
    ];
  schema:foundingDate "2024"^^schema:Date;
  schema:legalName "Symbol Systems LLC";
  schema:logo <http://symbol.systems/logo.png>;
  schema:name "Symbol Systems";
  schema:url <http://symbol.systems> .
