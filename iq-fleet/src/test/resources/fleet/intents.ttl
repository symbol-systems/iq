@base <urn:iq:test:>.

@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#>.
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .

@prefix iq: <urn:iq:>.
@prefix : <urn:iq:test:>.

:   a iq:Agent;
rdf:value "You an AI researcher. ";
iq:initial :intents;
.
:intents
rdf:value "You can only use the following intents.";
iq:prompt "{{my.prompt}}";
iq:to :search;
iq:to :ask;
iq:to :find;
iq:to :select;
iq:to :remodel;
iq:to :prompt;
iq:to :script;
iq:to :webpage;
iq:to :rdf;
iq:to :self;
iq:to :aware;
.

iq:State a iq:.
iq:to rdfs:domain iq:State.
iq:to rdfs:range iq:State.

iq:knows rdfs:range rdf:Statement .
#iq:find rdfs:range rdf:JSON  .

:ask
rdfs:label "You can ask the user for more information";
.
:find
rdfs:label "You can find in your knowledge base";
.
:search
rdfs:label "You can search the web ";
iq:script <urn:iq:test:script/brave_search>;
iq:to :remodel_search;
.
:remodel_search
iq:remodel <urn:iq:test:remodel/brave_search>;
.
:select
rdfs:label "You can SPARQL query your historic memory";
iq:select "{{my.prompt}}".
:remodel
rdfs:label "You can transform data into knowledge";
iq:remodel "{{my.prompt}}".
:prompt
rdfs:label "You can ask for executive assistance";
iq:prompt "{{my.prompt}}".
:think
rdfs:label "You can ask for executive assistance";
iq:think "{{my.prompt}}".
:script
rdfs:label "You can run scripts using Groovy and Javascript";
iq:script <urn:iq:test:script/hello>.
:webpage
rdfs:label "You can visit a webpage vis URL";
iq:webpage <https://www.w3.org/1999/02/22-rdf-syntax-ns>.
:rdf
rdfs:label "You can de-reference an RDF via URL";
iq:rdf <https://www.w3.org/1999/02/22-rdf-syntax-ns>.

:self
rdfs:label "You can answer questions about yourself";
iq:learn :Self;
iq:script <urn:iq:test:script/self>.

:aware
iq:guard [
iq:knows :Self;
];
iq:execute :think;
.