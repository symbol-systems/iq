@base <urn:iq:test:>.

@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#>.
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .

@prefix iq: <urn:iq:>.
@prefix : <urn:iq:test:>.

:   a iq:Agent;
rdf:value "You are my assistant, JO, reply accordingly.";
iq:initial :intents;
.
:intents
rdf:value "Think carefully about the user's intention. Then choose one of the following intents:";
iq:to :search;
iq:to :find;
iq:to :select;
iq:to :remodel;
iq:to :prompt;
iq:to :image;
iq:to :webpage;
iq:to :think;
iq:to :self;
iq:to :aware;
.

iq:State a iq:.
iq:to rdfs:domain iq:State.
iq:to rdfs:range iq:State.

iq:knows rdfs:range rdf:Statement .
#iq:find rdfs:range rdf:JSON  .

:find
rdfs:label "You can find in your knowledge base";
iq:to :search;
.
:image
rdfs:label "You can generate an image";
iq:script <urn:iq:test:tools/image/dal_e>;
.
:search
rdfs:label "You can search the web ";
iq:script <urn:iq:test:tools/brave/search>;
iq:to :search_remodel;
.
:search_remodel
iq:remodel <urn:iq:test:tools/brave/remodel>;
iq:to :search_answer;
.
:search_answer
iq:answer <urn:iq:test:tools/brave/answer>;
iq:to :intents;
.
:select
rdfs:label "You can SPARQL query your historic memory";
iq:select "{{my.prompt}}".
:remodel
rdfs:label "You can transform data into knowledge";
iq:remodel "{{my.prompt}}".
:prompt
rdfs:label "You can ask for executive assistance";
iq:prompt "{{my.prompt}}".
:think
rdfs:label "You can generate new ideas, plans or thoughts";
iq:think [
rdf:value "Generate a plan using the SKOS vocabulary."];
.
:webpage
rdfs:label "You can visit a webpage vis URL";
iq:webpage <https://www.w3.org/1999/02/22-rdf-syntax-ns>.

:self
rdfs:label "You can answer questions about yourself";
iq:learn :Self;
iq:script <urn:iq:test:tools/self>;
iq:to :aware;
.

:aware
iq:guard [
iq:knows :Self;
];
iq:to :self;
.

:intent_test
iq:to :self;
.