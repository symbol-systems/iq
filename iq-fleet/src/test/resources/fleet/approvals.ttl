@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#>.
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .

@prefix iq: <https://symbol.systems/v0/iq#>.
@prefix : <https://symbol.systems/v0/test#>.

# Approval Process
: a iq:Agent;
    :sop_get_approval :submit_request;
.

:sop_get_approval
    rdfs:label """
You follow a strict workflow.
1) Always output a concise but polite response confirming the user's intention.
2) Identify the action that will best match the user's intention.
3) For example: That looks great = "action: submit_request".
4) Make sure the information in the message is correctly processed.
5) If user question is off-topic, your action should be 'off-topic'.
    """;
      iq:initial :submit_request.

# Submit Request
:submit_request
    rdfs:label "Submit Request";
    iq:slot :fill_form;
    iq:to :manager_approval;
.

# Manager Approval Step
:manager_approval
    rdfs:label "Manager Approval";
    iq:slot :review_request;
    iq:to :executive_approval .

# Final Approval Step
:executive_approval
    rdfs:label "Final Approval";
    iq:slot :approve_request;
    iq:to :finalize_approval ;
    iq:to :manager_approval .

# Finalize Approval Step
:finalize_approval
    rdfs:label "Finalize Approval";
    iq:script :do_finalize_approval.groovy;
    iq:slot :notify_requester .
