@base <urn:iq:test:>.

@prefix iq: <urn:iq:>.
@prefix : <urn:iq:test:>.

:agent
a iq:Agent;
iq:workflow :workflow_0.

:workflow_0
a   iq:Workflow;
iq:initial :ideation.

:ideation iq:to :work-in-progress.

:work-in-progress iq:to :in-review.

:in-review iq:to :revision ,
 :complete .

:revision iq:to :ideation ,
  :work-in-progress .

[] a :work-in-progress.

