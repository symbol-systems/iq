package systems.symbol.controller.search;

import systems.symbol.platform.APIPlatform;
import systems.symbol.finder.TextFinder;
import systems.symbol.controller.responses.OopsResponse;
import systems.symbol.string.Validate;
import jakarta.inject.Inject;
import jakarta.ws.rs.*;
import jakarta.ws.rs.core.MediaType;

import jakarta.ws.rs.core.Response;

@Path("search/text")
public class SearchText {

@Inject
APIPlatform platform;

@GET
@Path("{finder}")
@Produces(MediaType.APPLICATION_JSON)
public Response search(@PathParam("finder") String finder, @QueryParam("query") String query,
@QueryParam("maxResults") int maxResults , @QueryParam("relevancy") double relevancy) {
if (Validate.isNonAlphanumeric(finder)) {
return new OopsResponse("ux.search.text#finder-invalid", Response.Status.BAD_REQUEST).asJSON();
}
TextFinder search = platform.getTextFinder(finder);
if (search==null) {
return new OopsResponse("ux.search.text#finder-missing", Response.Status.NOT_FOUND).asJSON();
}
return new OopsResponse("ux.search.text#todo", Response.Status.EXPECTATION_FAILED).asJSON();
}

}

