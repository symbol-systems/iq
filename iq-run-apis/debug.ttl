github:github rdf:value """import jakarta.ws.rs.core.Response
import systems.symbol.agent.IQFacade
import systems.symbol.controller.responses.OopsException
import systems.symbol.util.Env

import javax.script.Bindings

iq = (IQFacade)iq;
my = (Bindings)my;

assert my.provider == \"github\"

def api = iq.api(\"https://github.com/login/oauth/access_token\");
api.header('Accept', 'application/json')
def payload = [ client_id: Env.get(\"MY_GITHUB_CLIENT_ID\", \"\"), client_secret: Env.get(\"MY_GITHUB_SECRET\", \"\"), 
                'grant_type': 'authorization_code', 'code': my.code, 'redirect_uri': my.host+\"login/github\" ]
println(\"github.payload: ${payload}\")

def r = api.post(payload)
def auth = iq.json(r)
println(\"github.response: ${auth}\")

if (!auth || auth.error) throw new OopsException(\"github.oauth.error.\"+auth.error, Response.Status.FORBIDDEN)

if (auth.access_token) {
    def github_api = iq.api(\"https://api.github.com/user\")
    github_api.bearer(\"\"+auth.access_token)
    def github_reply = github_api.get()
    my.github = iq.json(github_reply)
    my.human = my.github.name ?: my.github.login ?: \"\"
    if (my.human && my.github.login) {
        my.identity = \"${my.issuer}${my.github.login}\"
    }
}
println(\"github.trusts: ${my.human} @ ${my.identity}\")
"""^^<urn:application/x-groovy> .

<https://github.com> iq:trusts :MY_GITHUB_SECRET .

<XXX:trust/github/> iq:secret :MY_GITHUB_SECRET;
  iq:initial github:verify;
  iq:trusts <https://github.com>, github:smart-trust .

github:verify iq:script github:github;
  iq:to github:authorize .

github:identify iq:script script:identity;
  iq:to github:trusted .

github:trusted iq:to <XXX:trust/> .

