ai:find rdf:value """PREFIX my: <XXX:>
PREFIX iq: <iq:>
PREFIX ai: <XXX:ai/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>
PREFIX rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#>

CONSTRUCT {
    ?self my:label ?label;
          my:comment ?comment;
          my:image ?image;
          my:url ?url;
          my:score ?score;
          a ?type;
}
WHERE {
    ?self my:label ?label;
    my:comment ?comment;
    my:image ?image.
    OPTIONAL {
        ?self my:url ?url;
    }
    OPTIONAL {
        ?self a ?type.
    }

    VALUES (?self ?score) { {{{these}}} }
} 
"""^^<urn:application/x-sparql-query> .

ai:lobby rdf:value """PREFIX my: <XXX:>
PREFIX iq: <iq:>
PREFIX ai: <XXX:ai/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>
PREFIX rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#>

CONSTRUCT {
    ?self my:label ?label;
          my:comment ?comment;
          my:image ?image;
          my:url ?url;
          a ?type;
}
WHERE {
    ?self a my:Avatar;
    a ?type;
    my:label ?label;
    my:comment ?comment;
    my:url ?url;
    my:image ?image.
}
"""^^<urn:application/x-sparql-query> .

ai:memes rdf:value """PREFIX my: <XXX:>
PREFIX iq: <iq:>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>
PREFIX rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#>
PREFIX self: <{{my.self}}>

# self: {{my.self}} 
# focus: {{my.id}} 
# time: {{my.time}} 

SELECT DISTINCT ?id ?label ?comment ?content ?image ?url
WHERE {
    BIND(<{{my.id}}> AS ?self)

    ?self a ?selfType;
          my:label ?selfLabel;
          my:comment ?selfComment.

    OPTIONAL {
        ?self my:url ?selfUrl;
              my:image ?selfImage.
    }

    # Handle intent traversal
    OPTIONAL {
        ?self iq:to+ ?intent.

        ?intent a ?intentType;
                my:label ?intentLabel;
                my:comment ?intentComment.

        OPTIONAL {
            ?intent my:url ?intentUrl;
                   my:image ?intentImage.
        }
    }

    BIND(COALESCE(?intent, ?self) AS ?entity)
    BIND(COALESCE(?intentType, ?selfType) AS ?type)
    BIND(COALESCE(?intentLabel, ?selfLabel) AS ?label)
    BIND(COALESCE(?intentComment, ?selfComment) AS ?comment)
    BIND(COALESCE(?intentUrl, ?selfUrl) AS ?url)
    BIND(COALESCE(?intentImage, ?selfImage) AS ?image)
}
"""^^<urn:application/x-sparql-query> .

ai:mind rdf:value """PREFIX my: <XXX:>
PREFIX iq: <iq:>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>
PREFIX rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#>
PREFIX self: <{{my.self}}>

CONSTRUCT {
    # Construct the avatar details
    ?avatar my:label ?avatarLabel;
            a ?type;
            my:comment ?avatarComment;
            my:image ?avatarImage;
            my:url ?avatarUrl;
            iq:to ?initialScene.

    # Construct the initial scene details
    ?initialScene my:label ?sceneLabel;
                  my:comment ?sceneComment;
                  my:image ?sceneImage;
                  my:url ?sceneUrl;
                  iq:to ?nextEntity.

    # Construct the next scene or entity details (if any)
    ?nextEntity my:label ?nextEntityLabel;
                my:comment ?nextEntityComment;
                my:image ?nextEntityImage;
                my:url ?nextEntityUrl.
}
WHERE {
    BIND(<{{my.id}}> AS ?avatar)

    # Retrieve avatar details
    ?avatar a my:Avatar;
            a ?type;
            my:label ?avatarLabel;
            my:comment ?avatarComment;
            my:image ?avatarImage;
            my:url ?avatarUrl;
            iq:initial ?initialScene.

    # Retrieve initial scene details
    ?initialScene my:label ?sceneLabel;
                  my:comment ?sceneComment;
                  my:image ?sceneImage.
    OPTIONAL { ?initialScene my:url ?sceneUrl }

    # Retrieve transitions (optional)
    OPTIONAL {
        ?initialScene iq:to ?nextEntity.
        ?nextEntity my:label ?nextEntityLabel;
                   my:comment ?nextEntityComment;
                   my:image ?nextEntityImage.
        OPTIONAL { ?nextEntity my:url ?nextEntityUrl }
    }
}
"""^^<urn:application/x-sparql-query> .

ai:trusts rdf:value """PREFIX iq: <iq:>

CONSTRUCT {
    ?s iq:trusts ?t .
    ?t ?p ?o.
} WHERE {
    {
        ?s iq:trusts ?t .
        ?t ?p ?o.
    }
    UNION
    {
        ?this iq:trusts ?s .
        ?s iq:trusts+ ?t .
        ?t ?p ?o.
    }
    BIND(<{{my.id}}> AS ?this)
}
"""^^<urn:application/x-sparql-query> .

