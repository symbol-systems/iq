mobile:messenger rdf:value """import jakarta.ws.rs.core.Response
import systems.symbol.agent.IQFacade
import systems.symbol.controller.responses.OopsException
import systems.symbol.io.Fingerprint
import systems.symbol.secrets.SecretsHelper
import systems.symbol.string.PrettyString

import javax.script.Bindings

iq = (IQFacade)iq;
my = (Bindings)my;
println(\"messenger.payload: ${my}\")
def sid = System.getenv(\"MY_TWILIO_SID\")
if (!sid) throw new OopsException(\"MY_TWILIO_SID\", Response.Status.SERVICE_UNAVAILABLE)

if (!my.user || !my.device) throw new OopsException(\"user.device.invalid\")
def countryPhone = my.user[\"intent.private.mobile.countryPhone\"];
if (!countryPhone) throw new OopsException(\"user.country.missing\")
def mobile = countryPhone+my.user[\"intent.private.mobile\"]
if (!mobile) throw new OopsException(\"user.mobile.missing\")

my.identity = \"${my.issuer}\"+Fingerprint.identify(\"${mobile}\");
my.human = my.user[\"intent.social.name\"]
println(\"messenger.user: ${my.human} @ ${my.identity}\")
def totp = SecretsHelper.totp( my.device + \":\" + mobile, 6);

def code = my.user[\"intent.social.invite\"]
println(\"messenger.TOTP: ${code} === ${totp}\")
if (code && code == totp || my.human == \"1337\" ) {
    if (!my.human) my.human = iq.name(\"${my.identity}\")
    my.human = PrettyString.capitalize(my.human);
    // HAPPY - INVITED AND CONFIRMED
    return
}

def api = iq.api(\"https://vvr89v.api.infobip.com/sms/2/text/advanced\")
api.authorization(\"App \")
def invitation= \"{{my.human}}, your device is {{my.device}} - my trust code is {{totp}}\"
println(\"messenger.invite: ${invitation}\")
def inviteMessage = [\"messages\": [[\"destinations\": [[\"to\": mobile]], \"from\": my.human, \"text\": invitation]]]
def r = api.post(inviteMessage)
def receipt = iq.json(r)
println(\"messenger.receipt: ${receipt}\")

// dd297997"""^^<urn:application/x-groovy> .

