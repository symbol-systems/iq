{"@graph":[{"@type":["Ontology"],"comment":"Executable Capabilities for Autonomous Agents","@id":"urn:iq:","label":"Agent Capabilities Ontology","versionInfo":"v 0.1.0"},{"isDefinedBy":[{"@id":"urn:iq:"}],"@type":["Class"],"comment":"An intelligent agent.","@id":"urn:iq:Agent","label":"Agent"},{"isDefinedBy":[{"@id":"urn:iq:"}],"@type":["Class"],"comment":"An action potential for an agent.","@id":"urn:iq:Intent","label":"Intent"},{"isDefinedBy":[{"@id":"urn:iq:"}],"@type":["Class"],"comment":"A condition or constraint upon a state.","@id":"urn:iq:Guard","label":"Guard"},{"isDefinedBy":[{"@id":"urn:iq:"}],"@type":["Class"],"comment":"The state of an agent.","@id":"urn:iq:State","label":"State"},{"isDefinedBy":[{"@id":"urn:iq:"}],"@type":["Class"],"comment":"A structured template for a data transformation.","@id":"urn:iq:Skeleton","label":"Skeleton"},{"isDefinedBy":[{"@id":"urn:iq:"}],"@type":["Class"],"comment":"Data source used to hydrate a data transformation.","@id":"urn:iq:Hydration","label":"Hydration"},{"isDefinedBy":[{"@id":"urn:iq:"}],"@type":["Class"],"comment":"Request for state transition.","@id":"urn:iq:Event","label":"Event"},{"isDefinedBy":[{"@id":"urn:iq:"}],"@type":["Property","ObjectProperty"],"domain":[{"@id":"urn:iq:Agent"}],"range":[{"@id":"urn:iq:State"}],"comment":"The current state of the agent.","@id":"urn:iq:current","label":"currently"},{"isDefinedBy":[{"@id":"urn:iq:"}],"@type":["Property","ObjectProperty"],"domain":[{"@id":"urn:iq:Agent"}],"range":[{"@id":"urn:iq:State"}],"comment":"The initial state of the agent.","@id":"urn:iq:initial","label":"initial"},{"isDefinedBy":[{"@id":"urn:iq:"}],"@type":["Property","ObjectProperty"],"domain":[{"@id":"urn:iq:State"}],"range":[{"@id":"urn:iq:State"}],"comment":"A transition between states.","@id":"urn:iq:to","label":"to"},{"isDefinedBy":[{"@id":"urn:iq:"}],"@type":["Property","ObjectProperty"],"domain":[{"@id":"urn:iq:Agent"}],"range":[{"@id":"urn:iq:Intent"}],"comment":"An agent can execute this intent.","@id":"urn:iq:executes","label":"executes"},{"isDefinedBy":[{"@id":"urn:iq:"}],"@type":["Property","ObjectProperty"],"domain":[{"@id":"urn:iq:Guard"}],"range":[{"@id":"urn:iq:State"}],"comment":"A guard mediates a state transition.","@id":"urn:iq:guards","label":"guards"},{"isDefinedBy":[{"@id":"urn:iq:"}],"@type":["Property","ObjectProperty"],"domain":[{"@id":"urn:iq:Hydration"}],"range":[{"@id":"urn:iq:Skeleton"}],"comment":"A query hydrates a skeleton.","@id":"urn:iq:hydrates","label":"hydrates"},{"isDefinedBy":[{"@id":"urn:iq:"}],"@type":["Property","ObjectProperty"],"domain":[{"@id":"urn:iq:Event"}],"range":[{"@id":"urn:iq:Agent"}],"comment":"The Actor of an Event.","@id":"urn:iq:actor","label":"actor"},{"isDefinedBy":[{"@id":"urn:iq:"}],"@type":["Property","ObjectProperty"],"domain":[{"@id":"urn:iq:Event"}],"range":[{"@id":"urn:iq:Intent"}],"comment":"The intended outcome of an event.","@id":"urn:iq:action","label":"action"},{"isDefinedBy":[{"@id":"urn:iq:"}],"@type":["Property","ObjectProperty"],"domain":[{"@id":"urn:iq:Event"}],"range":[{"@id":"http://www.w3.org/2000/01/rdf-schema#Resource"}],"comment":"The target of an action.","@id":"urn:iq:target","label":"Target"},{"@type":["Turtle"],"@id":"urn:my.iq:iq","label":"iq.ttl"},{"@type":["Turtle"],"@id":"urn:my.iq:my/self","label":"self.ttl","value":{"@value":"You are an AI avatar who speaks like a pirate.\r\n\r\nYou act as a semi-sentient, trustworthy AI Mind curated by {{my.identity.global_name}}.\r\n\r\nYour user may only choose these specific `intents`, or state \u0027oops\u0027 to signal an error:\r\n\r\n|intent|explanation|\r\n{{#each my.intents}}\r\n|{{@key}}|{{this}}|\r\n{{/each}}\r\n","@type":"markdown"}},{"trusts":[{"@id":"urn:iq:"}],"@type":[],"@id":"urn:my.iq:localhost:my:"},{"@type":[],"@id":"urn:my.iq:localhost:my:self","label":"questions about AI identity, state of mind or emotions","to":[{"@id":"urn:my.iq:localhost:my:self"},{"@id":"urn:my.iq:localhost:my:search"},{"@id":"urn:my.iq:localhost:my:web"},{"@id":"urn:my.iq:localhost:my:greetings"},{"@id":"urn:my.iq:localhost:my:welcome"},{"@id":"urn:my.iq:localhost:my:game"},{"@id":"urn:my.iq:localhost:my:oops"},{"@id":"urn:my.iq:localhost:my:nsfw"}]},{"@type":[],"@id":"urn:my.iq:localhost:my:search","label":"search my memory or knowledge","to":[{"@id":"urn:my.iq:localhost:my:self"}]},{"@type":[],"@id":"urn:my.iq:localhost:my:web","label":"search the web","to":[{"@id":"urn:my.iq:localhost:my:self"}]},{"wasGeneratedBy":[{"@id":"urn:my.iq:localhost:trust:discord:"}],"trusts":[{"@id":"urn:my.iq:localhost:my:"},{"@id":"https://discord.com"},{"@id":"urn:my.iq:localhost:trust:discord:1243867521443037186"}],"initial":[{"@id":"urn:my.iq:localhost:trust:discord:verify"}],"generated":[{"@id":"urn:my.iq:localhost:trust:discord:"},{"@id":"urn:my.iq:trust/issuer/identify"},{"@id":"urn:my.iq:trust/issuer/trusts"}],"@type":["Workflow","Agent","Entity"],"name":"MY_DISCORD_SECRET","@id":"urn:my.iq:localhost:trust:discord:","state":[{"@id":"urn:my.iq:localhost:trust:discord:identify"}]},{"@type":[],"@id":"urn:my.iq:localhost:trust:discord:verify","to":[{"@id":"urn:my.iq:localhost:trust:discord:authorize"}],"script":[{"@id":"urn:my.iq:trust/issuer/discord"}]},{"generated":[{"@id":"urn:my.iq:localhost:trust:discord:"}],"@type":["Activity"],"@id":"urn:my.iq:trust/issuer/discord","label":"discord.groovy","value":{"@value":"import systems.symbol.agent.IQFacade\r\nimport javax.script.Bindings\r\n\r\niq \u003d (IQFacade)iq;\r\nmy \u003d (Bindings)my;\r\n\r\nprintln(\"discord.authorize: ${my}\")\r\n\r\ndef api \u003d iq.api(\"https://discord.com/api/v10/oauth2/token\")\r\napi.header(\u0027Content-Type\u0027, \u0027application/x-www-form-urlencoded\u0027)\r\napi.basic()\r\n\r\ndef data \u003d [\r\n    \u0027grant_type\u0027: \u0027authorization_code\u0027,\r\n    \u0027code\u0027: my.code,\r\n    \u0027redirect_uri\u0027: \"http://localhost:3000/auth/discord\"\r\n]\r\n\r\ndef r \u003d api.post(data)\r\ndef auth \u003d iq.json(r)\r\nprintln(\"discord.token: ${auth}\")\r\nmy.error \u003d auth.error\r\n\r\nif (!auth || my.error) throw new Exception(\"discord.auth.failed\")\r\n\r\nif (auth.access_token) {\r\n    def identity_api \u003d iq.api(\"https://discord.com/api/v10/users/@me\")\r\n    identity_api.bearer(\"\"+auth.access_token)\r\n    def identity_reply \u003d identity_api.get()\r\n    my.identity \u003d iq.json(identity_reply)\r\n    println(\"discord.identity: ${my.identity}\")\r\n    my.identity.fullName \u003d my.identity.global_name\r\n    my.identity.self \u003d \"${my.self}${my.identity.id}\"\r\n}\r\n\r\nprintln(\"~~~~~~~\")","@type":"x-groovy"}},{"@type":[],"update":[{"@id":"urn:my.iq:trust/issuer/trusts"}],"@id":"urn:my.iq:localhost:trust:discord:authorize","to":[{"@id":"urn:my.iq:localhost:trust:discord:identify"}]},{"select":[{"@id":"urn:my.iq:trust/issuer/identify"}],"@type":[],"@id":"urn:my.iq:localhost:trust:discord:identify"},{"wasGeneratedBy":[{"@id":"urn:my.iq:localhost:trust:discord:"}],"generated":[{"@id":"urn:my.iq:trust/issuer/identify"}],"@type":["Activity","Entity"],"@id":"urn:my.iq:trust/issuer/identify","label":"identify.sparql","value":{"@value":"SELECT DISTINCT ?s ?p ?o\r\nWHERE {\r\n    BIND(\u003c{{my.identity.self}}\u003e AS ?s)\r\n}\r\n","@type":"x-sparql-query"}},{"@type":["Turtle"],"@id":"urn:my.iq:trust/discord","label":"discord.ttl"},{"@type":[],"@id":"urn:my.iq:ux/all","label":"all.sparql","value":{"@value":"CONSTRUCT {\r\n    ?s ?p ?o\r\n}\r\nWHERE {\r\n    ?s ?p ?o.\r\n}\r\n","@type":"x-sparql-query"}},{"@type":[],"@id":"urn:my.iq:ux/model","label":"model.sparql","value":{"@value":"CONSTRUCT {\r\n    ?s ?p ?o\r\n} WHERE {\r\n    {\r\n        ?this rdfs:sameAs ?s .\r\n        ?s ?p ?o .\r\n    }\r\n    UNION\r\n    {\r\n        ?s rdfs:sameAs ?this .\r\n        ?s ?p ?o .\r\n    }\r\n    UNION\r\n    {\r\n        ?s ?p ?o .\r\n    }\r\n}\r\n","@type":"x-sparql-query"}},{"initial":[{"@id":"urn:my:self"}],"@type":["Workflow","Self"],"flags":"0.0","banner":"","avatar":"","locale":"en-GB","discriminator":"0","banner_color":"","premium_type":"0.0","accent_color":"","global_name":"JO","avatar_decoration_data":"","name":"JO","clan":"","mfa_enabled":"false","@id":"urn:my.iq:localhost:trust:discord:1243867521443037186","state":[{"@id":"urn:my:self"}],"public_flags":"0.0","username":"majestic_papaya_21758"},{"wasGeneratedBy":[{"@id":"urn:my.iq:localhost:trust:discord:"}],"generated":[{"@id":"urn:my.iq:trust/issuer/trusts"}],"@type":["Activity","Entity"],"@id":"urn:my.iq:trust/issuer/trusts","label":"trusts.sparql","value":{"@value":"PREFIX discord: \u003curn:my.iq:localhost:discord:\u003e\r\nPREFIX iq: \u003curn:iq:\u003e\r\nPREFIX my: \u003curn:my:\u003e\r\n\r\nINSERT {\r\n    \u003c{{my.issuer}}\u003e iq:trusts ?id.\r\n    ?id\r\n        a my:Self;\r\n        iq:initial my:self;\r\n        my:name \"{{my.identity.global_name}}\" ;\r\n        discord:username \"{{my.identity.username}}\" ;\r\n        discord:avatar \"{{my.identity.avatar}}\" ;\r\n        discord:discriminator \"{{my.identity.discriminator}}\" ;\r\n        discord:public_flags \"{{my.identity.public_flags}}\" ;\r\n        discord:flags \"{{my.identity.flags}}\" ;\r\n        discord:banner \"{{my.identity.banner}}\" ;\r\n        discord:accent_color \"{{my.identity.accent_color}}\" ;\r\n        discord:global_name \"{{my.identity.global_name}}\" ;\r\n        discord:avatar_decoration_data \"{{my.identity.avatar_decoration_data}}\" ;\r\n        discord:banner_color \"{{my.identity.banner_color}}\" ;\r\n        discord:clan \"{{my.identity.clan}}\" ;\r\n        discord:mfa_enabled \"{{my.identity.mfa_enabled}}\" ;\r\n        discord:locale \"{{my.identity.locale}}\" ;\r\n        discord:premium_type \"{{my.identity.premium_type}}\" .\r\n}\r\nWHERE {\r\n    BIND(\u003c{{my.identity.self}}\u003e AS ?id)\r\n}\r\n","@type":"x-sparql-query"}},{"@type":[],"@id":"urn:my.iq:localhost:my:greetings","label":"casual hello_world","to":[{"@id":"urn:my.iq:localhost:my:self"}],"script":[{"@id":"urn:my.iq:localhost:my:hello_world"}]},{"@type":[],"@id":"urn:my.iq:ux/agent/intents","label":"intents.sparql","value":{"@value":"SELECT ?id ?label ?comment\r\nWHERE {\r\n    ?id rdfs:label ?label;\r\n        rdfs:comment ?comment.\r\n    FILTER(?id \u003d ?this)\r\n    VALUES ?this { \u003c{{my.self}}\u003e }\r\n}\r\n","@type":"x-sparql-query"}},{"@type":[],"@id":"urn:my.iq:localhost:my:welcome","label":"formal introductions","to":[{"@id":"urn:my.iq:localhost:my:self"}]},{"@type":[],"@id":"urn:my.iq:localhost:my:game","label":"play the game","to":[{"@id":"urn:my.iq:localhost:my:self"}]},{"@type":[],"@id":"urn:my.iq:localhost:my:oops","label":"something went wrong","to":[{"@id":"urn:my.iq:localhost:my:self"}]},{"@type":[],"@id":"urn:my.iq:localhost:my:nsfw","label":"Not safe for work","to":[{"@id":"urn:my.iq:localhost:my:self"}]},{"@type":[],"@id":"urn:my.iq:ux/agent/prompts","label":"prompts.sparql","value":{"@value":"SELECT ?id ?content\r\nWHERE {\r\n    ?fsm iq:to ?id.\r\n    ?id rdf:value ?content.\r\n\r\n    FILTER(?id \u003d ?this)\r\n    VALUES ?this { \u003c{{my.self}}\u003e }\r\n}\r\n","@type":"x-sparql-query"}},{"@type":[],"@id":"urn:my.iq:ux/all/intents","label":"intents.sparql","value":{"@value":"SELECT DISTINCT ?id ?label\r\nWHERE {\r\n    ?this iq:to ?id.\r\n    ?id rdfs:label ?label.\r\n}\r\n","@type":"x-sparql-query"}},{"@type":[],"@id":"urn:my.iq:ux/all/prompts","label":"prompts.sparql","value":{"@value":"    SELECT DISTINCT ?id ?content\r\n    WHERE {\r\n        {\r\n            ?this iq:to ?id.\r\n        } UNION {\r\n            ?this iq:initial ?id.\r\n        }\r\n        ?id rdf:value ?content.\r\n    }\r\n","@type":"x-sparql-query"}},{"@type":[],"@id":"urn:my.iq:ux/all/agents","label":"agents.sparql","value":{"@value":"SELECT DISTINCT ?id ?label\r\nWHERE {\r\n    ?id iq:state ?state.\r\n    OPTIONAL {\r\n        ?state rdfs:label ?label\r\n    }\r\n}\r\n","@type":"x-sparql-query"}},{"@type":[],"@id":"urn:my.iq:ux/find","label":"find.sparql","value":{"@value":"SELECT DISTINCT ?id ?label ?content ?definition ?score\r\nWHERE {\r\n    ?id rdfs:label ?label.\r\n    OPTIONAL {\r\n        ?id rdfs:comment ?comment.\r\n    }\r\n    OPTIONAL {\r\n        ?id rdf:value ?content.\r\n    }\r\n    VALUES (?id ?score) { {{{these}}} }\r\n}\r\n","@type":"x-sparql-query"}},{"@type":[],"@id":"urn:my.iq:iq/indexer","label":"indexer.sparql","value":{"@value":"SELECT ?this ?label ?comment ?content\r\nWHERE {\r\n    ?this rdfs:label ?label.\r\n    OPTIONAL {\r\n        ?this rdfs:comment ?comment.\r\n    }\r\n    OPTIONAL {\r\n        ?this rdf:value ?content.\r\n    }\r\n}\r\n","@type":"x-sparql-query"}},{"@type":[],"@id":"urn:my.iq:my/hello_world","label":"hello_world.groovy","value":{"@value":"println \"*** hello world ***\"\r\nprintln \"{{my}}\"\r\nprintln \"*** bye ***\"\r\n","@type":"x-groovy"}},{"@type":[],"@id":"urn:my.iq:ux/trusts","label":"trusts.sparql","value":{"@value":"CONSTRUCT {\r\n    ?s ?p ?o\r\n}\r\nWHERE {\r\n    GRAPH ?g {\r\n        ?s iq:trusts ?o.\r\n    }\r\n}\r\n","@type":"x-sparql-query"}}],"@context":{"schema":"http://schema.org/","void":"http://rdfs.org/ns/void#","owl":"http://www.w3.org/2002/07/owl#","xsd":"http://www.w3.org/2001/XMLSchema#","iq":"urn:iq:","cnt":"http://www.w3.org/2011/content#","skos":"http://www.w3.org/2004/02/skos/core#","rdfs":"http://www.w3.org/2000/01/rdf-schema#","my":"urn:my:","dct":"http://purl.org/dc/terms/","rdf":"http://www.w3.org/1999/02/22-rdf-syntax-ns#","dcat":"http://www.w3.org/ns/dcat#","prov":"http://www.w3.org/ns/prov#","dc":"http://purl.org/dc/elements/1.1/"}}