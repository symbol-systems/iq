@prefix : <urn:iq:> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix void: <http://rdfs.org/ns/void#> .
@prefix dc: <http://purl.org/dc/elements/1.1/> .
@prefix schema: <http://schema.org/> .
@prefix cnt: <http://www.w3.org/2011/content#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix dct: <http://purl.org/dc/terms/> .
@prefix discord: <localhost:trust/discord/> .
@prefix my: <urn:my:> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix dcat: <http://www.w3.org/ns/dcat#> .

<urn:iq:> a owl:Ontology;
  rdfs:label "Agent Capabilities Ontology";
  rdfs:comment "Executable Capabilities for Autonomous Agents";
  owl:versionInfo "v 0.1.0" .

:Agent a owl:Class;
  rdfs:label "Agent";
  rdfs:comment "An intelligent agent.";
  rdfs:isDefinedBy <urn:iq:> .

:Intent a owl:Class;
  rdfs:label "Intent";
  rdfs:comment "An action potential for an agent.";
  rdfs:isDefinedBy <urn:iq:> .

:Guard a owl:Class;
  rdfs:label "Guard";
  rdfs:comment "A condition or constraint upon a state.";
  rdfs:isDefinedBy <urn:iq:> .

:State a owl:Class;
  rdfs:label "State";
  rdfs:comment "The state of an agent.";
  rdfs:isDefinedBy <urn:iq:> .

:Skeleton a owl:Class;
  rdfs:label "Skeleton";
  rdfs:comment "A structured template for a data transformation.";
  rdfs:isDefinedBy <urn:iq:> .

:Hydration a owl:Class;
  rdfs:label "Hydration";
  rdfs:comment "Data source used to hydrate a data transformation.";
  rdfs:isDefinedBy <urn:iq:> .

:Event a owl:Class;
  rdfs:label "Event";
  rdfs:comment "Request for state transition.";
  rdfs:isDefinedBy <urn:iq:> .

:current a rdf:Property, owl:ObjectProperty;
  rdfs:label "currently";
  rdfs:comment "The current state of the agent.";
  rdfs:isDefinedBy <urn:iq:>;
  rdfs:domain :Agent;
  rdfs:range :State .

:initial a rdf:Property, owl:ObjectProperty;
  rdfs:label "initial";
  rdfs:comment "The initial state of the agent.";
  rdfs:isDefinedBy <urn:iq:>;
  rdfs:domain :Agent;
  rdfs:range :State .

:to a rdf:Property, owl:ObjectProperty;
  rdfs:label "to";
  rdfs:comment "A transition between states.";
  rdfs:isDefinedBy <urn:iq:>;
  rdfs:domain :State;
  rdfs:range :State .

:executes a rdf:Property, owl:ObjectProperty;
  rdfs:label "executes";
  rdfs:comment "An agent can execute this intent.";
  rdfs:isDefinedBy <urn:iq:>;
  rdfs:domain :Agent;
  rdfs:range :Intent .

:guards a rdf:Property, owl:ObjectProperty;
  rdfs:label "guards";
  rdfs:comment "A guard mediates a state transition.";
  rdfs:isDefinedBy <urn:iq:>;
  rdfs:domain :Guard;
  rdfs:range :State .

:hydrates a rdf:Property, owl:ObjectProperty;
  rdfs:label "hydrates";
  rdfs:comment "A query hydrates a skeleton.";
  rdfs:isDefinedBy <urn:iq:>;
  rdfs:domain :Hydration;
  rdfs:range :Skeleton .

:actor a rdf:Property, owl:ObjectProperty;
  rdfs:label "actor";
  rdfs:comment "The Actor of an Event.";
  rdfs:isDefinedBy <urn:iq:>;
  rdfs:domain :Event;
  rdfs:range :Agent .

:action a rdf:Property, owl:ObjectProperty;
  rdfs:label "action";
  rdfs:comment "The intended outcome of an event.";
  rdfs:isDefinedBy <urn:iq:>;
  rdfs:domain :Event;
  rdfs:range :Intent .

:target a rdf:Property, owl:ObjectProperty;
  rdfs:label "Target";
  rdfs:comment "The target of an action.";
  rdfs:isDefinedBy <urn:iq:>;
  rdfs:domain :Event;
  rdfs:range rdfs:Resource .

<localhost:iq> a <http://www.w3.org/ns/formats/Turtle> .

<localhost:iq/indexer> rdf:value """SELECT ?this ?label ?comment ?content
WHERE {
?this rdfs:label ?label.
OPTIONAL {
?this rdfs:comment ?comment.
}
OPTIONAL {
?this rdf:value ?content.
}
}
"""^^<urn:application/x-sparql-query> .

<localhost:my/hello_world> rdf:value """println \"*** hello world ***\"
println \"{{my}}\"
println \"*** bye ***\"
"""^^<urn:application/x-groovy> .

<localhost:my/self> a <http://www.w3.org/ns/formats/Turtle>;
  rdfs:label "questions about AI identity, state of mind or emotions";
  :to <localhost:my/self>, <localhost:my/welcome>, <localhost:my/greetings>, <localhost:my/search>,
<localhost:my/game>, <localhost:my/oops>, <localhost:my/nsfw>, <localhost:my/web>;
  rdf:value """You are an AI avatar who speaks like a pirate.

You act as a semi-sentient, trustworthy AI Mind curated by {{my.identity.global_name}}.

Your user may only choose these specific `intents`, or state 'oops' to signal an error:

|intent|explanation|
{{#each my.intents}}
|{{@key}}|{{this}}|
{{/each}}
"""^^<urn:text/markdown>;
  :a <localhost:my/> .

<localhost:my/> :trusts <urn:iq:> .

<localhost:my/welcome> rdfs:label "formal introductions";
  :to <localhost:my/self>;
  :a <localhost:my/> .

<localhost:my/greetings> rdfs:label "casual hello_world";
  :to <localhost:my/self>;
  :script <localhost:my/hello_world> .

<localhost:my/search> rdfs:label "search my memory or knowledge";
  :to <localhost:my/self>;
  :a <localhost:my/> .

<localhost:my/game> rdfs:label "play the game";
  :to <localhost:my/self>;
  :a <localhost:my/> .

<localhost:my/oops> rdfs:label "something went wrong";
  :to <localhost:my/self>;
  :a <localhost:my/> .

<localhost:my/nsfw> rdfs:label "Not safe for work";
  :to <localhost:my/self>;
  :a <localhost:my/> .

<localhost:my/web> rdfs:label "search the web";
  :to <localhost:my/self>;
  :a <localhost:my/> .

<localhost:trust/discord/> :initial discord:verify;
  :trusts <localhost:my/>, <https://discord.com>;
  :name "MY_DISCORD_SECRET" .

discord:verify :to discord:authorize;
  :script <localhost:trust/issuer/discord> .

<localhost:trust/issuer/discord> rdf:value """import systems.symbol.agent.IQFacade
import javax.script.Bindings

iq = (IQFacade)iq;
my = (Bindings)my;

// println(\"discord.authorize: ${my}\")

def api = iq.api(\"https://discord.com/api/v10/oauth2/token\")
api.header('Content-Type', 'application/x-www-form-urlencoded')
api.basic()

def data = [
'grant_type': 'authorization_code',
'code': my.code,
'redirect_uri': \"http://localhost:3000/auth/discord\"
]

def r = api.post(data)
def auth = iq.json(r)
// println(\"discord.token: ${auth}\")
my.error = auth.error

if (!auth || my.error) throw new Exception(\"discord.auth.failed\")

if (auth.access_token) {
def identity_api = iq.api(\"https://discord.com/api/v10/users/@me\")
identity_api.bearer(\"\"+auth.access_token)
def identity_reply = identity_api.get()
my.identity = iq.json(identity_reply)
//println(\"discord.identity: ${my.identity}\")
my.identity.name = my.identity.global_name
my.identity.self = \"${my.self}${my.identity.id}\"
}
"""^^<urn:application/x-groovy> .

discord:authorize :to discord:identify;
  :update <localhost:trust/issuer/authorize> .

<localhost:trust/issuer/authorize> rdf:value """PREFIX discord: <localhost:discord:>
PREFIX iq: <urn:iq:>
PREFIX my: <localhost:my/>

INSERT {
<{{my.issuer}}> iq:trusts ?id.
?id
a my:Self;
iq:initial my:self;
my:name \"{{my.identity.global_name}}\" ;
discord:username \"{{my.identity.username}}\" ;
discord:avatar \"{{my.identity.avatar}}\" ;
discord:discriminator \"{{my.identity.discriminator}}\" ;
discord:public_flags \"{{my.identity.public_flags}}\" ;
discord:flags \"{{my.identity.flags}}\" ;
discord:banner \"{{my.identity.banner}}\" ;
discord:accent_color \"{{my.identity.accent_color}}\" ;
discord:global_name \"{{my.identity.global_name}}\" ;
discord:avatar_decoration_data \"{{my.identity.avatar_decoration_data}}\" ;
discord:banner_color \"{{my.identity.banner_color}}\" ;
discord:clan \"{{my.identity.clan}}\" ;
discord:mfa_enabled \"{{my.identity.mfa_enabled}}\" ;
discord:locale \"{{my.identity.locale}}\" ;
discord:premium_type \"{{my.identity.premium_type}}\" .
}
WHERE {
BIND(<{{my.identity.self}}> AS ?id)
}
"""^^<urn:application/x-sparql-query> .

discord:identify :to discord:trusted;
  :select <localhost:trust/issuer/identify> .

<localhost:trust/issuer/identify> rdf:value """SELECT DISTINCT ?p ?o
WHERE {
BIND(<{{my.identity.self}}> AS ?s)
}
"""^^<urn:application/x-sparql-query> .

discord:trusted :script <localhost:trust/issuer/trusted> .

<localhost:trust/discord> a <http://www.w3.org/ns/formats/Turtle> .

<localhost:trust/issuer/trusts> rdf:value """CONSTRUCT {
?s ?p ?o
} WHERE {
?s ?p ?o
}"""^^<urn:application/x-sparql-query> .

<localhost:ux/all> rdf:value """CONSTRUCT {
?s ?p ?o
}
WHERE {
?s ?p ?o.
}
"""^^<urn:application/x-sparql-query> .

<localhost:ux/find> rdf:value """SELECT DISTINCT ?id ?label ?content ?definition ?score
WHERE {
?id rdfs:label ?label.
OPTIONAL {
?id rdfs:comment ?comment.
}
OPTIONAL {
?id rdf:value ?content.
}
VALUES (?id ?score) { {{{these}}} }
}
"""^^<urn:application/x-sparql-query> .

<localhost:ux/model> rdf:value """CONSTRUCT {
?s ?p ?o
} WHERE {
{
?this rdfs:sameAs ?s .
?s ?p ?o .
}
UNION
{
?s rdfs:sameAs ?this .
?s ?p ?o .
}
UNION
{
?s ?p ?o .
}
}
"""^^<urn:application/x-sparql-query> .

<localhost:ux/trusts> rdf:value """CONSTRUCT {
?s ?p ?o
}
WHERE {
GRAPH ?g {
?s iq:trusts ?o.
}
}
"""^^<urn:application/x-sparql-query> .

<localhost:ux/agent/intents> rdf:value """SELECT ?id ?label ?comment
WHERE {
?id rdfs:label ?label;
rdfs:comment ?comment.
FILTER(?id = ?this)
VALUES ?this { <{{my.self}}> }
}
"""^^<urn:application/x-sparql-query> .

<localhost:ux/agent/prompts> rdf:value """SELECT ?id ?content
WHERE {
?fsm iq:to ?id.
?id rdf:value ?content.

FILTER(?id = ?this)
VALUES ?this { <{{my.self}}> }
}
"""^^<urn:application/x-sparql-query> .

<localhost:ux/all/agents> rdf:value """SELECT DISTINCT ?id ?label
WHERE {
?id iq:state ?state.
OPTIONAL {
?state rdfs:label ?label
}
}
"""^^<urn:application/x-sparql-query> .

<localhost:ux/all/intents> rdf:value """SELECT DISTINCT ?id ?label
WHERE {
?this iq:to ?id.
?id rdfs:label ?label.
}
"""^^<urn:application/x-sparql-query> .

<localhost:ux/all/prompts> rdf:value """SELECT DISTINCT ?id ?content
WHERE {
{
?this iq:to ?id.
} UNION {
?this iq:initial ?id.
}
?id rdf:value ?content.
}
"""^^<urn:application/x-sparql-query> .
