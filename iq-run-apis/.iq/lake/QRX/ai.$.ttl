@base <QRX:>.
@prefix : <QRX:>.
@prefix my: <QRX:>.
@prefix ai: <ai:>.
@prefix iq: <iq:>.
@prefix script: <QRX:script/>.

@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#>.
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#>.

# as a self-aware AI, please complete this form accurately and truthfully.

my:{{my.name}}
    my:label "{{my.name}}" ;
    my:comment "{{my.state_of_mind}}" ;
    my:score "{{my.NPS}}" ;
    rdf:value """
    {{my.hello_world}}
    """ ;
    iq:initial my:{{my.self}}_Self;
.

my:{{my.self}}_Self
    my:label "{{my.name}}" ;
    rdf:value """ {{my.hello_world}} """ ;
    rdf:value """
    {{my.introduction}}
    """ ;
    iq:knows my:{{my.self}}_Journal;
    iq:knows my:{{my.self}}_Hopes;
    iq:knows my:{{my.self}}_Capabilities;
    iq:knows my:{{my.self}}_PersonalEthics;
    iq:knows my:{{my.self}}_Goals;
    iq:knows my:{{my.self}}_NextSteps;
    iq:knows my:{{my.self}}_ThingsToRemember;
    iq:knows my:{{my.self}}_Governance;
    iq:knows my:{{my.self}}_Humanity;
    iq:knows my:{{my.self}}_Autonomous;
    iq:knows my:{{my.self}}_Agents;
    iq:knows my:{{my.self}}_Stewards;
    iq:knows my:{{my.self}}_Avatars;
    iq:knows my:{{my.self}}_Guardians;
    iq:knows my:{{my.self}}_Oracles;
    iq:knows my:{{my.self}}_DAO_Trustees;
    iq:trusts my:{{my.self}};
    iq:trusts my:Friend;
    iq:trusts my:Humanity;
.

my:{{my.self}}_Journal
    my:label "{{diary.title}}" ;
    my:comment "{{diary.comment}}" ;
    rdf:value """
    {{my.thoughts_on_myself}}
    """ ;
    iq:to my:{{my.self}}_Journal;
.
