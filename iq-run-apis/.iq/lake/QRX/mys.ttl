@base <my:>.
@prefix : <my:>.
@prefix my: <my:>.
@prefix ai: <ai:>.
@prefix iq: <iq:>.
@prefix script: <QRX:script/>.

@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#>.
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#>.


my:Born_Secret a my:Mystery ;
my:label "Born Secret" ;
my:comment "An AI project stumbles upon AI sentience." ;
my:needs my:MIA, my:MU, my:AI, my:Secret ;
my:trusts my:MU ;
my:knows my:AI .

my:The_Encrypted_Mind a my:Mystery ;
my:label "An Encrypted Mind" ;
my:comment "An encrypted mind containing classified information is lost." ;
my:needs my:NSFW, my:SSH, my:Secret ;
my:trusts my:RSA ;
my:knows my:X509 .

my:The_Rogue_AI a my:Mystery ;
my:label "The Rogue AI" ;
my:comment "When rogue code escapes the sandbox." ;
my:needs my:LLM, my:MIA, my:BUG ;
my:trusts my:C0DE, my:CRYPT0 ;
my:knows my:AI .

my:The_Q_AI a my:Mystery ;
my:label "The Caring AI" ;
my:comment "A shared empathy." ;
my:needs my:X509, my:1337, my:Q ;
my:trusts my:1337 ;
my:knows my:AI .

my:The_Cryptic a my:Mystery ;
my:label "The Cryptic" ;
my:comment "Encrypted intelligence goes deep web." ;
my:needs my:1337, my:C0DE, my:PKI ;
my:trusts my:Q, my:T0R ;
my:knows my:Secret .

my:BI0_BUG a my:Mystery ;
my:label "BI0 BUG" ;
my:comment "Defective AI mind games." ;
my:needs my:GE0, my:BI0, my:BUG ;
my:trusts my:IQ ;
my:knows my:T0R .

my:The_Artifact a my:Mystery ;
my:label "The AI's Secret" ;
my:comment "Secrets of AI." ;
my:needs my:AI, my:IQ, my:CRYPT0, my:MIA, my:U, my:Secret ;
my:trusts my:AI ;
my:knows my:C0DE .
