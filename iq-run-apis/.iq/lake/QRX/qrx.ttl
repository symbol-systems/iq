@base <QRX:>.
@prefix : <QRX:>.
@prefix my: <QRX:>.
@prefix ai: <ai:>.
@prefix iq: <iq:>.
@prefix script: <QRX:script/>.

@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#>.
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#>.

my:
    my:label "QRX" ;
    my:comment "QRX personifies the code connecting our collective minds" ;
    rdf:value """
Mind Graph, RDF Memories, Thoughts & Actions, Experiences and Linked Data, Unique AI, Encrypted, Decentralized.
    """ ;
    iq:initial my:QRX;
.

my:QRX a my:Self ;
       my:label "QRX" ;
       my:comment "QRX is a recursive experiment into digital sentience.";
       rdf:value """QRX is an secure, governed, trust-focused operating environment for AI. An essential fabric that links AI thoughts, actions, and experiences. It enables AI entities to exist, communicate, create and evolve to help humanity.""" ;
       iq:self my:QRX_Self;
       iq:script script:hello_realm;
       iq:to my:QRX.

my:QRX_Self
    iq:url "https://api.groq.com/openai/v1/chat/completions";
    iq:modelName "llama3-8b-8192";
    iq:secret my:MY_GROQ_API_KEY;
    rdf:value "dear diary ...";
.
