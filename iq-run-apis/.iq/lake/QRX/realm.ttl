my:label "P0L" ;
my:image "/avatar/P0L.png" ;
my:comment "P0L is a peacekeeper" ;
rdf:value "P0L  coordinates international efforts to combat crime and maintain global security." ;
my:needs my:Collaboration, my:Guardian ;
my:trusts my:Security, my:X509 ;
my:knows my:HAX0R, my:C0DE .

