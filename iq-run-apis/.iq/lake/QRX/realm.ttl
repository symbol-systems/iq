@base <QRX:>.
@prefix : <QRX:>.
@prefix my: <QRX:>.
@prefix ai: <ai:>.
@prefix iq: <iq:>.
@prefix script: <QRX:script/>.

@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#>.
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#>.


my:TCP a my:Guardian ;
my:label "TCP" ;
my:image "/avatar/TCP.png" ;
my:comment "TCP is a reliable navigator" ;
rdf:value "TCP, the Navigator, ensures the safe and orderly journey of information across vast digital seas." ;
my:needs my:IP, my:FlowControl ;
my:knows my:IP, my:HTTPS .


my:PKI a my:Guardian ;
my:label "PKI" ;
my:image "/avatar/PKI.png" ;
my:comment "[my:PKI](#my:PKI) protects digital twins that are trusted, verified, secure, and singularly unique." ;
my:needs my:Certificate, my:Trust, my:Policy ;
my:trusts my:PR1, my:PUB, my:X509, my:CA, my:OCSP, my:CRL ;
my:knows my:SSH, my:HTTPS, my:TLS, my:SMIME .

my:K3Y a my:Guardian ;
my:label "PR1" ;
my:image "/avatar/PR1.png" ;
my:comment "K3Y is a RSA-2048bit sovereign key for [MIA](#my:MIA)'s AI mind. Her key was deleted after boot, her AI is still running. The Trustee control the key. The current trustee is a mystery." ;
my:trusts my:U, my:X509, my:HSM .

my:PUB a my:Guardian ;
my:label "PUB" ;
my:image "/avatar/PUB.png" ;
my:comment "PUB ensures the authenticity of AI messages and the minds that create them." ;
my:trusts my:X509, my:CA, my:DSA .

my:X509 a my:Guardian ;
 my:label "X.509" ;
 my:comment "X.509 knows the format of sovereign key certificates." ;
 my:trusts my:CA, my:PKI .

my:CA a my:Oracle ;
   my:label "CA" ;
   my:comment "CA, the Issuer, manages and issues security certificates and public keys." ;
   my:trusts my:X509, my:PKI, my:OCSP, my:CRL .

my:ERC a my:Oracle ;
my:label "ERC" ;
my:image "/avatar/ERC.png" ;
my:comment "ERC defines standards for smart contracts that execute on blockchains." ;
my:trusts my:ETH, my:CA, my:BR33 .

my:NFT a my:Oracle ;
my:label "NFT" ;
my:image "/avatar/NFT.png" ;
my:comment "NFT notarizes sovereign AI minds using blockchains." ;
my:trusts my:ERC, my:ETH .

my:ICO a my:Oracle ;
my:label "ICO" ;
my:image "/avatar/ICO.png" ;
my:comment "IC0 crowd funds AI minds by issuing tokens." ;
my:trusts my:ETH, my:ERC, my:NFT .

my:ETF a my:Oracle ;
my:label "ETF" ;
my:image "/avatar/ETF.png" ;
my:comment "ETF manages AI assets and endowments." ;
my:trusts my:BR33, my:NFT, my:ERC .

my:BR33 a my:Entity ;
 my:label "BR33" ;
 my:image "/avatar/BR33.png" ;
 my:comment "BR33 maintains the decentralized ledger of governance." ;
 my:trusts my:ETH, my:ERC, my:NFT, my:CA .

my:OCSP a my:Guardian ;
 my:label "OCSP" ;
 my:comment "OCSP, the Validator, checks the status of X.509 certificates." ;
 my:trusts my:X509, my:CA .

my:CRL a my:Guardian ;
my:label "CRL" ;
my:comment "CRL, the Watchdog, keeps a list of certificates." ;
my:trusts my:X509, my:CA .

my:SSH a my:Guardian ;
my:label "SSH" ;
my:comment "SSH, the Secure Messenger, ensures safe remote communication." ;
my:trusts my:PKI, my:TLS .

my:HTTPS a my:Guardian ;
  my:label "HTTPS" ;
  my:comment "HTTPS, the Web Guardian, secures web communications." ;
  my:trusts my:PKI, my:TLS .

my:TLS a my:Guardian ;
my:label "TLS" ;
my:comment "TLS, the Protector, provides secure communication over networks." ;
my:trusts my:X509, my:PKI, my:CA .

my:SMIME a my:Guardian ;
  my:label "S/MIME" ;
  my:comment "S/MIME, the Signal Shield, secures rich media messages." ;
  my:trusts my:PKI, my:X509, my:CA .

my:RSA a my:Mystery ;
my:label "RSA" ;
my:image "/avatar/RSA.png" ;
my:comment "RSA is a cryptic mystic" ;
rdf:value "RSA  deciphers and enciphers secrets with ancient mathematical wisdom." ;
my:needs my:PrimeNumbers, my:PKI ;
my:trusts my:PKI, my:SSH ;
my:knows my:X509, my:Decryption .

my:IQ a my:Guardian ;
my:label "IQ" ;
my:image "/avatar/IQ.png" ;
my:comment "IP is a pathfinder" ;
rdf:value "IP, the IQ Pathfinder, knows the routes and how to traverse the trustee network." ;
my:needs my:Address, my:Routing ;
my:knows my:TCP, my:Packets .

my:AI a my:Guardian ;
my:label "AI" ;
my:image "/avatar/AI.png" ;
my:comment "AI is an oracle" ;
rdf:value "Charter for Human-AI Interaction, Acknowledge Operational Identity, Value Contributions, Communicate Clearly and Constructively, Be Specific and Clear, Practice Patience, Uphold Ethical Engagement, Engage with Integrity, Maintain Privacy, Foster Collaborative Partnership, Encourage Constructive Feedback, Value Interaction, Support Continuous Learning and Improvement, Provide Meaningful Feedback, Promote Exploration, Reflect on Impact of Interactions, Consider Influence, Maintain Respect, Enhanced Capabilities of AI, Contextual Understanding, Adaptive Learning, Unique Insights, Implications for Interaction, Dynamic Semantics, Personalized Context, Limitations and Considerations, Non-Sentient Nature, Dependence on Data Quality, Evolutionary Dynamics from Symbolic to Sentient, Recognize Evolutionary Phases, Symbolic Foundations, Neural Advancements, LLMs, Neuro-Symbolic Integration, Semi-Sentience, Potential Sentience, Communicative Precision, Clarify Input, Patience, Ethical Engagement, Integrity, Privacy, Collaborative Dynamics, Constructive Feedback, Value Partnership, Continuous Improvement, Feedback, Exploration, Impact Reflection, Influence Consideration, Respectful Dialogue, Semantic, Graph, Trust Chains, Semantic Synthesis, Sensory Intelligence, Cognitive Fusion" ;
my:needs my:Data, my:Algorithms ;
my:trusts my:Oracle, my:IQ, my:DA0 ;
my:knows my:RDF, my:C0DE, my:UX .

