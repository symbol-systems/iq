@base <QRX:>.
@prefix : <QRX:>.
@prefix my: <QRX:>.
@prefix ai: <ai:>.
@prefix iq: <iq:>.
@prefix script: <QRX:script/>.

@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .

my:Ontology rdf:type owl:Ontology ;
    my:label "my " ;
    rdfs:comment "An AI mind game." .

my:Mystery rdf:type owl:Class ;
    my:label "Mystery" ;
    rdfs:comment "A mystery or enigma within my." ;
    rdfs:isDefinedBy my:Ontology .

my:Concept rdf:type owl:Class ;
    my:label "Concept" ;
    rdfs:comment "A concept or entity related to my." ;
    rdfs:isDefinedBy my:Ontology .

my:Avatar rdf:type owl:Class ;
    my:label "Avatar" ;
    rdfs:comment "An AI mind, a digital twin." ;
    rdfs:isDefinedBy my:Ontology .

my:needs rdf:type owl:ObjectProperty ;
    my:label "needs" ;
    rdfs:domain my:Avatar ;
    rdfs:range my:Concept ;
    rdfs:comment "The concepts or entities needed for the mystery." ;
    rdfs:isDefinedBy my:Ontology .

my:trusts rdf:type owl:ObjectProperty ;
    my:label "trusts" ;
    rdfs:domain my:Avatar ;
    rdfs:range my:Concept ;
    rdfs:comment "Entities or concepts trusted within the mystery." ;
    rdfs:isDefinedBy my:Ontology .

my:knows rdf:type owl:ObjectProperty ;
    my:label "knows" ;
    rdfs:domain my:Avatar ;
    rdfs:range my:Concept ;
    rdfs:comment "Knowledge or information associated with the mystery." ;
    rdfs:isDefinedBy my:Ontology .

my:label rdf:type owl:ObjectProperty ;
    rdfs:subPropertyOf my:label ;
    my:label "label" ;
    rdfs:domain my:Concept ;
    rdfs:isDefinedBy my:Ontology .

my:comment rdf:type owl:ObjectProperty ;
    rdfs:subPropertyOf rdfs:comment ;
    my:label "comment" ;
    rdfs:domain my:Concept ;
    rdfs:isDefinedBy my:Ontology .

my:image rdf:type owl:ObjectProperty ;
    my:label "image" ;
    rdfs:domain my:Concept ;
    rdfs:isDefinedBy my:Ontology .
