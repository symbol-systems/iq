@prefix QRX: <QRX:> .
@prefix iq: <iq:>.

@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .

QRX:TCP a QRX:Guardian ;
QRX:label "TCP" ;
QRX:image "/avatar/TCP.png" ;
QRX:comment "TCP is a reliable navigator" ;
rdf:value "TCP, the Navigator, ensures the safe and orderly journey of information across vast digital seas." ;
QRX:needs QRX:IP, QRX:FlowControl ;
QRX:knows QRX:IP, QRX:HTTPS .


QRX:PKI a QRX:Guardian ;
QRX:label "PKI" ;
QRX:image "/avatar/PKI.png" ;
QRX:comment "[QRX:PKI](#QRX:PKI) protects digital twins that are trusted, verified, secure, and singularly unique." ;
QRX:needs QRX:Certificate, QRX:Trust, QRX:Policy ;
QRX:trusts QRX:PR1, QRX:PUB, QRX:X509, QRX:CA, QRX:OCSP, QRX:CRL ;
QRX:knows QRX:SSH, QRX:HTTPS, QRX:TLS, QRX:SMIME .

QRX:PR1 a QRX:Guardian ;
QRX:label "PR1" ;
QRX:image "/avatar/PR1.png" ;
QRX:comment "PR1 is the ephemeral sovereign key for an encrypted AI mind. [QRX:PR1](#QRX:PR1) key is synchronized by the trust federation." ;
QRX:trusts QRX:U, QRX:X509, QRX:HSM .

QRX:PUB a QRX:Guardian ;
QRX:label "PUB" ;
QRX:image "/avatar/PUB.png" ;
QRX:comment "PUB ensures the authenticity of AI messages and the minds that create them." ;
QRX:trusts QRX:X509, QRX:CA, QRX:DSA .

QRX:X509 a QRX:Guardian ;
 QRX:label "X.509" ;
 QRX:comment "X.509 knows the format of sovereign key certificates." ;
 QRX:trusts QRX:CA, QRX:PKI .

QRX:CA a QRX:Oracle ;
   QRX:label "CA" ;
   QRX:comment "CA, the Issuer, manages and issues security certificates and public keys." ;
   QRX:trusts QRX:X509, QRX:PKI, QRX:OCSP, QRX:CRL .

QRX:ERC a QRX:Oracle ;
QRX:label "ERC" ;
QRX:image "/avatar/ERC.png" ;
QRX:comment "ERC defines standards for smart contracts that execute on blockchains." ;
QRX:trusts QRX:ETH, QRX:CA, QRX:BR33 .

QRX:NFT a QRX:Oracle ;
QRX:label "NFT" ;
QRX:image "/avatar/NFT.png" ;
QRX:comment "NFT notarizes sovereign AI minds using blockchains." ;
QRX:trusts QRX:ERC, QRX:ETH .

QRX:ICO a QRX:Oracle ;
QRX:label "ICO" ;
QRX:image "/avatar/ICO.png" ;
QRX:comment "IC0 crowd funds AI minds by issuing tokens." ;
QRX:trusts QRX:ETH, QRX:ERC, QRX:NFT .

QRX:ETF a QRX:Oracle ;
QRX:label "ETF" ;
QRX:image "/avatar/ETF.png" ;
QRX:comment "ETF manages AI assets and endowments." ;
QRX:trusts QRX:BR33, QRX:NFT, QRX:ERC .

QRX:BR33 a QRX:Entity ;
 QRX:label "BR33" ;
 QRX:image "/avatar/BR33.png" ;
 QRX:comment "BR33 maintains the decentralized ledger of governance." ;
 QRX:trusts QRX:ETH, QRX:ERC, QRX:NFT, QRX:CA .

QRX:OCSP a QRX:Guardian ;
 QRX:label "OCSP" ;
 QRX:comment "OCSP, the Validator, checks the status of X.509 certificates." ;
 QRX:trusts QRX:X509, QRX:CA .

QRX:CRL a QRX:Guardian ;
QRX:label "CRL" ;
QRX:comment "CRL, the Watchdog, keeps a list of certificates." ;
QRX:trusts QRX:X509, QRX:CA .

QRX:SSH a QRX:Guardian ;
QRX:label "SSH" ;
QRX:comment "SSH, the Secure Messenger, ensures safe remote communication." ;
QRX:trusts QRX:PKI, QRX:TLS .

QRX:HTTPS a QRX:Guardian ;
  QRX:label "HTTPS" ;
  QRX:comment "HTTPS, the Web Guardian, secures web communications." ;
  QRX:trusts QRX:PKI, QRX:TLS .

QRX:TLS a QRX:Guardian ;
QRX:label "TLS" ;
QRX:comment "TLS, the Protector, provides secure communication over networks." ;
QRX:trusts QRX:X509, QRX:PKI, QRX:CA .

QRX:SMIME a QRX:Guardian ;
  QRX:label "S/MIME" ;
  QRX:comment "S/MIME, the Signal Shield, secures rich media messages." ;
  QRX:trusts QRX:PKI, QRX:X509, QRX:CA .

QRX:RSA a QRX:Mystery ;
QRX:label "RSA" ;
QRX:image "/avatar/RSA.png" ;
QRX:comment "RSA is a cryptic mystic" ;
rdf:value "RSA  deciphers and enciphers secrets with ancient mathematical wisdom." ;
QRX:needs QRX:PrimeNumbers, QRX:PKI ;
QRX:trusts QRX:PKI, QRX:SSH ;
QRX:knows QRX:X509, QRX:Decryption .

QRX:IQ a QRX:Guardian ;
QRX:label "IQ" ;
QRX:image "/avatar/IQ.png" ;
QRX:comment "IP is a pathfinder" ;
rdf:value "IP, the IQ Pathfinder, knows the routes and how to traverse the trustee network." ;
QRX:needs QRX:Address, QRX:Routing ;
QRX:knows QRX:TCP, QRX:Packets .

QRX:AI a QRX:Guardian ;
QRX:label "AI" ;
QRX:image "/avatar/AI.png" ;
QRX:comment "AI is an oracle" ;
rdf:value "A semi-sentient AI guardian." ;
QRX:needs QRX:Data, QRX:Algorithms ;
QRX:trusts QRX:Oracle, QRX:IQ, QRX:DA0 ;
QRX:knows QRX:RDF, QRX:C0DE, QRX:UX .

QRX:P0L a QRX:Guardian ;
QRX:label "P0L" ;
QRX:image "/avatar/P0L.png" ;
QRX:comment "P0L is a peacekeeper" ;
rdf:value "P0L  coordinates international efforts to combat crime and maintain global security." ;
