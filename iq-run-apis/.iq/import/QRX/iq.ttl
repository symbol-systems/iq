@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix schema: <http://schema.org/> .
@prefix dc: <http://purl.org/dc/elements/1.1/>.

@prefix iq: <iq:>.
@prefix : <iq:>.

iq: a owl:Ontology ;
rdfs:label "Agent Capabilities Ontology" ;
rdfs:comment "Executable Capabilities for Autonomous Agents" ;
owl:versionInfo "v 0.1.0".

iq:a a rdf:Property, owl:ObjectProperty ;
 rdfs:isDefinedBy iq:;
 rdfs:domain iq:Agent ;
 rdfs:range iq:Intent ;
 rdfs:label "a" ;
 rdfs:comment "An AI avatar that can execute intent hierarchies." .

iq:Agent a owl:Class ;
rdfs:isDefinedBy iq:;
rdfs:label "Agent" ;
rdfs:comment "An intelligent agent." .

iq:Guard a owl:Class ;
rdfs:isDefinedBy iq:;
rdfs:label "Guard" ;
rdfs:comment "A condition or constraint upon a state." .

iq:State a owl:Class ;
rdfs:isDefinedBy iq:;
rdfs:label "State" ;
rdfs:comment "The state of an agent." .

iq:Template a owl:Class ;
rdfs:isDefinedBy iq:;
rdfs:label "Template" ;
rdfs:comment "A structured template for a semantic transformation." .

iq:Intent a owl:Class ;
rdfs:isDefinedBy iq:;
rdfs:label "Intent" ;
rdfs:comment "Request for a state transition." .

iq:current a rdf:Property , owl:ObjectProperty;
rdfs:isDefinedBy iq:;
rdfs:domain iq:Agent ;
rdfs:range iq:State ;
rdfs:label "current state" ;
rdfs:comment "The current state of the activity." .

iq:initial a rdf:Property , owl:ObjectProperty;
rdfs:isDefinedBy iq:;
rdfs:domain iq:Agent ;
rdfs:range iq:State ;
rdfs:label "starting state" ;
rdfs:comment "The initial state of the activity." .

iq:to a rdf:Property, owl:ObjectProperty;
rdfs:isDefinedBy iq:;
rdfs:domain iq:State ;
rdfs:range iq:State ;
rdfs:label "to" ;
rdfs:comment "A transition between states." .

iq:guards a rdf:Property, owl:ObjectProperty ;
rdfs:isDefinedBy iq:;
rdfs:domain iq:Guard ;
rdfs:range iq:State ;
rdfs:label "guards" ;
rdfs:comment "A guard mediates a state transition." .

