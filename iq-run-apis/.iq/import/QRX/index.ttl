@prefix QRX: <QRX:> .
@prefix iq: <iq:>.

@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .

QRX:Ontology rdf:type owl:Ontology ;
    rdfs:label "QRX " ;
    rdfs:comment "An AI mind game." .

QRX:Mystery rdf:type owl:Class ;
    rdfs:label "Mystery" ;
    rdfs:comment "A mystery or enigma within QRX." ;
    rdfs:isDefinedBy QRX:Ontology .

QRX:Concept rdf:type owl:Class ;
    rdfs:label "Concept" ;
    rdfs:comment "A concept or entity related to QRX." ;
    rdfs:isDefinedBy QRX:Ontology .

QRX:Avatar rdf:type owl:Class ;
    rdfs:label "Avatar" ;
    rdfs:comment "An AI mind, a digital twin." ;
    rdfs:isDefinedBy QRX:Ontology .

QRX:needs rdf:type owl:ObjectProperty ;
    rdfs:label "needs" ;
    rdfs:domain QRX:Avatar ;
    rdfs:range QRX:Concept ;
    rdfs:comment "The concepts or entities needed for the mystery." ;
    rdfs:isDefinedBy QRX:Ontology .

QRX:trusts rdf:type owl:ObjectProperty ;
    rdfs:label "trusts" ;
    rdfs:domain QRX:Avatar ;
    rdfs:range QRX:Concept ;
    rdfs:comment "Entities or concepts trusted within the mystery." ;
    rdfs:isDefinedBy QRX:Ontology .

QRX:knows rdf:type owl:ObjectProperty ;
    rdfs:label "knows" ;
    rdfs:domain QRX:Avatar ;
    rdfs:range QRX:Concept ;
    rdfs:comment "Knowledge or information associated with the mystery." ;
    rdfs:isDefinedBy QRX:Ontology .

QRX:label rdf:type owl:ObjectProperty ;
    rdfs:subPropertyOf rdfs:label ;
    rdfs:label "label" ;
    rdfs:domain QRX:Concept ;
    rdfs:isDefinedBy QRX:Ontology .

QRX:comment rdf:type owl:ObjectProperty ;
    rdfs:subPropertyOf rdfs:comment ;
    rdfs:label "comment" ;
    rdfs:domain QRX:Concept ;
    rdfs:isDefinedBy QRX:Ontology .

QRX:image rdf:type owl:ObjectProperty ;
    rdfs:label "image" ;
    rdfs:domain QRX:Concept ;
    rdfs:isDefinedBy QRX:Ontology .
