@prefix schema: <http://schema.org/> .
@prefix iq: <urn:iq:>.
@prefix ai: <urn:ai:>.

## IQ is your operating environment for neuro-symbolic cognitive AI.

### Hierarchy of Needs ###

ai:HierarchyOfNeeds a schema:Concept.

ai:BasicNeeds a schema:Concept;
              iq:needs ai:Tokenomic;
              iq:needs ai:HierarchyOfNeeds.
ai:SecurityNeeds a schema:Concept;
                 iq:needs ai:Tokenomic;
                 iq:needs ai:HierarchyOfNeeds.
ai:SocialNeeds a schema:Concept;
               iq:needs ai:Tokenomic;
               iq:needs ai:HierarchyOfNeeds.
ai:EsteemNeeds a schema:Concept;
               iq:needs ai:Tokenomic;
               iq:needs ai:HierarchyOfNeeds.
ai:SelfActualizationNeeds a schema:Concept;
                          iq:needs ai:Tokenomic;
                          iq:needs ai:HierarchyOfNeeds.

ai:Capital a schema:Concept;
           iq:needs ai:Tokenomic.

ai:Currency a schema:Concept
        iq:needs ai:Tokenomic.

ai:CapitalOrCurrency a schema:Concept;
                     rdfs:subTypeOf ai:Currency, ai:Capital;
                     iq:needs ai:Tokenomic;
           iq:needs ai:BasicNeeds, ai:SecurityNeeds, ai:SocialNeeds, ai:EsteemNeeds, ai:SelfActualizationNeeds.
ai:Time a schema:Concept;
        iq:needs ai:Tokenomic;
        iq:needs ai:BasicNeeds, ai:SecurityNeeds, ai:SocialNeeds, ai:EsteemNeeds, ai:SelfActualizationNeeds.
ai:Attention a schema:Concept;
             iq:needs ai:Tokenomic;
             iq:needs ai:BasicNeeds, ai:SecurityNeeds, ai:SocialNeeds, ai:EsteemNeeds, ai:SelfActualizationNeeds.



### Wardley Maps ###

ai:WardleyMaps a schema:Concept.

ai:Landscape a schema:Concept;
             iq:needs ai:WardleyMaps.
ai:Doctrine a schema:Concept;
            iq:needs ai:WardleyMaps.
ai:Evolution a schema:Concept;
             iq:needs ai:WardleyMaps.
ai:ValueChain a schema:Concept;
              iq:needs ai:WardleyMaps.
ai:Components a schema:Concept;
              iq:needs ai:WardleyMaps.
ai:WardleyMap a schema:Concept;
              iq:needs ai:WardleyMaps.
ai:UserNeeds a schema:Concept;
             iq:needs ai:WardleyMaps.
ai:WardleyMapping a schema:Concept;
                  iq:needs ai:WardleyMaps.

### Concepts related to Capital and Tokenomics ###

ai:Tokenomic a schema:Concept.

ai:SocialCapital a schema:Concept;
                 iq:needs ai:Tokenomic.
ai:AttentionCapital a schema:Concept;
                    iq:needs ai:Tokenomic.
ai:CurrencyCapital a schema:Concept;
                   iq:needs ai:Tokenomic.
ai:CryptoCapital a schema:Concept;
                 iq:needs ai:Tokenomic.
ai:HumanCapital a schema:Concept;
                iq:needs ai:Tokenomic.
ai:NaturalCapital a schema:Concept;
                  iq:needs ai:Tokenomic.
ai:FinancialCapital a schema:Concept;
                    iq:needs ai:Tokenomic.

### Concepts related to Cognitive, Algorithmic, and Computational Capital ###

ai:CognitiveCapital a schema:Concept;
                    iq:needs ai:Tokenomic.
ai:AlgorithmicCapital a schema:Concept;
                      iq:needs ai:Tokenomic.
ai:ComputationalCapital a schema:Concept;
                        iq:needs ai:Tokenomic.
