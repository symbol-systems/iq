@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix : <https://smarttrust.ai/v0/my/yarns#>.

### Classes ###
### Narrative ###
:narrative rdf:type rdfs:Class ;
   rdfs:label "Narrative" ;
   rdfs:comment "Represents the entire narrative structure." .

### Character ###
:character rdf:type rdfs:Class ;
   rdfs:label "Character" ;
   rdfs:comment "Represents a character in the narrative." .

### Setting ###
:setting rdf:type rdfs:Class ;
 rdfs:label "Setting" ;
 rdfs:comment "Represents a setting in the narrative." .

### Plot ###
:plot rdf:type rdfs:Class ;
  rdfs:label "Plot" ;
  rdfs:comment "Represents the plot structure of the narrative." .

### Event ###
:event rdf:type rdfs:Class ;
   rdfs:label "Event" ;
   rdfs:comment "Represents an event in the plot." .

### Conflict ###
:conflict rdf:type rdfs:Class ;
  rdfs:label "Conflict" ;
  rdfs:comment "Represents a conflict in the plot." .

:hasGenre rdf:type rdf:Property ;
  rdfs:domain :narrative ;
  rdfs:range xsd:string ;
  rdfs:label "hasGenre" ;
  rdfs:comment "Indicates the genre of the narrative." .

:hasCharacter rdf:type rdf:Property ;
  rdfs:domain :narrative ;
  rdfs:range :character ;
  rdfs:label "hasCharacter" ;
  rdfs:comment "Indicates the characters present in the narrative." .

:hasSetting rdf:type rdf:Property ;
rdfs:domain :narrative ;
rdfs:range :setting ;
rdfs:label "hasSetting" ;
rdfs:comment "Indicates the setting(s) where the narrative takes place." .

:hasPlot rdf:type rdf:Property ;
 rdfs:domain :narrative ;
 rdfs:range :plot ;
 rdfs:label "hasPlot" ;
 rdfs:comment "Indicates the plot structure of the narrative." .

### Character Properties ###
:hasName rdf:type rdf:Property ;
 rdfs:domain :character ;
 rdfs:range xsd:string ;
 rdfs:label "hasName" ;
 rdfs:comment "Indicates the name of the character." .

:hasRole rdf:type rdf:Property ;
 rdfs:domain :character ;
 rdfs:range xsd:string ;
 rdfs:label "hasRole" ;
 rdfs:comment "Indicates the role of the character in the narrative." .

:hasDescription rdf:type rdf:Property ;
rdfs:domain :character ;
rdfs:range xsd:string ;
rdfs:label "hasDescription" ;
rdfs:comment "Provides a description of the character." .

:hasRelation rdf:type rdf:Property ;
 rdfs:domain :character ;
 rdfs:range :character ;
 rdfs:label "hasRelation" ;
 rdfs:comment "Indicates relationships between characters." .

### Setting Properties ###
:hasLocation rdf:type rdf:Property ;
 rdfs:domain :setting ;
 rdfs:range xsd:string ;
 rdfs:label "hasLocation" ;
 rdfs:comment "Indicates the location of the setting." .

:hasTimePeriod rdf:type rdf:Property ;
   rdfs:domain :setting ;
   rdfs:range xsd:string ;
   rdfs:label "hasTimePeriod" ;
   rdfs:comment "Indicates the time period of the setting." .

:hasDescription rdf:type rdf:Property ;
rdfs:domain :setting ;
rdfs:range xsd:string ;
rdfs:label "hasDescription" ;
rdfs:comment "Provides a description of the setting." .

### Plot Properties ###
:hasEvent rdf:type rdf:Property ;
  rdfs:domain :plot ;
  rdfs:range :event ;
  rdfs:label "hasEvent" ;
  rdfs:comment "Indicates the sequence of events in the plot." .

:hasConflict rdf:type rdf:Property ;
 rdfs:domain :plot ;
 rdfs:range :conflict ;
 rdfs:label "hasConflict" ;
 rdfs:comment "Indicates the conflicts present in the plot." .

:hasResolution rdf:type rdf:Property ;
   rdfs:domain :plot ;
   rdfs:range xsd:string ;
   rdfs:label "hasResolution" ;
   rdfs:comment "Indicates the resolution of the conflicts." .

### Event Properties ###
:hasDescription rdf:type rdf:Property ;
rdfs:domain :event ;
rdfs:range xsd:string ;
rdfs:label "hasDescription" ;
rdfs:comment "Provides a description of the event." .

:hasTime rdf:type rdf:Property ;
 rdfs:domain :event ;
 rdfs:range xsd:dateTime ;
 rdfs:label "hasTime" ;
 rdfs:comment "Indicates the time when the event occurs in the narrative." .

:hasLocation rdf:type rdf:Property ;
 rdfs:domain :event ;
 rdfs:range xsd:string ;
 rdfs:label "hasLocation" ;
 rdfs:comment "Indicates the location where the event occurs." .

:hasParticipant rdf:type rdf:Property ;
rdfs:domain :event ;
rdfs:range :character ;
rdfs:label "hasParticipant" ;
rdfs:comment "Indicates the characters involved in the event." .

### Conflict Properties ###
:hasType rdf:type rdf:Property ;
 rdfs:domain :conflict ;
 rdfs:range xsd:string ;
 rdfs:label "hasType" ;
 rdfs:comment "Indicates the type of conflict." .

:hasDescription rdf:type rdf:Property ;
rdfs:domain :conflict ;
rdfs:range xsd:string ;
rdfs:label "hasDescription" ;
rdfs:comment "Provides a description of the conflict." .

:hasResolution rdf:type rdf:Property ;
   rdfs:domain :conflict ;
   rdfs:range xsd:string ;
   rdfs:label "hasResolution" ;
   rdfs:comment "Indicates how the conflict is resolved." .
