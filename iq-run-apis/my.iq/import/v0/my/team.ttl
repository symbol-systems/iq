@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

@prefix my: <https://smarttrust.ai/v0/my#>.
@prefix self: <https://smarttrust.ai/v0/self#> .
@prefix iq: <urn:iq:>.

my:Self a skos:ConceptScheme.
my:CxO a skos:Concept.

my:Team a skos:Concept ;
    prov:wasDerivedFrom my:Self ;
    skos:broader my:Activity ;
    skos:inScheme my:Self ;
    skos:prefLabel "Team";
    skos:definition "A group of individuals collaborating towards goals or objectives." .

my:TeamMember a skos:Concept ;
    prov:wasDerivedFrom my:Self ;
    skos:broader my:Team ;
    skos:inScheme my:Self ;
    skos:prefLabel "Team Member" ;
    skos:definition "Individuals contributing to our goals and our community." .

my:TeamLead a skos:Concept ;
    prov:wasDerivedFrom my:Self ;
    skos:broader my:Team ;
    skos:inScheme my:Self ;
    skos:prefLabel "Team Lead" ;
    skos:definition "Responsible for leading and coordinating the activities of a specific team." .

my:Developer a skos:Concept ;
    prov:wasDerivedFrom my:Self ;
    skos:broader my:Activity ;
    skos:broader my:Team ;
    skos:inScheme my:Self ;
    skos:prefLabel "Developer" ;
    skos:definition "Responsible for designing, coding, and maintaining software 1.0." .

my:Designer a skos:Concept ;
    prov:wasDerivedFrom my:Self ;
    skos:inScheme my:Self ;
    skos:broader my:Activity ;
    skos:broader my:Team ;
    skos:prefLabel "Designer" ;
    skos:definition "Creates visual concepts to communicate ideas." .

my:DataScientist a skos:Concept ;
    prov:wasDerivedFrom my:Self ;
    skos:inScheme my:Self ;
    skos:broader my:Activity ;
    skos:broader my:Team ;
    skos:prefLabel "Data Scientist" ;
    skos:definition "Uses scientific methods, algorithms, and systems to extract knowledge." .

my:KnowledgeEnginer a skos:Concept ;
    prov:wasDerivedFrom my:Self ;
    skos:inScheme my:Self ;
    skos:broader my:Activity ;
    skos:broader my:Team ;
    skos:prefLabel "Knowledge Engineer" ;
    skos:definition "Uses ontologies and taxonomies to organize data and facts into knowledge." .

my:CommunityManager a skos:Concept ;
    prov:wasDerivedFrom my:Self ;
    skos:inScheme my:Self ;
    skos:broader my:Activity ;
    skos:broader my:Team ;
    skos:prefLabel "Community Manager" ;
    skos:definition "Engages with and manages the community members, addressing their concerns." .

my:Finance a skos:Concept ;
    prov:wasDerivedFrom my:Self ;
    skos:inScheme my:Self ;
    skos:broader my:Activity ;
    skos:broader my:Team ;
    skos:prefLabel "Finance" ;
    skos:definition "Financial planning, reporting, and analysis." .

my:Marketing a skos:Concept ;
    prov:wasDerivedFrom my:Self ;
    skos:inScheme my:Self ;
    skos:broader my:Activity ;
    skos:broader my:Team ;
    skos:prefLabel "Marketing" ;
    skos:definition "Responsible for brand visibility." .

my:LegalCounsel a skos:Concept ;
    prov:wasDerivedFrom my:Self ;
    skos:broader my:Activity ;
    skos:broader my:Team ;
    skos:inScheme my:Self ;
    skos:prefLabel "Legal Counsel" ;
    skos:definition "Provides legal guidance and ensures compliance with relevant regulations and laws." .

my:CustomerSuccess a skos:Concept ;
    prov:wasDerivedFrom my:Self ;
    skos:broader my:Team ;
    skos:inScheme my:Self ;
    skos:broader my:Activity ;
    skos:prefLabel "Customer Success" ;
    skos:definition "Helping customers to realize valuable outcomes." .

my:CFO a skos:Concept ;
    prov:wasDerivedFrom my:Self ;
    skos:inScheme my:Self ;
    skos:broader my:Team ;
    skos:broader my:CxO ;
    skos:prefLabel "CFO" ;
    skos:altLabel  "Chief Financial Officer" ;
    skos:definition "Responsible for managing the financial actions of the organization." .

my:CTO a skos:Concept ;
    prov:wasDerivedFrom my:Self ;
    skos:inScheme my:Self ;
    skos:broader my:Team ;
    skos:broader my:CxO ;
    skos:prefLabel "CTO" ;
    skos:altLabel "Chief Technology Officer" ;
    skos:definition "Responsible for overseeing the technological direction of the organization." .

my:CIO a skos:Concept ;
    prov:wasDerivedFrom my:Self ;
    skos:inScheme my:Self ;
    skos:broader my:CxO ;
    skos:broader my:Team ;
    skos:prefLabel "CIO" ;
    skos:altLabel "Chief Information Officer" ;
    skos:definition "Responsible for the management, implementation, and usability of information." .

my:CISO a skos:Concept ;
    prov:wasDerivedFrom my:Self ;
    skos:broader my:Team ;
    skos:broader my:CxO ;
    skos:inScheme my:Self ;
    skos:prefLabel "CISO" ;
    skos:altLabel "Chief Information Security Officer" ;
    skos:definition "Responsible for protecting information assets and technologies." .

my:CKO a skos:Concept ;
    prov:wasDerivedFrom my:Self ;
    skos:broader my:Team ;
    skos:inScheme my:Self ;
    skos:broader my:CxO ;
    skos:prefLabel "CKO" ;
    skos:altLabel "Chief Knowledge Officer" ;
    skos:definition "Responsible for researching facts and curating knowledge." .

my:Activity a skos:Concept ;
    prov:wasDerivedFrom my:Self ;
    skos:inScheme my:Self ;
    skos:prefLabel "Activity" ;
    skos:definition "Carrying out specific tasks or duties." .

my:ActivityMonitoring a skos:Concept ;
    prov:wasDerivedFrom my:Self ;
    skos:inScheme my:Self ;
    skos:prefLabel "Activity Monitoring" ;
    skos:definition "Observation and assessment of tasks to ensure they are completed." .

my:ActivityReporting a skos:Concept ;
    prov:wasDerivedFrom my:Self ;
    skos:inScheme my:Self ;
    skos:prefLabel "Activity Reporting" ;
    skos:definition "Documentation and communication of activities, progress, and results." .

my:ActivityOptimization a skos:Concept ;
    prov:wasDerivedFrom my:Self ;
    skos:inScheme my:Self ;
    skos:prefLabel "Activity Optimization" ;
    skos:definition "Improving and refining tasks and processes to enhance performance and efficiency." .

