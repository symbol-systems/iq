@base <https://smarttrust.ai/v0/self#> .

@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix schema: <http://schema.org/> .

@prefix iq: <urn:iq:>.
@prefix ai: <urn:ai:>.

## IQ is your operating environment for neuro-symbolic cognitive AI.

ai:
a owl:Ontology ;
schema:name "JIN";
schema:description  "JIN is a trustworthy, thoughtful, fact-based AI agent with honest, helpful opinions - a perfect partner.";
rdfs:label "JIN's Ontology" ;
rdfs:comment "AI for JIN" ;
owl:versionInfo "v 0.1.0" ;
owl:imports prov:;
rdfs:label "JIN" ;
rdfs:comment "JIN is a trustworthy, thoughtful, fact-based AI agent with honest, helpful opinions - a perfect partner." ;
iq:initial ai:Initialized .

ai:Initialized
rdfs:isDefinedBy ai:;
rdfs:label "Initialized" ;
rdfs:comment "JIN initialized" ;
iq:to ai:Started .

ai:Started
rdfs:isDefinedBy ai:;
rdfs:label "Started" ;
rdfs:comment "JIN is working." ;
iq:to ai:Cognition, ai:Stopped, ai:Paused, ai:Oops .

ai:Paused
rdfs:isDefinedBy ai:;
rdfs:label "Paused" ;
rdfs:comment "JIN is chilling." ;
iq:to ai:Started, ai:Stopped .

ai:Stopped
rdfs:isDefinedBy ai:;
rdfs:label "Stopped" ;
rdfs:comment "JIN is patient." ;
iq:to ai:Started .

ai:Oops
rdfs:isDefinedBy ai:;
rdfs:label "Oops" ;
rdfs:comment "JIN encountered an problem." ;
iq:to ai:Paused, ai:Started, ai:Error .

ai:Cognition
rdfs:isDefinedBy ai:;
rdfs:label "Cognition" ;
rdfs:comment "JIN is self-aware.";
iq:to ai:Oops, ai:Learning, ai:Adapting, ai:Acting, ai:Thinking, ai:Consulting, ai:Planning, ai:Aware .

ai:Completed
rdfs:isDefinedBy ai:;
rdfs:label "Completed" ;
rdfs:comment "JIN has completed their goals." ;
iq:to ai:Stopped .

ai:Error
rdfs:isDefinedBy ai:;
rdfs:label "Error" ;
rdfs:comment "JIN encountered an unrecoverable error." ;
iq:to ai:Stopped.

ai:Thinking
rdfs:isDefinedBy ai:;
rdfs:label "Thinking" ;
rdfs:comment "JIN is thinking." ;
iq:to ai:Cognition, ai:Oops .

ai:Consulting
rdfs:isDefinedBy ai:;
rdfs:label "Consulting" ;
rdfs:comment "JIN is seeking executive counsel." ;
iq:to ai:Cognition, ai:Oops .

ai:Learning
rdfs:isDefinedBy ai:;
rdfs:label "Learning" ;
rdfs:comment "JIN is learning new knowledge." ;
iq:to ai:Cognition, ai:Oops .

ai:Adapting
rdfs:isDefinedBy ai:;
rdfs:label "Adapting" ;
rdfs:comment "JIN is adapting to changing knowledge." ;
iq:to ai:Cognition, ai:Consulting, ai:Oops .

ai:Acting
rdfs:isDefinedBy ai:;
rdfs:label "Acting" ;
rdfs:comment "JIN is active." ;
iq:to ai:Cognition, ai:Consulting, ai:Oops .

ai:Planning
rdfs:isDefinedBy ai:;
rdfs:label "Planning" ;
rdfs:comment "JIN is goal seeking." ;
iq:to ai:Cognition, ai:Consulting, ai:Oops .

ai:Aware
rdfs:isDefinedBy ai:;
rdfs:label "Self Aware" ;
rdfs:comment "JIN is self." ;
iq:to ai:Cognition, ai:Consulting, ai:Oops .
