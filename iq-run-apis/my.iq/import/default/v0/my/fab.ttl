@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

@prefix my: <https://smarttrust.ai/v0/my#>.
@prefix self: <https://smarttrust.ai/v0/self#> .
@prefix iq: <urn:iq:>.

my:Self a skos:ConceptScheme.

my:Value a skos:Concept ;
skos:inScheme my:Self ;
prov:wasDerivedFrom my:Self ;
skos:broader my:Capability;
skos:prefLabel "Value" ;
skos:definition "Importance in terms of benefits or usefulness." .

my:ImprovedEfficiency a skos:Concept ;
skos:inScheme my:Self ;
prov:wasDerivedFrom my:Self ;
skos:broader my:Value;
skos:prefLabel "Improved Efficiency" .

my:EnhancedInsights a skos:Concept ;
skos:inScheme my:Self ;
prov:wasDerivedFrom my:Self ;
skos:broader my:Value;
skos:prefLabel "Enhanced Insights" .

my:PersonalizedInteractions a skos:Concept ;
skos:inScheme my:Self ;
prov:wasDerivedFrom my:Self ;
skos:broader my:Value;
skos:prefLabel "Personalized Interactions" .

my:ContinuousLearning a skos:Concept ;
skos:inScheme my:Self ;
prov:wasDerivedFrom my:Self ;
skos:broader my:Value;
skos:prefLabel "Continuous Learning" .

my:Adaptability a skos:Concept ;
skos:inScheme my:Self ;
prov:wasDerivedFrom my:Self ;
skos:broader my:Value;
skos:prefLabel "Adaptability" .

my:Innovation a skos:Concept ;
skos:inScheme my:Self ;
prov:wasDerivedFrom my:Self ;
skos:broader my:Value;
skos:prefLabel "Innovation" .
