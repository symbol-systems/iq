"""^^<urn:application/x-sparql-query> .

<QRX:ux/trusts> rdf:value """PREFIX iq: <iq:>

CONSTRUCT {
    ?s iq:trusts ?t .
    ?t ?p ?o.
}
WHERE {
    {
        ?s iq:trusts ?t .
        ?t ?p ?o.
    }
    UNION
    {
        ?this iq:trusts ?s .
        ?s iq:trusts+ ?t .
        ?t ?p ?o.
    }
}
"""^^<urn:application/x-sparql-query> .

<QRX:ux/agent/intents> rdf:value """SELECT ?id ?label ?comment
