QRX:index a <http://www.w3.org/ns/formats/Turtle>;
  rdf:value """SELECT DISTINCT ?this ?label WHERE {
    ?this rdf:value ?label
}"""^^<urn:application/x-sparql-query> .

QRX:Ontology a owl:Ontology;
  rdfs:label "QRX ";
  rdfs:comment "An AI mind game." .

QRX:Concept a owl:Class;
  rdfs:label "Concept";
  rdfs:comment "A concept or entity related to QRX.";
  rdfs:isDefinedBy QRX:Ontology .

iq:Agent a owl:Class;
  rdfs:label "Agent";
  rdfs:comment "An intelligent agent.";
  rdfs:isDefinedBy <iq:> .

iq:Intent a owl:Class;
  rdfs:label "Intent";
  rdfs:comment "Request for a state transition.";
  rdfs:isDefinedBy <iq:> .

iq:Guard a owl:Class;
  rdfs:label "Guard";
  rdfs:comment "A condition or constraint upon a state.";
  rdfs:isDefinedBy <iq:> .

iq:State a owl:Class;
  rdfs:label "State";
  rdfs:comment "The state of an agent.";
  rdfs:isDefinedBy <iq:> .

iq:Template a owl:Class;
  rdfs:label "Template";
  rdfs:comment "A structured template for a semantic transformation.";
  rdfs:isDefinedBy <iq:> .

iq:current a owl:ObjectProperty, rdf:Property;
  rdfs:label "current state";
  rdfs:comment "The current state of the activity.";
  rdfs:isDefinedBy <iq:>;
  rdfs:domain iq:Agent;
  rdfs:range iq:State .

iq:guards a owl:ObjectProperty, rdf:Property;
  rdfs:label "guards";
  rdfs:comment "A guard mediates a state transition.";
  rdfs:isDefinedBy <iq:>;
  rdfs:domain iq:Guard;
  rdfs:range iq:State .

