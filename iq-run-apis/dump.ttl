discord:authorize rdf:value """PREFIX twilio: <QRX:twilio:>
PREFIX iq: <iq:>
PREFIX my: <QRX:>

INSERT {
    <{{my.issuer}}> iq:trusts ?self.
    ?self
        a my:Self;
        iq:trusts my:;
        iq:initial my:Hello;
        iq:name \"{{my.twilio.global_name}}\" ;
        my:label \"{{my.twilio.global_name}}\" ;
        my:image \"{{my.twilio.avatar}}\";
        rdf:value \"\"\"{
    \"twilio:username\": \"{{my.twilio.username}}\",
    \"twilio:avatar\": \"{{my.twilio.avatar}}\",
    \"twilio:discriminator\": \"{{my.twilio.discriminator}}\",
    \"twilio:public_flags\": \"{{my.twilio.public_flags}}\",
    \"twilio:flags\": \"{{my.twilio.flags}}\",
    \"twilio:banner\": \"{{my.twilio.banner}}\",
    \"twilio:accent_color\": \"{{my.twilio.accent_color}}\",
    \"twilio:global_name\": \"{{my.twilio.global_name}}\",
    \"twilio:avatar_decoration_data\": \"{{my.twilio.avatar_decoration_data}}\",
    \"twilio:banner_color\": \"{{my.twilio.banner_color}}\",
    \"twilio:clan\": \"{{my.twilio.clan}}\",
    \"twilio:mfa_enabled\": \"{{my.twilio.mfa_enabled}}\",
    \"twilio:locale\": \"{{my.twilio.locale}}\",
    \"twilio:premium_type\": \"{{my.twilio.premium_type}}\"
}\"\"\"^^rdf:JSON.
}
WHERE {
    BIND(<{{my.identity}}> AS ?self)
}
"""^^<urn:application/x-sparql-query>;
  iq:to discord:identify;
  iq:update discord:authorize .

discord:discord rdf:value """import jakarta.ws.rs.core.Response
import systems.symbol.agent.IQFacade
import systems.symbol.controller.responses.OopsException

import javax.script.Bindings

iq = (IQFacade)iq;
my = (Bindings)my;

assert my.provider == \"twilio\"

// println(\"twilio.authorize: ${my}\")

def api = iq.api(\"https://discord.com/api/v10/oauth2/token\")
api.header('Content-Type', 'application/x-www-form-urlencoded')
api.basic()

def payload = [ 'grant_type': 'authorization_code', 'code': my.code, 'redirect_uri': my.host+\"auth/twilio\" ]
println(\"twilio.payload: ${payload}\")

def r = api.post(payload)
def auth = iq.json(r)
my.error = auth.error
println(\"twilio.response: ${auth}\")

if (!auth || my.error) throw new OopsException(\"twilio.oauth.error\", Response.Status.FORBIDDEN)

if (auth.access_token) {
    def discord_api = iq.api(\"https://discord.com/api/v10/users/@me\")
    discord_api.bearer(\"\"+auth.access_token)
    def discord_reply = discord_api.get()
    my.twilio = iq.json(discord_reply)
    my.name = my.twilio.global_name
    my.identity = \"${my.issuer}${my.twilio.id}\"
    println(\"twilio.identity: ${my.identity}\")
}
"""^^<urn:application/x-groovy> .

