#!/usr/bin/env bash
set -euo pipefail
ROOT="$(cd "$(dirname "$0")/.." && pwd)"
cd "$ROOT"

JAR_PATH="$(ls -1 ~/.m2/repository/systems/symbol/iq-cli-pro/*/iq-cli-pro-*-shaded.jar 2>/dev/null | tail -n1 || true)"
[[ -z "$JAR_PATH" ]] && JAR_PATH="$(ls -1 iq-cli-pro/target/iq-cli-pro-*-shaded.jar 2>/dev/null | head -n1 || true)"
[[ -z "$JAR_PATH" ]] && JAR_PATH="$(ls -1 iq-cli-pro/target/iq-cli-pro.jar 2>/dev/null | head -n1 || true)"

if [[ -z "$JAR_PATH" ]]; then
  echo "Error: jar not found. Run: ./bin/install-cli-pro" >&2
  exit 1
fi

java -jar "$JAR_PATH" "$@" || {
  echo "[WARN] jar exec failed; retrying with maven..." >&2
  ./mvnw compile exec:java -pl iq-cli-pro -am -Dexec.mainClass=systems.symbol.PowerCLI -DskipTests "$@"
}
