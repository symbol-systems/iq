#!/usr/bin/env bash
# Run IQ CLI Pro (systems.symbol.PowerCLI)
set -euo pipefail
ROOT="$(cd "$(dirname "$0")/.." && pwd)"
cd "$ROOT"

JAR=$(find iq-cli-pro/target -name "iq-cli-pro-*-shaded.jar" -o -name "iq-cli-pro.jar" | head -n1 || true)

if [[ -z "$JAR" ]]; then
  echo "[INFO] Building iq-cli-pro..." >&2
  ./mvnw -pl iq-cli-pro -am package -DskipTests >/dev/null 2>&1 || {
    echo "[ERROR] Build failed" >&2
    exit 1
  }
  JAR=$(find iq-cli-pro/target -name "iq-cli-pro-*-shaded.jar" -o -name "iq-cli-pro.jar" | head -n1 || true)
fi

if [[ -z "$JAR" ]]; then
  echo "[ERROR] JAR not found, falling back to maven" >&2
  exec ./mvnw compile exec:java -pl iq-cli-pro -am \
    -Dexec.mainClass=systems.symbol.PowerCLI \
    -DskipTests \
    "$@"
fi

# Verify main class
MAIN=$(unzip -p "$JAR" META-INF/MANIFEST.MF 2>/dev/null | grep -i '^Main-Class:' | awk '{print $2}' | tr -d '\r' || true)
if [[ "$MAIN" == systems.symbol.PowerCLI ]]; then
  echo "[INFO] Running: $(basename "$JAR")" >&2
  exec java -jar "$JAR" "$@"
else
  echo "[WARN] Main-Class mismatch, falling back to maven" >&2
  exec ./mvnw compile exec:java -pl iq-cli-pro -am \
    -Dexec.mainClass=systems.symbol.PowerCLI \
    -DskipTests \
    "$@"
fi
