#!/usr/bin/env bash
# Run IQ AI/Trusted Module
set -euo pipefail
ROOT="$(cd "$(dirname "$0")/.." && pwd)"
cd "$ROOT"

JAR=$(find iq-trusted/target/quarkus-app -name "quarkus-run.jar" | head -n1 || true)

if [[ -z "$JAR" ]]; then
  echo "[INFO] Building iq-trusted..." >&2
  ./mvnw -pl iq-trusted -am package -DskipTests >/dev/null 2>&1 || {
    echo "[ERROR] Build failed" >&2
    exit 1
  }
  JAR=$(find iq-trusted/target/quarkus-app -name "quarkus-run.jar" | head -n1 || true)
fi

if [[ -z "$JAR" ]]; then
  echo "[ERROR] JAR not found, falling back to maven" >&2
  exec ./mvnw compile exec:java -pl iq-trusted -am \
    -Dexec.mainClass=systems.symbol.MY_IQ_AI \
    -DskipTests \
    "$@"
else
  echo "[INFO] Running: $(basename "$JAR")" >&2
  exec java -jar "$JAR" "$@"
fi
