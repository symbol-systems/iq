#!/usr/bin/env bash
# Install iq-cli-pro to $HOME/bin/ for system-wide access
set -euo pipefail
ROOT="$(cd "$(dirname "$0")/.." && pwd)"
cd "$ROOT"

echo "[INFO] Building iq-cli-pro..."
./mvnw clean package -Dmaven.test.skip=true -pl iq-cli-pro -am

# Find the built JAR
JAR=$(find "$ROOT/iq-cli-pro/target" -name "iq-cli-pro-*.jar" -not -name "*original*" | head -n1)
if [[ -z "$JAR" ]]; then
  echo "ERROR: iq-cli-pro jar not found in $ROOT/iq-cli-pro/target/" >&2
  exit 1
fi

# Install to $HOME/bin
mkdir -p "$HOME/bin"
echo "[INFO] Installing to $HOME/bin/"
cp "$JAR" "$HOME/bin/iq-cli-pro"

# Create wrapper script
cat > "$HOME/bin/iq-pro" <<'WRAPPER'
#!/usr/bin/env bash
exec java -jar "$HOME/bin/iq-cli-pro" "$@"
WRAPPER

chmod +x "$HOME/bin/iq-pro"
echo "✓ Installed: $HOME/bin/iq-pro"


