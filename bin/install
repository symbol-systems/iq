#!/usr/bin/env bash
set -euo pipefail
ROOT="$(cd "$(dirname "$0")/.." && pwd)"
cd "$ROOT"
./mvnw clean package install -Dmaven.test.skip=true -amd
JAR=$(ls "$ROOT/iq-cli-pro/target/iq-cli-pro-"*.jar 2>/dev/null | head -n1)
if [ -z "$JAR" ]; then
  echo "ERROR: iq-cli-pro jar not found in target directory" >&2
  exit 1
fi
mkdir -p "$HOME/bin"
cp "$JAR" "$HOME/bin/"
EXE="$HOME/bin/iq"
cat > "$EXE" <<'EOF'
#!/usr/bin/env bash
exec java -jar "$HOME/bin/$(basename "$JAR")" "$@"
EOF
chmod +x "$EXE"
echo "Installed CLI wrapper at $EXE"


