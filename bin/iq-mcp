#!/usr/bin/env bash
set -euo pipefail
ROOT="$(cd "$(dirname "$0")/.." && pwd)"
cd "$ROOT"

# Build iq-mcp with all dependencies
echo "[INFO] Building iq-mcp with dependencies..."
./mvnw -pl iq-mcp -am compile -DskipTests

# Run the MCP server using exec:java from the iq-mcp module directly
./mvnw -pl iq-mcp exec:java -Dexec.mainClass=systems.symbol.MCPServerMain -Dexec.classpathScope=compile -DskipTests "$@"
