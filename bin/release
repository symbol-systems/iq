#!/usr/bin/env bash
# Release helper: commit, tag, and push to origin
# Usage: ./bin/release [commit-message]
# If no message provided, uses version from pom.xml

set -euo pipefail

MSG="${1:-}"

# Auto-detect version from pom.xml
if [[ -z "$MSG" ]]; then
    if grep -q '<version>' pom.xml; then
        MSG=$(grep -oPm1 "(?<=<version>)[^<]+" pom.xml || true)
    fi
    if [[ -z "$MSG" ]] && grep -q '<parent>' pom.xml; then
        MSG=$(grep -oPm1 "(?<=<parent>.*<version>)[^<]+" pom.xml || true)
    fi
fi

if [[ -z "$MSG" ]]; then
    echo "ERROR: Commit message or pom version required" >&2
    echo "Usage: $0 <message>" >&2
    exit 1
fi

echo "[Release] Preparing: $MSG"

# Stage all changes
git add -A

# Commit only if there are staged changes
if git diff --cached --quiet; then
    echo "[INFO] No changes to commit"
else
    echo "[INFO] Committing: $MSG"
    git commit -m "$MSG"
fi

# Create tag
echo "[INFO] Creating tag: $MSG"
git tag -a "$MSG" -m "Release: $MSG" || {
    echo "[WARN] Tag already exists, skipping"
}

# Push to origin with tags
echo "[INFO] Pushing to origin..."
git push origin main --tags || {
    echo "ERROR: Push failed" >&2
    exit 1
}

echo "✓ Release complete: $MSG"
git push --tags

