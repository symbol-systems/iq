#!/usr/bin/env bash
# Run IQ CLI Server (unified command framework)
set -euo pipefail
ROOT="$(cd "$(dirname "$0")/.." && pwd)"
cd "$ROOT"

JAR=$(find iq-cli-server/target -name "iq-cli-server-*.jar" -not -name "*original*" | head -n1 || true)

if [[ -z "$JAR" ]]; then
  echo "[INFO] Building iq-cli-server..." >&2
  ./mvnw -pl iq-cli-server -am package -DskipTests >/dev/null 2>&1 || {
    echo "[ERROR] Build failed" >&2
    exit 1
  }
  JAR=$(find iq-cli-server/target -name "iq-cli-server-*.jar" -not -name "*original*" | head -n1)
fi

if [[ -z "$JAR" ]]; then
  echo "[ERROR] JAR not found after build" >&2
  exit 1
fi

echo "[INFO] Running: $(basename "$JAR")" >&2
JAVA_OPTS="${JAVA_OPTS:-} -Djava.util.logging.manager=org.jboss.logmanager.LogManager"
exec java ${JAVA_OPTS} -jar "$JAR" "${@:-server mcp start}"
