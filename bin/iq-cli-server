#!/usr/bin/env bash
set -euo pipefail
ROOT="$(cd "$(dirname "$0")/.." && pwd)"
cd "$ROOT"

JAR_PATH="$(ls -1 ~/.m2/repository/systems/symbol/iq-cli-server/*/iq-cli-server-*.jar 2>/dev/null | grep -v original | tail -n1 || true)"
[[ -z "$JAR_PATH" ]] && JAR_PATH="$(ls -1 iq-cli-server/target/iq-cli-server-*.jar 2>/dev/null | grep -v original | head -n1 || true)"

if [[ -z "$JAR_PATH" ]]; then
  echo "Error: jar not found. Run: ./bin/install-cli-server" >&2
  exit 1
fi

[[ $# -eq 0 ]] && set -- server mcp start
JAVA_OPTS="${JAVA_OPTS:-} -Djava.util.logging.manager=org.jboss.logmanager.LogManager"
java $JAVA_OPTS -jar "$JAR_PATH" "$@"
