@prefix : <urn:iq:test:>.

# Canonical Ontology Definitions (e.g. W3C standards)

@prefix dcat: <http://www.w3.org/ns/dcat#> .
@prefix cnt: <http://www.w3.org/2011/content#>.
@prefix dct: <http://purl.org/dc/terms/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix tropes: <https://myiq.cloud/storystream/tropes#> .

:who
    rdfs:label  "who";
    rdfs:domain :Story;
    rdfs:range  :Character;
    skos:inScheme :Mystery;
    skos:inScheme :Drama;
    skos:inScheme :Romance;
.
:how
    rdfs:label  "how";
    rdfs:domain :Story;
    rdfs:range  :Fact;
    skos:inScheme :Mystery;
    skos:inScheme :Drama;
.
:what
    rdfs:label  "what";
    rdfs:domain :Story;
    rdfs:range  :Thing;
    skos:inScheme :Mystery;
    skos:inScheme :Drama;
.
:where
    rdfs:label  "what";
    rdfs:domain :Story;
    rdfs:range :Place;
    skos:inScheme :Mystery;
    skos:inScheme :Drama;
.
:why
    rdfs:label  "why";
    rdfs:domain :Story;
    rdfs:range :Motive;
    skos:inScheme :Mystery;
    skos:inScheme :Drama;
.
:when
    rdfs:label  "when";
    rdfs:domain :Story;
    rdfs:range :Event;
    skos:inScheme :Mystery;
    skos:inScheme :Drama;
.
