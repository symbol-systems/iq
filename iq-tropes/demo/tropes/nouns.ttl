    rdfs:isDefinedBy :;
    skos:prefLabel "Valuable Character"@en;
    skos:inScheme :Drama;
    skos:inScheme :Heist;
    skos:inScheme :Rescue;
    skos:inScheme :Mystery;
.
:ValuableThing
    rdfs:subClassOf :Valuable;
