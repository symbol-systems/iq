    skos:inScheme :Heist;
    skos:inScheme :Rescue;
    skos:inScheme :Mystery;
.
:MacGuffin
    rdfs:subClassOf :Thing;
    rdfs:subClassOf :Mystery;
    rdfs:subClassOf :Motive;
    rdfs:label "MacGuffin";
    skos:inScheme :Drama;
    skos:inScheme :Mystery;
    skos:inScheme :Heist;
    skos:inScheme :Rescue;
    skos:inScheme :Romance;
    skos:inScheme :Scene;
