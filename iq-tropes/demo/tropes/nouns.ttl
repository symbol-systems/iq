@prefix : <urn:iq:test:>.

# Canonical Ontology Definitions (e.g. W3C standards)

@prefix dcat: <http://www.w3.org/ns/dcat#> .
@prefix cnt: <http://www.w3.org/2011/content#>.
@prefix dct: <http://purl.org/dc/terms/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix tropes: <https://myiq.cloud/storystream/tropes#> .

:
  a owl:Ontology ;
  skos:prefLabel "Tropes";
  dcterms:contributor [
      a foaf:Person ;
      foaf:name "Gnomad" ;
    ] ;
.
:Trope
    rdfs:isDefinedBy :;
    skos:prefLabel "Trope";
    skos:description "A plot trick, a setup, a narrative structure or character type"@en;
.
:Scene
    rdfs:isDefinedBy :;
    rdfs:subClassOf :Event;
    rdfs:isDefinedBy :;
    skos:prefLabel "Scene"@en;
    skos:inScheme :Plot;
.
:Story
    rdfs:isDefinedBy :;
    rdfs:isDefinedBy :;
    skos:prefLabel "Story"@en;
.
:Plot
    rdfs:isDefinedBy :;
    skos:prefLabel "Plot"@en;
    rdfs:subClassOf :Trope;
    rdfs:subClassOf :Motive;
.
:Event
    rdfs:isDefinedBy :;
    rdfs:subClassOf :Fact;
    skos:prefLabel "Event"@en;
.
:Motive
    rdfs:isDefinedBy :;
    rdfs:subClassOf :PlotDriver;
    skos:prefLabel "Motive"@en;
.
:Place
    rdfs:isDefinedBy :;
    rdfs:subClassOf :Fact;
    skos:prefLabel "Place"@en;
.
:Luck
    rdfs:isDefinedBy :;
    skos:prefLabel "Luck"@en;
.
:GoodLuck
    rdfs:isDefinedBy :;
    rdfs:subClassOf :Luck;
    skos:prefLabel "Good Luck"@en;
.
:BadLuck
    rdfs:isDefinedBy :;
    rdfs:subClassOf :Luck;
    skos:prefLabel "Bad Luck"@en;
.
:Character
    rdfs:isDefinedBy :;
    skos:prefLabel "Character"@en;
.
:Role
    rdfs:isDefinedBy :;
    rdfs:subClassOf :Character;
    skos:prefLabel "Role"@en;
.
:Protagonist
    rdfs:isDefinedBy :;
    rdfs:subClassOf :Role;
    skos:prefLabel "Protagonist"@en;
.
:Antagonist
    rdfs:isDefinedBy :;
    rdfs:subClassOf :Role;
    skos:prefLabel "Antagonist"@en;
.
:Extra
    rdfs:isDefinedBy :;
    rdfs:subClassOf :Role;
    skos:prefLabel "Extra"@en;
.
:Sidekick
    rdfs:isDefinedBy :;
    rdfs:subClassOf :Role;
    skos:prefLabel "Sidekick"@en;
.
:Finale
    rdfs:isDefinedBy :;
    rdfs:subClassOf :Scene;
    skos:prefLabel "Finale"@en;
.
:Conflict
    rdfs:isDefinedBy :;
    rdfs:subClassOf :Motive;
    skos:prefLabel "Conflict"@en;
.
:Resolution
    rdfs:isDefinedBy :;
    rdfs:subClassOf :Motive;
    skos:prefLabel "Resolution"@en;
.
:What
    rdfs:isDefinedBy :;
    rdfs:subClassOf :Thing;
    rdfs:isDefinedBy :;
    skos:prefLabel "What"@en;
    skos:inScheme :Scene;
    rdfs:isDefinedBy :;
.
:How
    rdfs:isDefinedBy :;
    rdfs:subClassOf :Event;
    rdfs:isDefinedBy :;
    skos:prefLabel "How"@en;
    skos:inScheme :Scene;
    rdfs:isDefinedBy :;
.
:Where
    rdfs:isDefinedBy :;
    rdfs:subClassOf :Place;
    rdfs:isDefinedBy :;
    skos:prefLabel "Where"@en;
    skos:inScheme :Scene;
.
:Who
    rdfs:isDefinedBy :;
    rdfs:subClassOf :Character;
    rdfs:isDefinedBy :;
    skos:prefLabel "Who"@en;
    skos:inScheme :Scene;
.
:When
    rdfs:isDefinedBy :;
    rdfs:subClassOf :Event;
    rdfs:isDefinedBy :;
    skos:prefLabel "When"@en;
    skos:inScheme :Scene;
.
:Why
    rdfs:isDefinedBy :;
    rdfs:subClassOf :Motive;
    rdfs:isDefinedBy :;
    skos:prefLabel "Why"@en;
    skos:inScheme :Scene;
.
:Fact
    rdfs:isDefinedBy :;
    skos:prefLabel "Fact"@en;
.
:Clue
    rdfs:subClassOf :Fact;
    rdfs:isDefinedBy :;
    skos:prefLabel "Clue"@en;
    skos:inScheme :Mystery;
.
:Secret
    rdfs:subClassOf :Motive;
    rdfs:isDefinedBy :;
    skos:prefLabel "Secret"@en;
    skos:inScheme :Mystery;
    skos:inScheme :Drama;
.
:Truth
    rdfs:subClassOf :Motive;
    rdfs:isDefinedBy :;
    skos:prefLabel "Truth"@en;
    skos:inScheme :Mystery;
    skos:inScheme :Drama;
.
:Lie
    rdfs:subClassOf :Motive;
    rdfs:isDefinedBy :;
    skos:prefLabel "Lie"@en;
    skos:inScheme :Mystery;
    skos:inScheme :Drama;
.
:Thing
    rdfs:subClassOf :What;
    rdfs:isDefinedBy :;
    skos:prefLabel "Thing"@en;
.
:Fear
    rdfs:subClassOf :Motive;
    rdfs:isDefinedBy :;
    skos:prefLabel "Danger"@en;
    skos:inScheme :Drama;
.
:Valuable
    rdfs:subClassOf :Thing;
    rdfs:subClassOf :Motive;
    rdfs:isDefinedBy :;
    skos:prefLabel "Valuable"@en;
    skos:inScheme :Drama;
    skos:inScheme :Heist;
    skos:inScheme :Rescue;
    skos:inScheme :Mystery;
.
:ValuableCharacter
    rdfs:subClassOf :Valuable;
