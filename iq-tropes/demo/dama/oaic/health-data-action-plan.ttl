@prefix oaic: <https://www.oaic.gov.au/privacy/australian-privacy-principles-guidelines/>.


# Model Definitions
:
    a skos:ConceptScheme;
    a frames:ActionPlan;
    dct:title "Privacy Action Plan for Healthcare Providers"@en;
    skos:hasTopConcept IQ: Example;
    rdfs:seeAlso <https://www.oaic.gov.au/assets/privacy/guidance-and-advice/privacy-action-plan-for-your-health-practice-poster.pdf>
.
:ACTIONS
    a skos:ConceptScheme;
    a frames:ActionPlan;
    dct:title "Privacy Action for Healthcare Providers"@en;
    skos:hasTopConcept IQ: Example;
.

:ACTION_1
    a frames:Action;
    skos:inScheme :ACTIONS;
    dct:title "Develop and implement a privacy management plan"@en;
    dct:description "The Privacy Act requires you to be proactive in establishing, implementing and maintaining privacy processes that ensure you comply with the Australian Privacy Principles (APPs)."@en;
    skos:related :STEP_1;
.
:ACTION_2
    a frames:Action;
    skos:inScheme :ACTIONS;
    dct:title "Develop clear lines of accountability for privacy management"@en;
    dct:description "2 Knowing whom in the practice has the expertise and responsibility for meeting privacy requirements helps all staff respond efficiently to any privacy issues and seek prompt guidance when they need it."@en;
    skos:related :STEP_2;
.
:ACTION_3
    a frames:Action;
    skos:inScheme :ACTIONS;
    dct:title "Create a documented record of the types of personal information you handle"@en;
    dct:description "Understanding your practice’s personal information holdings is an important foundation for effective privacy management and compliance."@en;
    skos:related :STEP_3;
.
:ACTION_4
    a frames:Action;
    skos:inScheme :ACTIONS;
    dct:title "Understand your privacy obligations and implement processes to meet them"@en;
    dct:description "It is important to understand your privacy obligations and how key APPs apply to and operate in a healthcare context. Develop and implement processes that facilitate your practice’s compliance with those obligations."@en;
    skos:related :STEP_4;
.
:ACTION_5
    a frames:Action;
    skos:inScheme :ACTIONS;
    dct:title "Hold staff training sessions on privacy obligations"@en;
    dct:description "Training staff on their privacy obligations and the importance of privacy will help to create a confident team that is able to handle personal information in a privacy-enhancing way."@en;
    skos:related :STEP_5;
.
:ACTION_6
    a frames:Action;
    skos:inScheme :ACTIONS;
    dct:title "Create a privacy policy"@en;
    dct:description "You must take reasonable steps to make the privacy policy available free of charge and in an appropriate format. This might include making the policy available on your website, or prominently displaying a copy of the policy (or instructions for how to obtain it) in your practice."@en;
    skos:related :STEP_6;
.
:ACTION_7
    a frames:Action;
    skos:inScheme :ACTIONS;
    dct:title "Protect the information you hold"@en;
    dct:description "The Privacy Act requires you to take reasonable steps to protect the personal information you hold from misuse, interference, loss, and from unauthorised access, modification or disclosure."@en;
    skos:related :STEP_7;
.
:ACTION_8
    a frames:Action;
    skos:inScheme :ACTIONS;
    dct:title "Develop a data breach response plan"@en;
    dct:description "A data breach response plan is a tool to help you manage a data breach. It is a framework setting out how you will manage and respond to a data breach, including the steps you will take and the roles of various staff members."@en;
    skos:related :STEP_8;
.

:STEPS
    a skos:ConceptScheme;
    a frames:ActionPlan;
    dct:title "Privacy Action Plan for Healthcare Providers"@en;
    skos:hasTopConcept IQ: Example;
.

:STEP_1
    a frames:Action;
    skos:inScheme :STEPS;
    dct:title "Step 1"@en;
    dct:description " Develop a STEP privacy 1 management plan"@en;
.
:STEP_2
    a frames:Action;
    skos:inScheme :STEPS;
    dct:title "Step 2"@en;
    dct:description ""@en;
.
:STEP_3
    a frames:Action;
    skos:inScheme :STEPS;
    dct:title "Step 3"@en;
    dct:description "Be accountable"@en;
.
:STEP_4
    a frames:Action;
    skos:inScheme :STEPS;
    dct:title "Step 4"@en;
    dct:description "Keep orderly records"@en;
.
:STEP_5
    a frames:Action;
    skos:inScheme :STEPS;
    dct:title "Step 5"@en;
    dct:description "understand obligations"@en;
.
:STEP_6
    a frames:Action;
    skos:inScheme :STEPS;
    dct:title "Step 6"@en;
    dct:description "train staff"@en;
.
:STEP_7
    a frames:Action;
    skos:inScheme :STEPS;
    dct:title "Step 7"@en;
    dct:description "protect personal information"@en;
.
:STEP_8
    a frames:Action;
    skos:inScheme :STEPS;
    dct:title "Step 8"@en;
    dct:description "plan for a data breach"@en;
.
