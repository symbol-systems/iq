# Model Definitions

:
    a skos:ConceptScheme;
    a frames:Framework;
    dct:title "Business Drivers"@en;
    skos:hasTopConcept gg:Example;
.

:mission
    dct:title "Mission Statement"@en;
    skos:inScheme :;
.
:generic
    dct:title "Business Drivers"@en;
    skos:inScheme :;
.

# Mission Statement

:customer_experience
    a dama:Principle;
    skos:inScheme :mission;
    dct:title "We need to become data-driven organisation in order to make intelligent decisions based on customer experience"@en;
.
:data_excellence
    a dama:Principle;
    skos:inScheme :mission;
    dct:title "We to develop and maintain data excellence so we can make the best-informed decisions possible."
.

# Generic Business Drivers

:privacy
    a dama:Principle;
    a dama:Outcome;
    skos:inScheme :generic;
    dct:title "Comply with relevant privacy regulations."
.
:sharing
    a dama:Principle;
    a dama:Outcome;
    skos:inScheme :generic;
    dct:title "Create a shared data eco-system."
.
:trust
    a dama:Principle;
    a dama:Outcome;
    skos:inScheme :generic;
    dct:title "Enhance business trust in data."@en;
.
:efficiency
    a dama:Principle;
    a dama:Outcome;
    skos:inScheme :generic;
    dct:title "Improve operational efficiency.";
.
:agility
    a dama:Principle;
    a dama:Outcome;
    skos:inScheme :generic;
    dct:title "Enhance business agility"@en;
.
:insights
    a dama:Principle;
    a dama:Outcome;
    skos:inScheme :generic;
    dct:title "Improve business insights and analytics"@en;
.
:quality
    a dama:Principle;
    a dama:Outcome;
    skos:inScheme :generic;
    dct:title "Improve data quality"@en;
.
:mdm
    a dama:Principle;
    a dama:Outcome;
    skos:inScheme :generic;
    dct:title "Improve master data management"@en;
.
:regulations
    a dama:Principle;
    a dama:Outcome;
    skos:inScheme :generic;
    dct:title "Comply with regulations"@en;
.


