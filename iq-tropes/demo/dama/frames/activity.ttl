# Model Definitions

dama:BusinessStrategyActivity
a dama:Activity;
dct:title "Establish clear and communicable business strategy"@en;
dct:description "A clearly articulated business strategy"@en;
.
frames:Business raci:responsible dama:BusinessStrategyActivity.

dama:BusinessPriorityActivity
a dama:Activity;
dct:title "Prioritze key business domains, goals and problems"@en;
.
frames:Business raci:responsible dama:BusinessPriorityActivity.

dama:BusinessOwnershipActivity
a dama:Activity;
dct:title "Own the data through data governance principles and practices"@en;
.
frames:Business raci:responsible dama:BusinessOwnershipActivity.

dama:BusinessMeasureActivity
a dama:Activity;
dct:title "Estimate the expected and and measure actual results of the strategy"@en;
.
frames:Business raci:responsible dama:BusinessMeasureActivity.

dama:BusinessChangeActivity
a dama:Activity;
dct:title "Effect the business, process and behavioural changes required to implement the strategy"@en;
.
frames:Business raci:responsible dama:BusinessChangeActivity.


# Technology Activities

dama:TechnologyStrategyActivity
a dama:Activity;
dct:title "Understand the business strategy and it's technical implications"@en;
.
frames:ICT raci:responsible dama:TechnologyStrategyActivity.

dama:TechnologyPriorityActivity
a dama:Activity;
dct:title "Evalute, select and procure appropriate technologies to support the data strategy"@en;
.
frames:ICT raci:responsible dama:TechnologyPriorityActivity.

dama:TechnologyOwnershipActivity
a dama:Activity;
dct:title "Understand and introduce data management best practices and methodologies"@en;
.
frames:ICT raci:responsible dama:TechnologyOwnershipActivity.

dama:TechnologyMeasureActivity
a dama:Activity;
dct:title "Monitor technology for innovations that enhance or support the data strategy"@en;
.
frames:ICT raci:responsible dama:TechnologyMeasureActivity.

dama:TechnologyChangeActivity
a dama:Activity;
dct:title "Proactively propose new technology that improves or enriches the business strategy"@en;
.
frames:ICT raci:responsible dama:TechnologyChangeActivity.



dama:JointStrategyActivity
a dama:Activity;
dct:title "Business and IT jointly forumate and execute the data strategy"@en;
.
frames:Business raci:responsible dama:JointStrategyActivity.
frames:ICT raci:responsible dama:JointStrategyActivity.

dama:JointPriorityActivity
a dama:Activity;
dct:title "Both Business and IT leadership play an active role to ensure success"@en;
.
frames:Business raci:responsible dama:JointPriorityActivity.
frames:ICT raci:responsible dama:JointPriorityActivity.

dama:JointOwnershipActivity
a dama:Activity;
dct:title "Exercise rapid and effecive change control"@en;
.
frames:Business raci:responsible dama:JointOwnershipActivity.
frames:ICT raci:responsible dama:JointOwnershipActivity.

dama:JointMeasureActivity
a dama:Activity;
dct:title "Monitor deliverables and instigate corrective action as required"@en;
.
frames:Business raci:responsible dama:JointMeasureActivity.
frames:ICT raci:responsible dama:JointMeasureActivity.

dama:JointChangeActivity
a dama:Activity;
dct:title "Regular dialogue between Business and IT to ensure strategic alignment"@en;
.
frames:Business raci:responsible dama:JointChangeActivity.
frames:ICT raci:responsible dama:JointChangeActivity.
