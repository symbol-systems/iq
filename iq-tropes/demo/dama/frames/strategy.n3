@prefix : <https://symbol.systems/v0/onto/demo/dama/frames/strategy#>.

# Canonical Ontology Definitions (e.g. W3C standards)

@prefix dbr:  <https://dbpedia.org/page/>.
@prefix dcat: <http://www.w3.org/ns/dcat#> .
@prefix cnt: <http://www.w3.org/2011/content#>.
@prefix dct: <http://purl.org/dc/terms/> .
@prefix dctype: <http://purl.org/dc/dcmitype/> .
@prefix foaf: <http://xmlns.com/foaf/0.1/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix sdo: <http://schema.org/> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix vcard: <http://www.w3.org/2006/vcard/ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

# Logical Ontology Definitions (experimental, private or proprietary)

@prefix raci: <https://symbol.systems/v0/onto/raci#>.
@prefix fact: <https://symbol.systems/v0/onto/fact#>.
@prefix frames: <https://symbol.systems/v0/onto/frames#>.
@prefix dama: <https://symbol.systems/v0/onto/dama#>.
@prefix fab: <https://symbol.systems/v0/onto/fab#>.
@prefix pmo: <https://symbol.systems/v0/onto/pmo#>.
@prefix IQ:  <https://symbol.systems/v0/onto/gg#>.
@prefix iq-test: <https://test.symbol.systems/cases#>.

# Model Definitions

:Principle
skos:inScheme frames:Classification;
skos:inScheme fact:Question;
skos:inScheme frames:What;
dct:title "Principle"@en;
dct:description "What are the beliefs and values that will guide the Government to achieve its vision?"@en;
.
:Strategy
skos:inScheme frames:Classification;
skos:inScheme fact:Question;
skos:inScheme frames:What;
dct:title "Strategy"@en;
dct:description "What general direction needs to be taken?"@en;
.
:BusinessStrategy
rdfs:subClassOf dama:Strategy;
dct:title "Business Strategy"@en;
.
:DataStrategy
rdfs:subClassOf dama:Strategy;
dct:title "Data Strategy"@en;
.
:DataStrategy dama:informs dama:BusinessStrategy.
:BusinessStrategy dama:guides dama:DataStrategy.
:InfoStandards
skos:inScheme frames:Classification;
skos:inScheme fact:Question;
skos:inScheme frames:What;
dct:title "Information Standards"@en;
dct:description "What are the specific directions, constraints and requirements which will achieve the Government’s strategies?"@en;
.
frames:Outcome
skos:inScheme frames:Classification;
skos:inScheme fact:Question;
skos:inScheme frames:What;
dct:title "Outcome"@en;
dct:description "What targets must be met to realise the stated policy outcomes?"@en;
.
:Tools
skos:inScheme frames:Classification;
skos:inScheme fact:Question;
skos:inScheme frames:What;
dct:title "Tools"@en;
dct:description "How are the targets and policies to be met?"@en;
.
