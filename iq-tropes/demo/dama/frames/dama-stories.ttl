# Model Definitions

# Data Accountability

IQ: Story_DAMADataGovernanceFramework
a pmo:Story;
skos:inScheme dama:DataAccountability;
dct:title "Create a Data Governance Framework"@en;
.

IQ: Story_DAMARolesResponsibilities
a pmo:Story;
skos:inScheme dama:DataAccountability;
dct:title "Define clear Roles and Responsibilities"@en;
.

IQ: Story_DAMACorporateDataPolicy
a pmo:Story;
skos:inScheme dama:DataAccountability;
dct:title "Publish a corporate Data Policy"@en;
.

IQ: Story_DAMADocumentDataStandards
a pmo:Story;
skos:inScheme dama:DataAccountability;
dct:title "Document Data Standards"@en;
.

IQ: Story_DAMATrainDataAccountability
a pmo:Story;
skos:inScheme dama:DataAccountability;
dct:title "Train staff in Data Accountability"@en;
.

# Data Quality
IQ: Story_DAMADefineKPI
a pmo:Story;
skos:inScheme dama:DataQuality;
dct:title "Define KPIs and other measurements for key data items"@en;
.

IQ: Story_DAMAMonitorQualityImprovements
a pmo:Story;
skos:inScheme dama:DataQuality;
dct:title "Report and monitor data quality improvements"@en;
.
IQ: Story_DAMADevelopQualityImprovements
a pmo:Story;
skos:inScheme dama:DataQuality;
dct:title "Develop repeatable processes for data quality improvements"@en;
.
IQ: Story_DAMAImplementQualityImprovements
a pmo:Story;
skos:inScheme dama:DataQuality;
dct:title "Implement data quality checks as BAU activities"@en;
.

# Data Culture

IQ: Story_DAMACultureRole
a pmo:Story;
skos:inScheme dama:DataCulture;
skos:inScheme dama:DataSteward;
skos:inScheme dama:DataQuality;
dct:title "Ensure data stewards understand their contribution to data quality"@en;
.

IQ: Story_DAMACultureBenefit
a pmo:Story;
skos:inScheme dama:DataCulture;
skos:inScheme dama:DataQuality;
dct:title "Promote benefits of better data quality"@en;
.

IQ: Story_DAMACultureEngage
a pmo:Story;
skos:inScheme dama:DataCulture;
dct:title "Engage in innovative ways to leverage data for strategic advantage"@en;
.

IQ: Story_DAMACultureCommunity
