# Model Definitions

:
rdfs:subClassOf frames:Framework;
a skos:ConceptScheme;
dct:title "Data Governance Models"@en;
skos:hasTopConcept IQ: Example;
.
:governance_process
skos:inScheme :;
skos:inScheme frames:Principle;
skos:inScheme dama:DataOwner;
skos:inScheme frames:Processes;
dct:title "Process Centric"@en;
dct:description "Process Owners are the Data Owners for all data created, amended and deleted by their business processes."@en;
rdfs:seeAlso [
a fab:Advantage;
dct:title "Works well where end-to-end processes are clearly defined."@en;
];
rdfs:seeAlso [
a fab:Advantage;
dct:title "Business processes naturally create and update data."@en;
];
rdfs:seeAlso [
a fab:Advantage;
dct:title "Data is a measure of process efficiency"@en;
];
rdfs:seeAlso [
a fab:Advantage;
dct:title "Data improvement usually requires process change"@en;
];
rdfs:seeAlso [
a fab:Advantage;
dct:title "Helps engage business stakeholders"@en;
];
.

:governance_system
skos:inScheme frames:Principle;
skos:inScheme :;
dct:title "Systems Centric"@en;
dct:description "Systems Owners are the Data Owners for all data created, amended and deleted by their IT systems."@en;
skos:inScheme dama:DataOwner;
skos:inScheme frames:Tools;
.
:governance_domain
skos:inScheme frames:Principle;
skos:inScheme :;
dct:title "Subject Matter Experts"@en;
dct:description "Domain Experts are the Data Owners for key Data Domains across the organisation."@en;
skos:inScheme dama:DataOwner;
skos:inScheme frames:People;
.
:governance_organisation
skos:inScheme frames:Principle;
skos:inScheme :;
dct:title "Line of Business"@en;
dct:description "Domain Experts are the Data Owners for key Data Domains across key business units."@en;
skos:inScheme dama:DataOwner;
.
:governance_blended
skos:inScheme frames:Principle;
skos:inScheme :;
dct:title "Blended"@en;
dct:description "In large and complex organisations, a mixture of the above models may often be employed."@en;
skos:inScheme :governance_process;
skos:inScheme :governance_system;
skos:inScheme :governance_domain;
skos:inScheme :governance_organisation;
.
