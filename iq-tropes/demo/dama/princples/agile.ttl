# Model Definitions
:
    a skos:ConceptScheme;
    dct:title "Agile Data Governance Principles"@en;
    skos:hasTopConcept gg:Example;
    rdfs:seeAlso <https://data.world>
.

:AGP_1
    a dama:Principle;
    skos:inScheme :;
    dct:title "Governance should increase transparency, trust, understanding, and speed—not obscurity, doubt, confusion, and delay."@en;
.
:AGP_2
    a dama:Principle;
    skos:inScheme :;
    dct:title "Start with the business problems and analytics questions you have today."@en;
.
:AGP_3
    a dama:Principle;
    skos:inScheme :;
    dct:title "Iterate quickly to build better habits and get to value faster."@en;
.
:AGP_4
    a dama:Principle;
    skos:inScheme :;
    dct:title "One person’s work should help everyone else’s."@en;
.
:AGP_5
    a dama:Principle;
    skos:inScheme :;
    dct:title "Give all stakeholders ways to add knowledge and improve data assets."@en;
.
:AGP_6
    a dama:Principle;
    skos:inScheme :;
    dct:title "Keep people, data, docs, and analysis connected and accessible from the beginning."@en;
.
:AGP_7
    a dama:Principle;
    skos:inScheme :;
    dct:title "Make documentation easy and iterative or it won’t happen."@en;
.
:AGP_8
    a dama:Principle;
    skos:inScheme :;
    dct:title "Promote good statistical and scientific methods."@en;
.
:AGP_9
    a dama:Principle;
    skos:inScheme :;
    dct:title "Analytics is valuable while it’s happening, not just when it’s 'done.'"@en;
.
:AGP_10
    a dama:Principle;
    skos:inScheme :;
    dct:title "Make the user experience twice as good as the products and practices it competes with to earn adoption."@en;
.
