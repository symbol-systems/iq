package systems.symbol.finder;

import dev.langchain4j.data.embedding.Embedding;
import dev.langchain4j.data.segment.TextSegment;
import dev.langchain4j.model.embedding.AllMiniLmL6V2EmbeddingModel;
import dev.langchain4j.model.embedding.EmbeddingModel;
import dev.langchain4j.store.embedding.EmbeddingMatch;
import dev.langchain4j.store.embedding.EmbeddingStore;
import dev.langchain4j.store.embedding.inmemory.InMemoryEmbeddingStore;
import org.eclipse.rdf4j.model.IRI;
import org.eclipse.rdf4j.model.util.Values;
import org.slf4j.Logger;
import org.slf4j.LoggerFactory;

import java.util.*;

public class SearchMatrix implements I_Search<IRI> {
	protected final Logger log = LoggerFactory.getLogger(getClass());
	private final int MAX_RESULTS =100;

	Map<Integer, float[]> vectorsById = new HashMap<>();
	Map<Integer, IRI> thingById = new HashMap<>();
	Map<IRI, Integer> idByThing = new HashMap<>();
	Map<IRI, Set<Integer>> indexByThing = new HashMap<>();
	I_Finder finder;

	public SearchMatrix(I_Finder finder) {
		this.finder = finder;
	}

	public void index(IRI iri, IRI concept, String content) {
		Embedding embed = finder.embed(content);
		Integer l = idByThing.get(iri);
		if ( l == null) {
			l = vectorsById.size();
			vectorsById.put(l, new float[MAX_RESULTS]);
		}
		long id = vectorsById.size();
		vectorsById.put(id,embed.vector());
		thingById.put(id,iri);
		Set<Long> longs = indexByThing.computeIfAbsent(concept, k -> new HashSet<>());
		indexByThing.put(concept, longs);
		longs.add(id);
	}

	@Override
	public Collection<IRI> search(String text, int maxResults, double minScore) {
		List<EmbeddingMatch<TextSegment>> found = finder.find(finder.embed(text), maxResults, minScore);
		List<IRI> results = new ArrayList<>();
		for(EmbeddingMatch<TextSegment> embeddingMatch: found) {
			results.add(Values.iri(embeddingMatch.embeddingId()));
		}
		return results;
	}

	public I_Search<T> byConcept(IRI concept) {
		return new I_Search<T>() {
			@Override
			public Collection<T> search(String text, int maxResults, double minScore) {
				return List.of();
			};
		}
	}

}