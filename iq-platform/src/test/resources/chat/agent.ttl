@prefix : <https://test.symbol.systems/cases#>.
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#>.
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix schema: <http://schema.org/>.
@prefix iq: <urn:systems.symbol:v0:iq:>.

: a iq:Agent;
   rdfs:label """
You follow a strict workflow.
1) Always output a concise but polite response confirming the user's intention.
2) Identify the action that will best match the user's intention.
3) For example: I want to fly to Timbuktu = "action: update_destination".
4) Make sure the information in the message is correctly processed.
5) If user question is off-topic, your action should be 'off-topic'.

    """;
    iq:initial :chit_chat;
.
:consult
    rdfs:label "Ask a question to best plan the itinerary.";
    iq:to :chit_chat;
    iq:to :update_origin;
    iq:to :update_destinations;
    iq:to :update_travellers;
    iq:to :update_fare_class;
    iq:to :update_traveller_ages;
    iq:to :check_availability;
    iq:to :consult;
    iq:to :inappropriate;
.
:inappropriate
    rdfs:label "Reply to inappropriate";
    iq:to :consult;
    iq:to :inappropriate;
.

:chit_chat
    rdfs:label "Reply politely to smalltalk but keep user on task";
    iq:to :chit_chat;
    iq:to :consult;
    iq:to :update_destinations;
    iq:to :update_travellers;
.
:update_origin
    rdfs:label "Set Departure Location";
    iq:slot :trip_origin;
    iq:to :consult;
    iq:to :inappropriate;
.
:update_destinations
    rdfs:label "Set Destination Location";
    iq:slot :trip_destination;
    iq:to :inappropriate;
    iq:to :consult;
.
:update_travellers
    rdfs:label "Set Travellers Names and/or Details";
    iq:slot :traveller_details;
    iq:to :update_destinations;
    iq:to :consult;
    iq:to :inappropriate;
.
:update_fare_class
    rdfs:label "Select Fare Class";
    iq:slot :fare_class;
    iq:to :consult;
    iq:to :inappropriate;
.
:update_traveller_ages
    rdfs:label "Select Ages of Travelers";
    iq:slot :traveller_details;
    iq:to :consult;
    iq:to :inappropriate;
.

:traveller_details
    iq:slot :traveller_name;
    iq:slot :traveller_age_class;
.

:check_availability
    rdfs:label "Check Flight Availability";
    schema:url "https://check.flightapi.com/{origin}/{destination}/{fare_class}";
    iq:to :update_missing_info;
    iq:to :consult;
    iq:to :inappropriate;
.

:update_missing_info
    rdfs:label "Prompt for Missing Information";
    iq:to :consult;
.
