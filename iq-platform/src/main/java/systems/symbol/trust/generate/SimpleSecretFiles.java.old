package systems.symbol.secrets;

import com.google.gson.Gson;
import core.systems.symbol.HasSecrets;
import org.slf4j.Logger;
import org.slf4j.LoggerFactory;

import javax.crypto.spec.SecretKeySpec;
import java.io.File;
import java.io.FileInputStream;
import java.io.FileOutputStream;
import java.io.IOException;
import java.nio.charset.StandardCharsets;
import java.security.KeyStore;
import java.security.KeyStoreException;
import java.security.NoSuchAlgorithmException;
import java.security.UnrecoverableEntryException;
import java.security.cert.CertificateException;
import java.util.HashMap;
import java.util.Map;
import java.util.Set;

/**
 * Manage secrets stored in a set of Java Keystore files
 *
 * See https://www.baeldung.com/java-keystore
 *
 */
public class SimpleSecretFiles implements HasSecrets {
private static final Logger log = LoggerFactory.getLogger( SimpleSecretFiles.class );
KeyStore keystore;
KeyStore.ProtectionParameter protectionParameter = null;
char[] password;
String type = "PKCS12";
private String algorithm = "DSA";
File file;

public SimpleSecretFiles(File store, String password) throws CertificateException, KeyStoreException, IOException, NoSuchAlgorithmException {
this.password=password.toCharArray();
this.protectionParameter = new KeyStore.PasswordProtection(this.password);
init(store);
}

public void init(File file) throws IOException, CertificateException, NoSuchAlgorithmException, KeyStoreException {
this.file = file;
if (file.exists()) {
keystore = KeyStore.getInstance( file, password );
keystore.load( new FileInputStream(file), password);
} else {
// if not exists, create a new one
keystore = KeyStore.getInstance(type);
keystore.load(null, password);
keystore.store(new FileOutputStream(file), password);
}
}

public Map<String, String> secret(String name) throws UnrecoverableEntryException, NoSuchAlgorithmException, KeyStoreException {
KeyStore.Entry entry = keystore.getEntry(name, protectionParameter);
if (entry==null) return null;
if (entry instanceof KeyStore.SecretKeyEntry) {
KeyStore.SecretKeyEntry secretKeyEntry = (KeyStore.SecretKeyEntry) entry;
byte[] encoded = secretKeyEntry.getSecretKey().getEncoded();
new Gson().fromJson( new String(encoded) , HashMap.class);
}

Map<String, String> unsecured = new HashMap();
Set<KeyStore.Entry.Attribute> attributes = entry.getAttributes();
for( KeyStore.Entry.Attribute attribute: attributes) {
unsecured.put( attribute.getName(), attribute.getValue());
}
return unsecured;
}

void save(String name, Map<String, String> namedMap) throws UnrecoverableEntryException, NoSuchAlgorithmException, KeyStoreException, IOException, CertificateException {
KeyStore.Entry entry = keystore.getEntry(name, protectionParameter);
if (entry == null) {
//byte[] dummyKey = name.getBytes(StandardCharsets.UTF_8);
//SecretKeySpec keySpec = new SecretKeySpec(dummyKey, algorithm);
//Set<KeyStore.Entry.Attribute> attributes = new HashSet<>();
//namedMap.forEach( (k, v) -> {
//PKCS12Attribute attribute = new PKCS12Attribute(k, v);
//attributes.add(attribute);
//});
//entry = new KeyStore.SecretKeyEntry(keySpec,attributes);
String json = new Gson().toJson(namedMap);
byte[] jsonBytes = json.getBytes(StandardCharsets.UTF_8);
SecretKeySpec keySpec = new SecretKeySpec(jsonBytes, algorithm);
entry = new KeyStore.SecretKeyEntry(keySpec);
}
keystore.setEntry(name, entry, protectionParameter);
keystore.store( new FileOutputStream(file), this.password);
}
}
