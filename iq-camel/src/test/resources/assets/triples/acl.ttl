:everyone_read_iq
a   acl:Authorization;
skos:prefLabel  "Anonymous Access to /iq/";
acl:accessTo<https://test.symbol.systems/iq/>;
acl:modeacl:Read;
acl:agent   acl:Anonymous;
.
