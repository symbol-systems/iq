public class SelectQueryProcessor extends AbstractCamelRDFProcessor {
String query;
protected boolean inferred = true;
protected int maxQueryTime = -1;

public SelectQueryProcessor(Repository repository, boolean inferred, int maxQueryTime, String query) {
super(repository);
this.query=query;
this.inferred=inferred;
this.maxQueryTime=maxQueryTime;

}

public void process(Exchange exchange) throws RDFHandlerException, MalformedQueryException, RepositoryException, IOException, QueryResultHandlerException, QueryEvaluationException {
Message in = exchange.getIn();
//Message out = exchange.getOut();
//Map<String,Object> headers = in.getHeaders();
//out.setHeaders(headers);

//log.info("camel.rdf4j.select.exchange: "+exchange.getExchangeId()+" @ "+component.iq);
//process(component.iq, exchange, exchange.getIn());
}

public void process(IQ iq, Exchange exchange, Message out) throws RDFHandlerException, MalformedQueryException, RepositoryException, QueryResultHandlerException, QueryEvaluationException {
log.info("camel.rdf4j.select.iq: "+iq.getIdentity());
Map namedMap = getMessageModel(exchange.getIn());
SPARQLMapper sparqlMapper = new SPARQLMapper(iq);
IRI queryIRI = iq.toIRI(this.query);
//String sparql = sparqlMapper.resolve(queryIRI);
//TupleQuery tupleQuery = sparqlMapper.query(sparql, namedMap);
//log.info("camel.rdf4j.select.query: "+this.query+"->"+(tupleQuery==null?"missing":"found"));
//if (tupleQuery==null) throw new QueryEvaluationException("Missing query: "+this.query);
//tupleQuery.setIncludeInferred(inferred);
//if (maxQueryTime>0) tupleQuery.setMaxExecutionTime(maxQueryTime);
//
//TupleQueryResult queryResult = tupleQuery.evaluate();

TupleQuery tupleQuery = sparqlMapper.query(sparqlMapper.findQuery(queryIRI), namedMap);
QueryResults.asModel(tupleQuery.);

List<Map<String,Object>> models = sparqlMapper.models(queryIRI, namedMap);
log.info("camel.rdf4j.select.models: "+queryIRI+" -> "+models);
//out.setHeader("Content-Type", TupleQueryResultFormat.JSON);
out.setHeader("x-iq-operation", queryIRI.stringValue());
out.setBody(models);
}

}
