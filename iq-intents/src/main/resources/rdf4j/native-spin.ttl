#
# Sesame configuration template for a native repository with a SPIN reasoner 
#
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#>.
@prefix config: <tag:rdf4j.org,2023:config/>.
@prefix sp: <http://spinrdf.org/sp#>.


[] a config:Repository ;
   config:rep.id "{%id|native-spin%}";
   rdfs:label "{%title|Native store with basic SPIN support%}";
   config:rep.impl [
      config:rep.type "openrdf:SailRepository";
      config:sail.impl [
         config:sail.type "openrdf:SpinSail";
         config:spin.axiomClosureNeeded true ;
         config:sail.delegate [
				config:sail.type "openrdf:NativeStore";
				config:sail.iterationCacheSyncThreshold "{%Query Iteration Cache sync threshold|10000%}";
				config:native.tripleIndexes "{%Triple indexes|spoc,posc%}";
				config:sail.evaluationStrategyFactory "{%EvaluationStrategyFactory|org.eclipse.rdf4j.query.algebra.evaluation.impl.StrictEvaluationStrategyFactory%}"
			 ]
		 ]
      ] .
