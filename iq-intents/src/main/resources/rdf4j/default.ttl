#
# Sesame configuration template for a native RDF repository with
# RDF Schema inferencing
#
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#>.
@prefix config: <tag:rdf4j.org,2023:config/>.


[] a config:Repository ;
   config:rep.id "{%id|default%}";
   rdfs:label "{%title|Native RDF inferencing%}";
   config:rep.impl [
  config:rep.type "openrdf:SailRepository";
  config:sail.impl [
 config:sail.type "openrdf:NativeStore";
	  config:sail.iterationCacheSyncThreshold "{%Query Iteration Cache size|10000%}";
 config:native.tripleIndexes "{%Triple indexes|spoc,posc%}";
 config:sail.evaluationStrategyFactory "{%EvaluationStrategyFactory|org.eclipse.rdf4j.query.algebra.evaluation.impl.StrictEvaluationStrategyFactory%}"
  ]
   ].
