#
# Sesame configuration template for a main-memory repository with SHACL
#
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#>.
@prefix config: <tag:rdf4j.org,2023:config/>.


[] a config:Repository ;
   config:rep.id "{%id|memory-rdfs%}";
   rdfs:label "{%title|Memory store with SHACL%}";
   config:rep.impl [
      config:rep.type "openrdf:SailRepository";
      config:sail.impl [
         config:sail.type "rdf4j:ShaclSail";
         config:sail.delegate [
            config:sail.type "openrdf:MemoryStore";
	        config:sail.iterationCacheSyncThreshold "{%Query Iteration Cache size|10000%}";
            config:mem.persist {%Persist|true|false%} ;
            config:mem.syncDelay {%Sync delay|60%};
            config:sail.evaluationStrategyFactory "{%EvaluationStrategyFactory|org.eclipse.rdf4j.query.algebra.evaluation.impl.StrictEvaluationStrategyFactory%}"
         ]
      ]
   ].
