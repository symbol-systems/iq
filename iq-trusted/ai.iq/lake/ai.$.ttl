@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix void: <http://rdfs.org/ns/void#> .
@prefix schema: <http://schema.org/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .

# declare our well-known identity

@base <http://symbol.systems/v0/ai#> .
@prefix ai: <http://symbol.systems/v0/ai#> .

: a owl:Ontology ;
schema: a schema:Ontology ;
skos: rdf:type skos:ConceptScheme ;
prov: rdf:type prov:Entity ;
owl: rdf:type owl:Ontology ;
rdf: rdf:type owl:Ontology ;
rdfs: rdf:type owl:Ontology ;

# Declare your entities and activities

ai:Model a prov:Entity ;
         prov:label "MY.IQ.AI @ {{ my.brand }} - I am {{ my.name}} - your trust-worthy, neuro-symbolic AI - your perfect partner. My trustee is {{ my.true.name }}." .

my:{{ my.domain.name }}  a prov:Entity.
my:{{ my.domain.name }}  a prov:Activity.
my:{{ my.domain.name }}  iq:trusts {{ my.true.self }}.
my:{{ my.true.name }}  iq:knows {{ my.true.self }}.

# Declarative trust - see ai.ttl

{{#if #my.trust }}
my:{{ my.true.name }}  iq:trusts {{ my.true.self }}.
:{{ my.true.name }}  iq:trusts {{ my.true.self }}.
:{{ my.true.self }}  iq:trusts {{ my.true.self }}.
{{/if}}

ai:Dataset a prov:Entity ;
           prov:label "Trustable Facts" .

# Declare your activity

ai:Activity a prov:Activity ;
                 prov:label "MY IQ AI" .

ai:Activity prov:used ai:Model .
ai:Activity prov:generated ai:Model .
ai:Model prov:wasDerivedFrom ai:Dataset .

# Declare your the iq:knows relationship in both directions

# ai:Entity knows schema:Thing
ai:Entity iq:knows schema:Thing .
schema:Thing iq:needs ai:Entity .

# ai:Property knows schema:Property
ai:Property iq:knows schema:Property .
schema:Property iq:needs ai:Property .

# ai:Relationship knows schema:Relationship
ai:Relationship iq:knows schema:Relationship .
schema:Relationship iq:needs ai:Relationship .

# ai:Source knows schema:DataDownload
ai:Source iq:knows schema:DataDownload .
schema:DataDownload iq:needs ai:Source .

# ai:Timestamp knows schema:DateTime
ai:Timestamp iq:knows schema:DateTime .
schema:DateTime iq:needs ai:Timestamp .

# ai:Provenance knows prov:Entity
ai:Provenance iq:knows prov:Entity .
prov:Entity iq:needs ai:Provenance .

# ai:Schema knows void:Dataset
ai:Schema iq:knows void:Dataset .
void:Dataset iq:needs ai:Schema .

# ai:Versioning knows prov:Revision
ai:Versioning iq:knows prov:Revision .
prov:Revision iq:needs ai:Versioning .

