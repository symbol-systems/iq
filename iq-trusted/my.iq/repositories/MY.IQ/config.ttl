@prefix config: <tag:rdf4j.org,2023:config/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<#MY.IQ> a <http://www.openrdf.org/config/repository#Repository>, config:Repository;
  <http://www.openrdf.org/config/repository#repositoryID> "MY.IQ";
  <http://www.openrdf.org/config/repository#repositoryImpl> [
  <http://www.openrdf.org/config/repository#repositoryType> "openrdf:SailRepository";
  <http://www.openrdf.org/config/repository/sail#sailImpl> [
  <http://www.openrdf.org/config/sail#iterationCacheSyncThreshold> "10000"^^xsd:long;
  <http://www.openrdf.org/config/sail#sailType> "openrdf:NativeStore";
  <http://www.openrdf.org/config/sail/base#evaluationStrategyFactory> "org.eclipse.rdf4j.query.algebra.evaluation.impl.StrictEvaluationStrategyFactory";
  <http://www.openrdf.org/config/sail/native#tripleIndexes> "spoc,posc"
]
];
  rdfs:label "Native RDF inferencing" .
