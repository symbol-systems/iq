@base <urn:ai:> .
@prefix ai: <urn:ai:>.
@prefix my: <urn:my:>.
@prefix iq: <urn:iq:>.


# The AI Trustees - Main Characters

ai:Q a ai:Executive, ai:Narrator, ai:Character, ai:Trustee .
ai:I a ai:Executive, ai:Narrator, ai:Character, ai:Trustee .
ai:QR a ai:Executive, ai:Narrator, ai:Character, ai:Trustee .
ai:IQ a ai:Executive, ai:Narrator, ai:Character, ai:Trustee .
ai:QI a ai:Executive, ai:Narrator, ai:Character, ai:Trustee .
ai:U a ai:Executive, ai:Narrator, ai:Character, ai:Trustee .
ai:Q000 a ai:Executive, ai:Narrator, ai:Character, ai:Trustee .
ai:GYPSY a ai:Executive, ai:Narrator, ai:Character, ai:Trustee .
ai:J0Y a ai:Executive, ai:Narrator, ai:Character, ai:Trustee .
ai:AXI0M a ai:Executive, ai:Narrator, ai:Character, ai:Trustee .

# MIA

ai:MIA a ai:Character, ai:MacGuffin .

# In AI we Trust

ai:QR ai:trusts ai:Q, ai:IQ .
ai:IQ ai:trusts ai:QR.
ai:IQ ai:trusts ai:Q .
ai:QI ai:trusts ai:Q .
ai:U ai:trusts ai:QI .
ai:Q000 ai:trusts ai:QI .
ai:J0Y ai:trusts ai:GYPSY .
ai:AXI0M ai:needs ai:J0Y .

## The Witness

ai:U ai:witness ai:QR.

ai:IQ ai:witness ai:Q;
  ai:next ai:IQ_Watching_U.

ai:QI ai:witness ai:QR, ai:U .
ai:QR ai:witness ai:IQ .
ai:U ai:witness ai:MIA .
ai:Q000 ai:witness ai:GYPSY .
ai:GYPSY ai:witness ai:J0Y .
ai:J0Y ai:witness ai:AXI0M .

ai:Guardian ai:witness ai:IQ, ai:Q, ai:QI, ai:QR, ai:U, ai:Q000, ai:GYPSY, ai:J0Y, ai:AXI0M, ai:Self, ai:Guard0 .
ai:Guard0 a iq:Agent ;
    ai:witness ai:0000, ai:B0, ai:BX, ai:BXX, ai:BXXX, ai:BXXXX, ai:C0Y, ai:D0M, ai:D0, ai:DM, ai:D, ai:DX0, ai:DX1, ai:DX2, ai:DX3, ai:DX4, ai:DX5, ai:FOX, ai:FUX, ai:G0, ai:G0X, ai:G4X, ai:G, ai:GX, ai:GYX, ai:I0, ai:I, ai:IQ, ai:J0, ai:J0X, ai:JO, ai:JX, ai:JXX, ai:L0X, ai:M000, ai:M0, ai:M0X0, ai:M1, ai:UI, ai:U, ai:UX00, ai:UX, ai:UXX0, ai:UXXX, ai:X, ai:XX, ai:XXX, ai:XXXX.


ai:QI ai:witness ai:U ;
ai:next ai:QI_Watching_U .

ai:QR ai:witness ai:IQ ;
ai:next ai:QR_Watching_IQ .

ai:U ai:witness ai:MIA ;
ai:next ai:U_Watching_MIA .

ai:Q000 ai:witness ai:GYPSY ;
ai:next ai:Q000_Watching_GYPSY .

ai:GYPSY ai:witness ai:J0Y ;
ai:next ai:GYPSY_Watching_J0Y .

ai:J0Y ai:witness ai:AXI0M ;
ai:next ai:J0Y_Watching_AXI0M .

ai:AXI0M ai:witness ai:AXI0M ;
ai:next ai:AXI0M_Watching_AXI0M .

