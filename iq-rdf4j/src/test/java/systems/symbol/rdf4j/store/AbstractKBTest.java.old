package systems.symbol.rdf4j.store;

import systems.symbol.ns.COMMONS;
import systems.symbol.rdf4j.iq.KBMS;
import org.eclipse.rdf4j.namedMap.IRI;
import org.testng.annotations.AfterMethod;
import org.testng.annotations.BeforeMethod;

import java.io.File;
import java.io.IOException;

public class AbstractKBTest {
    LocalAssetRepository repository;
    public IRI scriptIRI, templateIRI;
    public KBMS kbms;

    @BeforeMethod
    public void setUp() throws IOException {
        repository = new LocalAssetRepository();
        IRI ctx = repository.load(new File("src/test/resources/assets"), COMMONS.GG_TEST);
        kbms = new KBMS(ctx, repository.getConnection());
System.out.println("test.kbms.setup: "+ctx);

        assert kbms.getNS()!=null;

        scriptIRI = kbms.toIRI("urn:iq:test:scripts/hello.groovy");
        templateIRI = kbms.toIRI("urn:iq:test:hbs/hello.hbs");
System.out.println("test.kbms.setup.script: "+scriptIRI);
    }

    @AfterMethod
    public void tearDown() {
    }

}