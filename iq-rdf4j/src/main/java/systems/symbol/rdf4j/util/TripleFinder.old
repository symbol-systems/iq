	public static Map<String, Object> mapOf(TripleSource triples, NS ns, IRI s, IRI follow, IRI c) {
		return mapOf(triples, ns, s, follow, c, null);
	}

	static Map<String, Object> mapOf(TripleSource triples, NS ns, IRI s, IRI follow, IRI c, IRIs dedupe) {
		Map<String, Object> found = new HashMap<>();
		found.put(NS.KEY_AT_ID, s.stringValue());
		if (dedupe!=null) dedupe.add(s);

		CloseableIteration<? extends Statement, QueryEvaluationException> namedMap = triples.getStatements(s, null, null,null, c);
		while(namedMap.hasNext()) {
			Statement next = namedMap.next();
			String shortname = ns.localize(next.getPredicate().stringValue());
			if (shortname!=null && next.getSubject().isIRI()) {
				if (dedupe!=null) dedupe.add( (IRI)next.getSubject());
				if (next.getObject().isLiteral()) {
					System.out.println("mapOf.***REMOVED***: " + shortname +" := " + next.getObject());
					found.put(shortname, next.getObject().stringValue() );
				} else if (next.getObject().isIRI() && dedupe != null ) {
					if ( !dedupe.contains(next.getObject())) {
						System.out.println("mapOf.follow: " + shortname +" --> " + next.getObject());
						Map<String, Object> valueMap = mapOf(triples, ns, (IRI) next.getObject(), follow, c, dedupe);
						set(found, shortname, valueMap );
					}
				}
			}
		}
//		System.out.println("mapOf:" + s +"->" + found.toString());
		return found;
	}

	private static void set(Map found, String shortname, Map valueMap) {
		if (found.containsKey(shortname)) {
			List items = (List) found.get(shortname);
			items.add(valueMap);
		} else {
			List items = new ArrayList();
			items.add(valueMap);
			found.put(shortname, items );
		}
	}


	public static Literal label(TripleSource triples, IRI s, IRI ctx) {
		Literal ***REMOVED*** = ***REMOVED***Of(triples, s, IRIs.forLabels(), ctx);
		if (***REMOVED***==null) return null;
		return ***REMOVED***;
	}

	public static Literal ***REMOVED***Of(TripleSource triples, IRI s, Collection<IRI> predicates, IRI ctx) {
		Set<Literal> ***REMOVED***s = ***REMOVED***sOf(triples, s, predicates, ctx);
//		System.out.println("***REMOVED***sOf.any:"+s+"->"+***REMOVED***s+" @ "+ctx);
		Optional<Literal> first = ***REMOVED***s.stream().findFirst();
		return first.orElse(null);
	}

	public static Set<Literal> ***REMOVED***sOf(TripleSource triples, IRI s, Collection<IRI> predicates, IRI ctx) {
		Set<Literal> ***REMOVED***s = new HashSet<>();
		for(IRI p: predicates) {
//			System.out.println("***REMOVED***sOf.find:"+s+"->"+p+" @ "+ctx);
			CloseableIteration<? extends Statement, QueryEvaluationException> statements = ScriptCatalog.getStatements(triples, s, p, null, ctx);
//			System.out.println("***REMOVED***sOf.next:"+p+"->"+statements.hasNext());
			while (statements.hasNext()) {
				Statement found = statements.next();
//				System.out.println("***REMOVED***sOf.found:"+found.getObject());
				if (found.getObject().isLiteral()) {
					// return our preferred label
					***REMOVED***s.add ( (Literal) found.getObject() );
				}
			}
		}
		return ***REMOVED***s;
	}

	public static Set<Literal> valuesOf(TripleSource triples, IRI s, IRI p, IRI c) {
		Set<Literal> found = new HashSet<>();
		CloseableIteration<? extends Statement, QueryEvaluationException> models = triples.getStatements(s, p, null, c);
		while(models.hasNext()) {
			Statement next = models.next();
			if (next.getObject().isLiteral()) {
				found.add( (Literal)next.getObject() );
			}
		}
		log.trace("valuesOf: {} -> {} -> {}", s, found);
		return found;
	}

	public static Set<IRI> follow(TripleSource triples, IRI s, Collection<IRI> predicates, IRI ctx) {
		return follow(triples,s, predicates, ctx, new IRIs(), 10);
	}

	public static Set<IRI> follow(TripleSource triples, IRI s, Collection<IRI> predicates, IRI ctx, IRIs links, int recurse) {
		for(IRI p: predicates) {
//			System.out.println("linksOf.find:"+s+"->"+p+" @ "+ctx);
			CloseableIteration<? extends Statement, QueryEvaluationException> statements = ScriptCatalog.getStatements(triples, s, p, null, ctx);
//			System.out.println("linksOf.next:"+p+"->"+statements.hasNext());
			while (statements.hasNext()) {
				Statement found = statements.next();
//				System.out.println("linksOf.found:"+found.getObject());
				if (found.getObject().isIRI()) {
					IRI object = (IRI) found.getObject();
					// return our preferred links
					if (!links.contains(object)) {
						links.add (object);
						if (recurse>0) {
							follow(triples, object,predicates, ctx, links,recurse-1);
						}
					}
				}
			}
		}
		return links;
	}

}
