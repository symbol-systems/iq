#
# Sesame configuration template for a (proxy for a) remote repository
#
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#>.
@prefix config: <tag:rdf4j.org,2023:config/>.

[] a config:Repository ;
   config:rep.impl [
  config:rep.type "openrdf:HTTPRepository";
  config:http.url <{%Sesame server location|http://localhost:8080/openrdf-sesame%}/repositories/{%Remote repository ID|SYSTEM%}>
   ];
   config:rep.id "{%Local repository ID|SYSTEM@localhost%}";
   rdfs:label "{%title|SYSTEM repository @localhost%}" .
